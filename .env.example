# =============================================================================
# Solodoc Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit actual secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=solodoc
POSTGRES_USER=solodoc
POSTGRES_PASSWORD=CHANGE_ME_IN_ENV

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_IN_ENV
MINIO_BUCKET=solodoc-dev
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# SEQ (Structured logging)
# -----------------------------------------------------------------------------
SEQ_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
JWT_ISSUER=solodoc.app
JWT_AUDIENCE=solodoc.app
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# -----------------------------------------------------------------------------
# BankID / ID-porten (Tenant registration)
# -----------------------------------------------------------------------------
BANKID_CLIENT_ID=CHANGE_ME
BANKID_CLIENT_SECRET=CHANGE_ME
BANKID_AUTHORITY=https://test.idporten.no

# -----------------------------------------------------------------------------
# DeepL (Translation)
# -----------------------------------------------------------------------------
DEEPL_API_KEY=CHANGE_ME
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# -----------------------------------------------------------------------------
# Anthropic (AI summaries + chatbot)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Email (Transactional)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@solodoc.no
EMAIL_FROM_NAME=Solodoc

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
