@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="@_mapId" style="height:400px;border-radius:12px;border:1px solid #e9ecef;"></div>

@code {
    [Parameter] public double? Latitude { get; set; }
    [Parameter] public double? Longitude { get; set; }
    [Parameter] public string? GeofenceGeoJson { get; set; }
    [Parameter] public double? GeofenceRadiusMeters { get; set; }
    [Parameter] public string? Address { get; set; }
    [Parameter] public EventCallback<GeofenceData> OnGeofenceChanged { get; set; }

    private readonly string _mapId = $"geofence-map-{Guid.NewGuid():N}";
    private DotNetObjectReference<GeofenceEditor>? _dotnetRef;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await InitMapAsync();
        }
    }

    private async Task InitMapAsync()
    {
        if (_initialized) return;

        // Wait for Leaflet Draw to be available (CDN might be slow)
        for (var i = 0; i < 20; i++)
        {
            var ready = await JS.InvokeAsync<bool>("eval",
                "typeof L !== 'undefined' && typeof L.Control !== 'undefined' && typeof L.Control.Draw !== 'undefined' && typeof mapInterop !== 'undefined' && typeof mapInterop.initGeofenceEditor === 'function'");
            if (ready) break;
            await Task.Delay(250);
        }

        try
        {
            await JS.InvokeVoidAsync("mapInterop.initGeofenceEditor",
                _mapId, Latitude, Longitude, GeofenceGeoJson, GeofenceRadiusMeters, _dotnetRef);

            if (Latitude is null && Longitude is null && !string.IsNullOrWhiteSpace(Address))
                await JS.InvokeVoidAsync("mapInterop.geocodeAndPan", _mapId, Address);

            _initialized = true;
        }
        catch
        {
            // Silently fail — map is non-critical
        }
    }

    [JSInvokable("OnGeofenceChanged")]
    public async Task HandleGeofenceChanged(string? geojson, double? radius, double? lat, double? lng)
    {
        await OnGeofenceChanged.InvokeAsync(new GeofenceData(lat, lng, geojson, radius));
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("mapInterop.destroy", _mapId); } catch { }
        _dotnetRef?.Dispose();
    }

    public record GeofenceData(double? Latitude, double? Longitude, string? GeoJson, double? RadiusMeters);
}
