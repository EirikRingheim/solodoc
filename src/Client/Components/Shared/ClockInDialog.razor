@using Solodoc.Shared.Hours
@using Solodoc.Shared.Projects
@using Solodoc.Shared.Locations
@inject ProjectService ProjectService
@inject JobService JobService
@inject LocationService LocationService

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Style="color:#00B5A6;" />
            <MudText Typo="Typo.h6" Style="font-weight:600;">Stemple inn</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudSkeleton Height="56px" Class="mb-3" />
            <MudSkeleton Height="56px" Class="mb-3" />
            <MudSkeleton Height="56px" />
        }
        else
        {
            <MudStack Spacing="3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Velg hva du jobber med</MudText>

                @* Prosjekt (grouped by parent) *@
                <MudSelect T="Guid?" Value="_selectedProjectId" ValueChanged="OnProjectChanged" Label="Prosjekt" Variant="Variant.Outlined"
                           Clearable="true" AdornmentIcon="@Icons.Material.Filled.Folder"
                           Placeholder="Velg prosjekt...">
                    @foreach (var p in _projects.Where(p => p.ParentProjectId is null))
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)p.Id)">@p.Name</MudSelectItem>
                        @foreach (var sub in _projects.Where(s => s.ParentProjectId == p.Id))
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)sub.Id)">
                                <span style="padding-left:16px;color:#6B7280;">↳ @sub.Name</span>
                            </MudSelectItem>
                        }
                    }
                </MudSelect>

                @* Oppdrag *@
                <MudSelect T="Guid?" Value="_selectedJobId" ValueChanged="OnJobChanged" Label="Oppdrag" Variant="Variant.Outlined"
                           Clearable="true" AdornmentIcon="@Icons.Material.Filled.Handyman"
                           Placeholder="Velg oppdrag...">
                    @foreach (var j in _jobs)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)j.Id)">@j.Description</MudSelectItem>
                    }
                </MudSelect>

                @* Lokasjon *@
                <MudSelect T="Guid?" Value="_selectedLocationId" ValueChanged="OnLocationChanged" Label="Lokasjon" Variant="Variant.Outlined"
                           Clearable="true" AdornmentIcon="@Icons.Material.Filled.LocationOn"
                           Placeholder="Velg lokasjon...">
                    @foreach (var l in _locations)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)l.Id)">@l.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudDivider />

                @* Kategori *@
                <MudSelect T="string" Label="Kategori" @bind-Value="_selectedCategory"
                           Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Category">
                    <MudSelectItem T="string" Value="@("Arbeid")">Arbeid</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Reise")">Reise</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Kontorarbeid")">Kontorarbeid</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Lagerarbeid")">Lagerarbeid</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Kurs")">Kurs/opplæring</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Annet")">Annet</MudSelectItem>
                </MudSelect>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Disabled="@(_loading || !HasSelection)"
                   Style="text-transform:none;background:#00B5A6;color:#fff;border-radius:8px;">
            Stemple inn
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<ProjectListItemDto> _projects = [];
    private List<JobListItemDto> _jobs = [];
    private List<LocationListItemDto> _locations = [];
    private bool _loading = true;
    private string _selectedCategory = "Arbeid";

    private Guid? _selectedProjectId;
    private Guid? _selectedJobId;
    private Guid? _selectedLocationId;

    private bool HasSelection => _selectedProjectId.HasValue || _selectedJobId.HasValue || _selectedLocationId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        var projectsTask = ProjectService.GetActiveProjectsAsync();
        var jobsTask = JobService.GetJobsAsync(1, 100, null, null, false);
        var locationsTask = LocationService.GetLocationsAsync();

        try { await Task.WhenAll(projectsTask, jobsTask, locationsTask); } catch { }

        _projects = projectsTask.IsCompletedSuccessfully ? projectsTask.Result : [];
        _jobs = jobsTask.IsCompletedSuccessfully
            ? jobsTask.Result.Items.Where(j => j.Status == "Aktiv").ToList()
            : [];
        _locations = locationsTask.IsCompletedSuccessfully ? locationsTask.Result : [];

        _loading = false;
    }

    private void OnProjectChanged(Guid? val) { _selectedProjectId = val; if (val.HasValue) { _selectedJobId = null; _selectedLocationId = null; } }
    private void OnJobChanged(Guid? val) { _selectedJobId = val; if (val.HasValue) { _selectedProjectId = null; _selectedLocationId = null; } }
    private void OnLocationChanged(Guid? val) { _selectedLocationId = val; if (val.HasValue) { _selectedProjectId = null; _selectedJobId = null; } }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        var request = new ClockInRequest(
            _selectedProjectId, _selectedJobId,
            _selectedCategory, null, null);
        MudDialog.Close(DialogResult.Ok(request));
    }
}
