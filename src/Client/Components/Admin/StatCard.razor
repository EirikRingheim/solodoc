@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string? Sub { get; set; }
    [Parameter] public string Color { get; set; } = "#4361EE";
}

<div style="@($"border:1px solid {Color}30;border-radius:10px;padding:12px;background:{Color}08;height:100%;")">
    <div style="@($"font-size:1.4rem;font-weight:700;color:{Color};")">@Value</div>
    <div style="font-size:0.75rem;color:#6B7280;font-weight:500;">@Label</div>
    @if (Sub is not null)
    {
        <div style="font-size:0.65rem;color:#9CA3AF;margin-top:2px;">@Sub</div>
    }
</div>
