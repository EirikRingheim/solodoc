@page "/invite/{Id:guid}"
@attribute [AllowAnonymous]
@layout Solodoc.Client.Layout.AuthLayout
@using System.Net.Http.Json
@using Solodoc.Shared.Auth
@inject HttpClient Http
@inject Solodoc.Client.Services.AuthHttpService AuthService
@inject NavigationManager Navigation

<PageTitle>Solodoc - Invitasjon</PageTitle>

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="mb-6">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body1" Color="Color.Secondary">Laster invitasjon...</MudText>
    </MudStack>
}
else if (_invitation is null || _errorMessage is not null)
{
    <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Color="Color.Error" />
        <MudText Typo="Typo.h5" Style="font-weight:700;">Invitasjon ikke funnet</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">@(_errorMessage ?? "Denne invitasjonen finnes ikke eller er ugyldig.")</MudText>
    </MudStack>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
               Style="text-transform:none;border-radius:8px;" Href="/login">
        Gå til innlogging
    </MudButton>
}
else if (_invitation.Status != "Pending")
{
    <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" Color="Color.Warning" />
        <MudText Typo="Typo.h5" Style="font-weight:700;">Invitasjon ugyldig</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            @(_invitation.Status switch
            {
                "Accepted" => "Denne invitasjonen er allerede brukt.",
                "Revoked" => "Denne invitasjonen er tilbakekalt.",
                "Expired" => "Denne invitasjonen har utløpt.",
                _ => "Denne invitasjonen er ikke lenger gyldig."
            })
        </MudText>
    </MudStack>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
               Style="text-transform:none;border-radius:8px;" Href="/login">
        Gå til innlogging
    </MudButton>
}
else
{
    <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h4" Style="font-weight:700;">SoloDoc</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
            @_invitation.InvitedByName har invitert deg til <strong>@_invitation.TenantName</strong>
        </MudText>
    </MudStack>

    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-4 align-self-center">
        @_invitation.Role
    </MudChip>

    <MudTextField Value="@_invitation.Email" Label="E-postadresse" Variant="Variant.Outlined"
                  ReadOnly="true" FullWidth="true" Class="mb-3"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />

    @if (!string.IsNullOrEmpty(_submitError))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_submitError</MudAlert>
    }

    <MudTextField @bind-Value="_fullName" Label="Fullt navn" Variant="Variant.Outlined"
                  FullWidth="true" Class="mb-3"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />

    <MudTextField @bind-Value="_password" Label="Passord" Variant="Variant.Outlined"
                  InputType="@(_showPassword ? InputType.Text : InputType.Password)" FullWidth="true" Class="mb-1"
                  Adornment="Adornment.End"
                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                  OnAdornmentClick="() => _showPassword = !_showPassword" />

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
        Minst 8 tegn, en stor bokstav og ett tall
    </MudText>

    <MudTextField @bind-Value="_confirmPassword" Label="Bekreft passord" Variant="Variant.Outlined"
                  InputType="InputType.Password" FullWidth="true" Class="mb-4"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />

    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
               Size="Size.Large" Style="text-transform:none;border-radius:8px;font-weight:600;"
               OnClick="HandleAccept" Disabled="_submitting">
        @if (_submitting)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
        }
        Opprett konto og bli med
    </MudButton>

    <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
        <MudText Typo="Typo.body2" Color="Color.Secondary">Har du allerede en konto?</MudText>
        <MudLink Href="@($"/login?returnUrl=/invite/{Id}")" Typo="Typo.body2" Color="Color.Primary" Style="font-weight:500;">
            Logg inn
        </MudLink>
    </MudStack>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private InvitationDetailDto? _invitation;
    private bool _loading = true;
    private string? _errorMessage;

    private string _fullName = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string? _submitError;
    private bool _submitting;
    private bool _showPassword;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"api/invitations/{Id}");
            if (response.IsSuccessStatusCode)
            {
                _invitation = await response.Content.ReadFromJsonAsync<InvitationDetailDto>();
            }
            else
            {
                _errorMessage = "Invitasjonen ble ikke funnet.";
            }
        }
        catch
        {
            _errorMessage = "Kunne ikke laste invitasjonen. Sjekk nettverksforbindelsen.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleAccept()
    {
        _submitError = null;

        if (string.IsNullOrWhiteSpace(_fullName))
        {
            _submitError = "Fullt navn er påkrevd.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_password))
        {
            _submitError = "Passord er påkrevd.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _submitError = "Passordene er ikke like.";
            return;
        }

        if (_password.Length < 8)
        {
            _submitError = "Passordet må være minst 8 tegn.";
            return;
        }

        _submitting = true;

        try
        {
            var request = new AcceptInvitationRequest(_fullName, _password);
            var response = await Http.PostAsJsonAsync($"api/invitations/{Id}/accept", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AcceptInvitationResponse>();
                if (result?.Auth is not null)
                {
                    // Store tokens and select the tenant
                    await AuthService.StoreTokens(result.Auth);
                    await AuthService.SelectTenantAsync(result.TenantId);
                    Navigation.NavigateTo("/", forceLoad: false);
                }
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _submitError = error?.Error ?? "Noe gikk galt. Prøv igjen.";
            }
        }
        catch
        {
            _submitError = "Noe gikk galt. Sjekk nettverksforbindelsen.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private record ErrorResponse(string? Error);
}
