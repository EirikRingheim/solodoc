@page "/forgot-password"
@page "/reset-password"
@layout Solodoc.Client.Layout.AuthLayout
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - Glemt passord</PageTitle>

<MudPaper Elevation="0" Style="max-width:420px;margin:40px auto;border:1px solid #e9ecef;border-radius:12px;" Class="pa-6">
    @if (_resetToken is null)
    {
        @* Step 1: Request reset *@
        <MudText Typo="Typo.h5" Style="font-weight:700;text-align:center;" Class="mb-2">Glemt passord</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align:center;" Class="mb-4">
            Skriv inn e-postadressen din, så sender vi en lenke for å tilbakestille passordet.
        </MudText>

        <MudStack Spacing="3">
            <MudTextField @bind-Value="_email" Label="E-post" Variant="Variant.Outlined"
                          InputType="InputType.Email" Required="true" />

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }

            @if (_sent)
            {
                <MudAlert Severity="Severity.Success" Dense="true">
                    Hvis e-postadressen finnes i systemet, har vi sendt en lenke for tilbakestilling.
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RequestReset"
                       Disabled="_loading || _sent" FullWidth="true"
                       Style="text-transform:none;border-radius:8px;">
                @(_loading ? "Sender..." : "Send tilbakestillingslenke")
            </MudButton>
        </MudStack>

        <MudText Typo="Typo.body2" Style="text-align:center;margin-top:16px;">
            <MudLink Href="/login" Color="Color.Primary">Tilbake til innlogging</MudLink>
        </MudText>
    }
    else
    {
        @* Step 2: Set new password *@
        <MudText Typo="Typo.h5" Style="font-weight:700;text-align:center;" Class="mb-2">Nytt passord</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align:center;" Class="mb-4">
            Velg et nytt passord for kontoen din.
        </MudText>

        <MudStack Spacing="3">
            <MudTextField @bind-Value="_newPassword" Label="Nytt passord" Variant="Variant.Outlined"
                          InputType="InputType.Password" Required="true" />
            <MudTextField @bind-Value="_confirmPassword" Label="Bekreft passord" Variant="Variant.Outlined"
                          InputType="InputType.Password" Required="true" />

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResetPassword"
                       Disabled="_loading" FullWidth="true"
                       Style="text-transform:none;border-radius:8px;">
                @(_loading ? "Lagrer..." : "Sett nytt passord")
            </MudButton>
        </MudStack>
    }
</MudPaper>

@code {
    private string _email = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private string? _error;
    private string? _resetToken;
    private bool _loading;
    private bool _sent;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _resetToken = query["token"];
        _email = query["email"] ?? "";
    }

    private async Task RequestReset()
    {
        if (string.IsNullOrWhiteSpace(_email)) { _error = "Skriv inn e-postadressen din."; return; }
        _loading = true; _error = null;
        StateHasChanged();

        var r = await Http.PostAsJsonAsync("api/auth/forgot-password", new { email = _email });
        _sent = true; // Always show success (don't reveal if email exists)
        _loading = false;
    }

    private async Task ResetPassword()
    {
        if (_newPassword != _confirmPassword) { _error = "Passordene stemmer ikke overens."; return; }
        if (_newPassword.Length < 8) { _error = "Passord må være minst 8 tegn."; return; }
        _loading = true; _error = null;
        StateHasChanged();

        var r = await Http.PostAsJsonAsync("api/auth/reset-password",
            new { email = _email, token = _resetToken, newPassword = _newPassword });

        if (r.IsSuccessStatusCode)
        {
            Snackbar.Add("Passord oppdatert! Logg inn med det nye passordet.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        else
        {
            var err = await r.Content.ReadFromJsonAsync<ErrorDto>();
            _error = err?.Error ?? "Kunne ikke tilbakestille passordet. Lenken kan ha utløpt.";
        }
        _loading = false;
    }

    private record ErrorDto(string? Error);
}
