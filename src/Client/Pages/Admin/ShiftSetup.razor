    }

    // ── Confirmed deletes ──
    private Guid? _confirmDeleteId;
    private string _confirmDeleteName = "";
    private string _confirmDeleteType = "";
    private bool _confirmDialogOpen;

    private void RequestDelete(Guid id, string name, string type)
    {
        _confirmDeleteId = id;
        _confirmDeleteName = name;
        _confirmDeleteType = type;
        _confirmDialogOpen = true;
    }

    private async Task ConfirmDeleteShift(Guid id, string name) => RequestDelete(id, name, "shift");
    private async Task ConfirmDeleteRotation(Guid id, string name) => RequestDelete(id, name, "rotation");

    private async Task ExecuteDelete()
    {
        if (_confirmDeleteId is null) return;
        _confirmDialogOpen = false;

        bool ok = _confirmDeleteType switch
        {
            "shift" => await ShiftService.DeleteShiftAsync(_confirmDeleteId.Value),
            "rotation" => await ShiftService.DeleteRotationAsync(_confirmDeleteId.Value),
            _ => false
        };

        if (ok)
        {
            Snackbar.Add($"{_confirmDeleteName} slettet. Eksisterende planlagte skift beholdes i historikken.", Severity.Success);
            if (_confirmDeleteType == "shift") _shifts = await ShiftService.GetShiftsAsync();
            if (_confirmDeleteType == "rotation") _rotations = await ShiftService.GetRotationsAsync();
        }
        else Snackbar.Add("Kunne ikke slette", Severity.Error);

        _confirmDeleteId = null;
    }

    // ── Holiday rate ──
    private void UpdateHolidayRate(int idx, decimal newRate)
    {
        if (idx >= 0 && idx < _norwegianHolidays.Count)
            _norwegianHolidays[idx].RatePercent = newRate;
        // TODO: persist to database when save button is added
    }

