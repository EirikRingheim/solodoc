    {
        _otName = ""; _otRate = 50; _otPriority = _overtimeRules.Count + 1;
        _otWeekdays = true; _otSaturday = false; _otSunday = false; _otRedDays = false;
        _otDialogOpen = true;
    }

    private async Task SaveOvertimeRule()
    {
        var id = await ShiftService.CreateOvertimeRuleAsync(new CreateOvertimeRuleRequest(
            _otName, _otPriority, _otRate, _otWeekdays, _otSaturday, _otSunday, _otRedDays, null, null, null));
        if (id.HasValue)
        { Snackbar.Add("Regel opprettet", Severity.Success); _otDialogOpen = false; _overtimeRules = await ShiftService.GetOvertimeRulesAsync(); }
        else Snackbar.Add("Feil", Severity.Error);
    }

    // ── Overtime preset rules ──
    private async Task TogglePresetRule(PresetRule preset, bool enable)
    {
        if (enable)
        {
            await ShiftService.CreateOvertimeRuleAsync(new CreateOvertimeRuleRequest(
                preset.Name, preset.Priority, preset.RatePercent,
                preset.Weekdays, preset.Saturday, preset.Sunday, preset.RedDays,
                null, null, null));
            Snackbar.Add($"{preset.Name} aktivert", Severity.Success);
        }
        else
        {
            var existing = _overtimeRules.FirstOrDefault(r => r.Name == preset.Name);
            if (existing is not null)
            {
                await ShiftService.DeleteOvertimeRuleAsync(existing.Id);
                Snackbar.Add($"{preset.Name} deaktivert", Severity.Success);
            }
        }
        _overtimeRules = await ShiftService.GetOvertimeRulesAsync();
    }

