    private void EditAllowance(AllowanceRuleDto rule)
    {
        _editingAllowanceId = rule.Id;
        _alName = rule.Name; _alType = rule.Type; _alAmountType = rule.AmountType; _alAmount = rule.Amount;
        _alDialogOpen = true;
    }

    private async Task SaveAllowance()
    {
        var dto = new AllowanceRuleDto(_editingAllowanceId ?? Guid.Empty, _alName, _alType, _alAmountType, _alAmount, null, null, true);

        bool ok;
        if (_editingAllowanceId.HasValue)
            ok = await HoursService.UpdateAllowanceRuleAsync(_editingAllowanceId.Value, dto);
        else
            ok = await HoursService.CreateAllowanceRuleAsync(dto);

        if (ok)
        {
            Snackbar.Add(_editingAllowanceId.HasValue ? "Tillegg oppdatert" : "Tillegg opprettet", Severity.Success);
            _alDialogOpen = false;
            _allowanceRules = await HoursService.GetAllowanceRulesAsync();
        }
        else Snackbar.Add("Feil", Severity.Error);
    }

    private async Task DeleteAllowance(Guid id)
    {
        var ok = await HoursService.DeleteAllowanceRuleAsync(id);
        if (ok)
        {
            Snackbar.Add("Tillegg slettet", Severity.Success);
            _allowanceRules = await HoursService.GetAllowanceRulesAsync();
        }
        else Snackbar.Add("Kunne ikke slette", Severity.Error);
    }

    // ── Settings ──
