@page "/admin/shifts"
@attribute [Authorize]
@inject ShiftService ShiftService
@inject HoursService HoursService
@inject ISnackbar Snackbar

<PageTitle>Solodoc - Skift og overtid</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Skift, overtid og tillegg</MudText>

<MudTabs Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0 pt-4"
         ActivePanelIndex="_tab" ActivePanelIndexChanged="t => _tab = t">

    @* ═══ Tab 0: Skifttyper ═══ *@
    <MudTabPanel Text="Skifttyper" Icon="@Icons.Material.Filled.Schedule">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Skifttyper</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenNewShift" Style="text-transform:none;border-radius:8px;">Ny skifttype</MudButton>
        </MudStack>

        @if (_shifts.Count == 0)
        {
            <MudPaper Class="pa-8" Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen skifttyper opprettet</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="2">
                @foreach (var shift in _shifts)
                {
                    <MudItem xs="12" sm="6" md="4">
                        @{
                            var capturedShiftId = shift.Id;
                        }
                        <MudPaper Elevation="0" Style="@($"border:1px solid #e9ecef;border-left:4px solid {shift.Color};border-radius:12px;")" Class="pa-4">
                            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@shift.Name</MudText>
                                    @if (shift.IsWorkDay && shift.StartTime.HasValue && shift.EndTime.HasValue)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @shift.StartTime.Value.ToString("HH:mm") – @shift.EndTime.Value.ToString("HH:mm")
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @shift.NormalHours.ToString("0.#")t (pause: @shift.BreakMinutes min)
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Fridag</MudText>
                                    }
                                </MudStack>
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   Color="Color.Default" Title="Rediger"
                                                   OnClick="() => OpenEditShift(shift)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                                   Color="Color.Error" Title="Slett"
                                                   OnClick="async () => await ConfirmDeleteShift(capturedShiftId, shift.Name)" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    @* ═══ Tab 1: Rotasjoner ═══ *@
    <MudTabPanel Text="Rotasjoner" Icon="@Icons.Material.Filled.Loop">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Rotasjonsmonstre</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenNewRotation" Style="text-transform:none;border-radius:8px;">Ny rotasjon</MudButton>
        </MudStack>

        @if (_rotations.Count == 0)
        {
            <MudPaper Class="pa-8" Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Loop" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen rotasjoner opprettet</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            @foreach (var rot in _rotations)
            {
                var capturedRotId = rot.Id;
                <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-4 mb-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@rot.Name</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@rot.CycleLengthDays dager</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                           Color="Color.Error" Title="Slett"
                                           OnClick="async () => await ConfirmDeleteRotation(capturedRotId, rot.Name)" />
                        </MudStack>
                    </MudStack>
                    <div style="display:flex;gap:2px;flex-wrap:wrap;">
                        @foreach (var day in rot.Days)
                        {
                            <div style="width:28px;height:28px;border-radius:4px;background:@day.ShiftColor;display:flex;align-items:center;justify-content:center;font-size:0.6rem;color:#FFF;font-weight:600;"
                                 title="Dag @day.DayInCycle: @day.ShiftName">
                                @day.DayInCycle
                            </div>
                        }
                    </div>
                </MudPaper>
            }
        }
    </MudTabPanel>

    @* ═══ Tab 2: Overtidsregler ═══ *@
    <MudTabPanel Text="Overtidsregler" Icon="@Icons.Material.Filled.Timer">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Vanlige regler</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Aktiver regler som gjelder for din bedrift. Juster satsene etter behov.
        </MudText>

        @foreach (var preset in _presetOvertimeRules)
        {
            var capturedPreset = preset;
            var existing = _overtimeRules.FirstOrDefault(r => r.Name == preset.Name);
            var isEnabled = existing is not null;

            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-3 mb-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap:wrap;gap:4px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudCheckBox T="bool" Value="isEnabled"
                                     ValueChanged="async v => await TogglePresetRule(capturedPreset, v)"
                                     Color="Color.Primary" Dense="true" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@preset.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@preset.Description</MudText>
                        </MudStack>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="font-weight:600;color:#4361EE;">@preset.RatePercent%</MudText>
                </MudStack>
            </MudPaper>
        }

        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenNewOvertimeRule" Style="text-transform:none;border-radius:8px;" Class="mt-3 mb-3">
            Ny egendefinert regel
        </MudButton>

        <MudDivider Class="my-3" />
        <MudExpansionPanels Class="mt-3">
            <MudExpansionPanel Style="border:1px solid #e9ecef;border-radius:12px;">
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Error" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;">Røde dager (@_norwegianHolidays.Count helligdager)</MudText>
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        Juster sats per helligdag. Klikk på prosenten for å endre.
                    </MudText>
                    @for (var i = 0; i < _norwegianHolidays.Count; i++)
                    {
                        var idx = i;
                        var holiday = _norwegianHolidays[i];
                        <MudPaper Elevation="0" Style="border:1px solid #f1f3f5;border-radius:8px;" Class="pa-2 mb-1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Style="font-weight:500;">@holiday.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @holiday.Date
                                        @if (holiday.IsHalfDay) { <span> (halv rød, fra @(holiday.HalfDayCutoff?.ToString("HH:mm") ?? "12:00"))</span> }
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudNumericField T="decimal" Value="holiday.RatePercent"
                                                     ValueChanged="v => UpdateHolidayRate(idx, v)"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     Style="max-width:80px;" Min="0" Max="300"
                                                     Adornment="Adornment.End" AdornmentText="%" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudTabPanel>

    @* ═══ Tab 3: Tillegg ═══ *@
    <MudTabPanel Text="Tillegg" Icon="@Icons.Material.Filled.AddCircle">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Tilleggsregler</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenNewAllowance" Style="text-transform:none;border-radius:8px;">Nytt tillegg</MudButton>
        </MudStack>

        @foreach (var rule in _allowanceRules)
        {
            var captured = rule;
            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-3 mb-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@rule.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @rule.Amount @(rule.AmountType == "FixedKroner" ? "kr" : "%")
                            per @(rule.Type switch { "TimeBased" => "time", "DayBased" => "dag", "OperationBased" => "operasjon", "FixedPerDay" => "dag", _ => "time" })
                            @if (rule.TimeRangeStart.HasValue && rule.TimeRangeEnd.HasValue)
                            {
                                <span> (@rule.TimeRangeStart.Value.ToString("HH:mm")–@rule.TimeRangeEnd.Value.ToString("HH:mm"))</span>
                            }
                        </MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Primary" OnClick="() => EditAllowance(captured)" />
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                       Color="Color.Error" OnClick="async () => await DeleteAllowance(captured.Id)" />
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    </MudTabPanel>

    @* ═══ Tab 4: Innstillinger ═══ *@
    <MudTabPanel Text="Innstillinger" Icon="@Icons.Material.Filled.Settings">
        @if (_settings is not null)
        {
            <MudStack Spacing="3" Style="max-width:500px;">
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Beregningsmetode</MudText>
                <MudCheckBox T="bool" Value="_settings.OvertimeStackingMode" Label="Satser legges sammen"
                             ValueChanged="ToggleStacking" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(_settings.OvertimeStackingMode ? "Alle matchende satser summeres" : "Kun høyeste sats gjelder")
                </MudText>

                <MudDivider />
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Timebank</MudText>
                <MudCheckBox T="bool" Value="_settings.TimebankEnabled" Label="Aktiver timebank"
                             ValueChanged="ToggleTimebank" Color="Color.Primary" />
            </MudStack>
        }
    </MudTabPanel>
</MudTabs>

@* ═══ New Shift Dialog ═══ *@
<MudDialog @bind-Visible="_shiftDialogOpen" Options="_dlgOpts">
    <TitleContent><MudText Typo="Typo.h6">@(_editingShiftId.HasValue ? "Rediger skifttype" : "Ny skifttype")</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField T="string" @bind-Value="_sName" Label="Navn" Variant="Variant.Outlined" Placeholder="Dagskift" />

            @* Color palette instead of hex *@
            <MudText Typo="Typo.caption" Color="Color.Secondary">Farge</MudText>
            <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap;">
                @foreach (var c in _colorPalette)
                {
                    var capturedColor = c;
                    <div style="width:32px;height:32px;border-radius:6px;background:@c;cursor:pointer;border:@(_sColor == c ? "3px solid #1F2937" : "2px solid transparent");"
                         @onclick="() => _sColor = capturedColor"></div>
                }
            </MudStack>

            <MudCheckBox T="bool" @bind-Value="_sIsWork" Label="Arbeidsdag" Color="Color.Primary" />
            @if (_sIsWork)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="6"><MudTextField T="string" @bind-Value="_sStart" Label="Start" Variant="Variant.Outlined" Placeholder="06:00" /></MudItem>
                    <MudItem xs="6"><MudTextField T="string" @bind-Value="_sEnd" Label="Slutt" Variant="Variant.Outlined" Placeholder="18:00" /></MudItem>
                </MudGrid>
                <MudNumericField T="int" @bind-Value="_sBreak" Label="Pause (min)" Variant="Variant.Outlined" Min="0" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _shiftDialogOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveShift" Style="text-transform:none;border-radius:8px;">Lagre</MudButton>
    </DialogActions>
</MudDialog>

@* ═══ New Rotation Dialog ═══ *@
<MudDialog @bind-Visible="_rotDialogOpen" Options="_dlgOptsWide">
    <TitleContent><MudText Typo="Typo.h6">Ny rotasjon</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" @bind-Value="_rName" Label="Navn" Variant="Variant.Outlined" Placeholder="Tunnelskift 12/16" />

            <MudSelect T="string" @bind-Value="_rMode" Label="Oppsett" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("days")">Dager (syklus)</MudSelectItem>
                <MudSelectItem T="string" Value="@("weeks")">Uker</MudSelectItem>
            </MudSelect>

            @if (_rMode == "weeks")
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Definer ukene i rotasjonen:</MudText>
                @for (var wi = 0; wi < _rWeeks.Count; wi++)
                {
                    var weekIdx = wi;
                    <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;" Class="pa-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.caption" Style="font-weight:600;min-width:50px;">Uke @(weekIdx + 1)</MudText>
                            <MudSelect T="Guid" Value="_rWeeks[weekIdx]" Label="Skifttype" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" Style="flex:1;"
                                       ValueChanged="v => { _rWeeks[weekIdx] = v; StateHasChanged(); }">
                                @foreach (var s in _shifts)
                                {
                                    <MudSelectItem T="Guid" Value="s.Id">@s.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudStack>
                    </MudPaper>
                }
                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="() => _rWeeks.Add(_shifts.Count > 0 ? _shifts[0].Id : Guid.Empty)"
                           Style="text-transform:none;">Legg til uke</MudButton>
            }
            else
            {
                <MudNumericField T="int" @bind-Value="_rCycleLength" Label="Sykluslengde (dager)" Variant="Variant.Outlined" Min="1" Max="90" />

                @if (_rCycleLength > 0 && _shifts.Count > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Klikk på dager for å bytte skift:</MudText>
                    <div style="display:flex;gap:3px;flex-wrap:wrap;">
                        @for (var i = 1; i <= _rCycleLength; i++)
                        {
                            var dayNum = i;
                            _rDayShifts.TryGetValue(dayNum, out var assignedId);
                            var shift = assignedId != Guid.Empty ? _shifts.FirstOrDefault(s => s.Id == assignedId) : null;
                            var bg = shift?.Color ?? "#E5E7EB";

                            <div style="width:30px;height:30px;border-radius:4px;background:@bg;display:flex;align-items:center;justify-content:center;font-size:0.6rem;color:#FFF;font-weight:600;cursor:pointer;border:1px solid #D1D5DB;"
                                 title="Dag @dayNum: @(shift?.Name ?? "Ikke tildelt")"
                                 @onclick="() => CycleShiftForDay(dayNum)">
                                @dayNum
                            </div>
                        }
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Klikk for å bytte: @string.Join(" → ", _shifts.Select(s => s.Name))
                    </MudText>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _rotDialogOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRotation" Style="text-transform:none;border-radius:8px;">Lagre</MudButton>
    </DialogActions>
</MudDialog>

@* ═══ New Allowance Dialog ═══ *@
<MudDialog @bind-Visible="_alDialogOpen" Options="_dlgOpts">
    <TitleContent><MudText Typo="Typo.h6">@(_editingAllowanceId.HasValue ? "Rediger tillegg" : "Nytt tillegg")</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField T="string" @bind-Value="_alName" Label="Navn" Variant="Variant.Outlined" />
            <MudSelect T="string" @bind-Value="_alType" Label="Type" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("TimeBased")">Per time</MudSelectItem>
                <MudSelectItem T="string" Value="@("DayBased")">Per dag</MudSelectItem>
                <MudSelectItem T="string" Value="@("OperationBased")">Per operasjon</MudSelectItem>
                <MudSelectItem T="string" Value="@("FixedPerDay")">Fast per dag</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_alAmountType" Label="Belopstype" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("FixedKroner")">Kroner (kr)</MudSelectItem>
                <MudSelectItem T="string" Value="@("Percentage")">Prosent (%)</MudSelectItem>
            </MudSelect>
            <MudNumericField T="decimal" @bind-Value="_alAmount" Label="Belop" Variant="Variant.Outlined" Min="0" />

            @if (_shifts.Count > 0)
            {
                <MudSelect T="Guid?" @bind-Value="_alShiftId" Label="Knyttet til skift (valgfritt)" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var s in _shifts)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)s.Id)">@s.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _alDialogOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAllowance" Style="text-transform:none;border-radius:8px;">Lagre</MudButton>
    </DialogActions>
</MudDialog>

@* ═══ Delete Confirmation Dialog ═══ *@
<MudDialog @bind-Visible="_confirmDialogOpen" Options="_dlgOpts">
    <TitleContent><MudText Typo="Typo.h6">Bekreft sletting</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body1">
                Er du sikker på at du vil slette <strong>@_confirmDeleteName</strong>?
            </MudText>
            <MudAlert Severity="Severity.Warning" Dense="true">
                Eksisterende planoppforinger og historikk beholdes, men denne typen vil ikke lenger vaere tilgjengelig for nye tildelinger.
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmDialogOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ExecuteDelete"
                   Style="text-transform:none;border-radius:8px;">Slett</MudButton>
    </DialogActions>
</MudDialog>

@* ═══ Custom Overtime Rule Dialog ═══ *@
<MudDialog @bind-Visible="_otDialogOpen" Options="_dlgOpts">
    <TitleContent><MudText Typo="Typo.h6">Ny overtidsregel</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField T="string" @bind-Value="_otName" Label="Navn" Variant="Variant.Outlined" />
            <MudNumericField T="decimal" @bind-Value="_otRate" Label="Sats (%)" Variant="Variant.Outlined" Min="0" Step="10m" />
            <MudNumericField T="int" @bind-Value="_otPriority" Label="Prioritet (lavere = høyere)" Variant="Variant.Outlined" Min="1" />
            <MudText Typo="Typo.caption" Style="font-weight:600;">Gjelder for:</MudText>
            <MudStack Row="true" Spacing="2" Style="flex-wrap:wrap;">
                <MudCheckBox T="bool" @bind-Value="_otWeekdays" Label="Ukedager" Dense="true" />
                <MudCheckBox T="bool" @bind-Value="_otSaturday" Label="Lørdag" Dense="true" />
                <MudCheckBox T="bool" @bind-Value="_otSunday" Label="Søndag" Dense="true" />
                <MudCheckBox T="bool" @bind-Value="_otRedDays" Label="Røde dager" Dense="true" />
            </MudStack>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _otDialogOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveOvertimeRule" Style="text-transform:none;border-radius:8px;">Lagre</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private int _tab;
    private readonly DialogOptions _dlgOpts = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
    private readonly DialogOptions _dlgOptsWide = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };

    private List<ShiftDefinitionDto> _shifts = [];
    private List<RotationPatternDto> _rotations = [];
    private List<OvertimeRuleDto> _overtimeRules = [];
    private List<AllowanceRuleDto> _allowanceRules = [];
    private HoursSettingsDto? _settings;

    // Color palette
    private readonly string[] _colorPalette = [
        "#4361EE", "#3A86FF", "#0891B2", "#059669", "#16A34A",
        "#CA8A04", "#EA580C", "#DC2626", "#9333EA", "#7C3AED",
        "#6B7280", "#1F2937", "#7C2D12", "#155E75"
    ];

    // Shift dialog
