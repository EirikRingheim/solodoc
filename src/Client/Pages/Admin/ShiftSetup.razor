    {
        if (_settings is null) return;
        _settings = _settings with { OvertimeStackingMode = val };
        await ShiftService.UpdateHoursSettingsAsync(new UpdateHoursSettingsRequest(_settings.TimebankEnabled, val));
        Snackbar.Add("Oppdatert", Severity.Success);
    }

    private async Task ToggleTimebank(bool val)
    {
        if (_settings is null) return;
        _settings = _settings with { TimebankEnabled = val };
        await ShiftService.UpdateHoursSettingsAsync(new UpdateHoursSettingsRequest(val, _settings.OvertimeStackingMode));
        Snackbar.Add("Oppdatert", Severity.Success);
    }
