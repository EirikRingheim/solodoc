    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        var s = ShiftService.GetShiftsAsync();
        var r = ShiftService.GetRotationsAsync();
        var o = ShiftService.GetOvertimeRulesAsync();
        var a = HoursService.GetAllowanceRulesAsync();
        var st = ShiftService.GetHoursSettingsAsync();
        _shifts = await s; _rotations = await r; _overtimeRules = await o;
        _allowanceRules = await a; _settings = await st;
    }

    // ── Shift ──
    private void OpenNewShift()
    {
        _editingShiftId = null;
        _sName = ""; _sColor = "#4361EE"; _sStart = "07:00"; _sEnd = "15:00"; _sIsWork = true; _sBreak = 30;
        _shiftDialogOpen = true;
    }

    private async Task SaveShift()
    {
        var req = new CreateShiftDefinitionRequest(
            _sName, _sColor, _sIsWork, _sIsWork ? _sStart : null, _sIsWork ? _sEnd : null, _sBreak);

        bool ok;
        if (_editingShiftId.HasValue)
        {
            ok = await ShiftService.UpdateShiftAsync(_editingShiftId.Value, req);
            if (ok) Snackbar.Add("Skifttype oppdatert", Severity.Success);
        }
        else
        {
            var id = await ShiftService.CreateShiftAsync(req);
            ok = id.HasValue;
            if (ok) Snackbar.Add("Skifttype opprettet", Severity.Success);
        }

        if (ok)
        {
            _shiftDialogOpen = false;
            _shifts = await ShiftService.GetShiftsAsync();
        }
        else Snackbar.Add("Feil", Severity.Error);
    }

    // ── Rotation ──
    private void OpenNewRotation()
    {
        _rName = ""; _rCycleLength = 28; _rDayShifts = []; _rMode = "days";
        _rWeeks = [_shifts.Count > 0 ? _shifts[0].Id : Guid.Empty];
        _rotDialogOpen = true;
    }

    private void CycleShiftForDay(int dayNum)
    {
        _rDayShifts.TryGetValue(dayNum, out var current);
        var idx = _shifts.FindIndex(s => s.Id == current);
        _rDayShifts[dayNum] = _shifts[(idx + 1) % _shifts.Count].Id;
    }

    private async Task SaveRotation()
    {
        List<RotationDayInput> days;
        int cycleLen;

        if (_rMode == "weeks")
        {
            cycleLen = _rWeeks.Count * 7;
            days = [];
            for (var wi = 0; wi < _rWeeks.Count; wi++)
            {
                var shiftId = _rWeeks[wi];
                for (var d = 0; d < 7; d++)
                {
                    var dayInCycle = wi * 7 + d + 1;
                    // Weekdays = shift, weekend = first "off" shift or same shift
                    var isWeekend = d >= 5;
                    var offShift = _shifts.FirstOrDefault(s => !s.IsWorkDay);
                    days.Add(new RotationDayInput(dayInCycle, isWeekend && offShift is not null ? offShift.Id : shiftId));
                }
            }
        }
        else
        {
            cycleLen = _rCycleLength;
            days = [];
            for (var i = 1; i <= cycleLen; i++)
            {
                _rDayShifts.TryGetValue(i, out var sid);
                if (sid == Guid.Empty && _shifts.Count > 0) sid = _shifts[0].Id;
                days.Add(new RotationDayInput(i, sid));
            }
        }

        var id = await ShiftService.CreateRotationAsync(new CreateRotationPatternRequest(_rName, cycleLen, days));
        if (id.HasValue)
        {
            Snackbar.Add("Rotasjon opprettet", Severity.Success);
            _rotDialogOpen = false;
            _rotations = await ShiftService.GetRotationsAsync();
        }
        else Snackbar.Add("Feil", Severity.Error);
    }

