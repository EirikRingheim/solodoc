@page "/welcome"
@attribute [Authorize]
@layout Solodoc.Client.Layout.AuthLayout
@inject OnboardingService OnboardingService
@inject NavigationManager Navigation
@using Solodoc.Shared.Onboarding

<PageTitle>Solodoc - Velkommen</PageTitle>

<div style="max-width:700px;margin:0 auto;padding:24px;">
    @* Slide indicators *@
    <div style="display:flex;justify-content:center;gap:6px;margin-bottom:24px;">
        @for (var i = 0; i < _slides.Count; i++)
        {
            var bg = i == _current ? "#4361EE" : "#E5E7EB";
            <div style="@($"width:{(i == _current ? "24px" : "8px")};height:8px;border-radius:4px;background:{bg};transition:all 0.3s;")"></div>
        }
    </div>

    @if (_current < _slides.Count)
    {
        var slide = _slides[_current];

        <div style="text-align:center;margin-bottom:24px;">
            @* Device mockup with feature screenshot *@
            <div style="@($"width:280px;height:400px;margin:0 auto 24px;background:{slide.MockBg};border-radius:20px;padding:16px;display:flex;flex-direction:column;")">
                <div style="background:#fff;border-radius:12px;flex:1;padding:16px;overflow:hidden;display:flex;flex-direction:column;">
                    @((MarkupString)slide.MockContent)
                </div>
            </div>

            <h2 style="font-size:1.5rem;font-weight:700;color:#1B2A4A;margin:0 0 8px;">@slide.Title</h2>
            <p style="color:#6B7280;max-width:480px;margin:0 auto;line-height:1.6;">@slide.Description</p>
        </div>
    }

    @* Navigation *@
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <MudButton Variant="Variant.Text" OnClick="Skip"
                   Style="text-transform:none;color:#9CA3AF;">Hopp over</MudButton>

        <MudStack Row="true" Spacing="2">
            @if (_current > 0)
            {
                <MudButton Variant="Variant.Text" OnClick="Prev"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Style="text-transform:none;">Tilbake</MudButton>
            }
            @if (_current < _slides.Count - 1)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="Next"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           Style="text-transform:none;border-radius:10px;">Neste</MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="Finish"
                           StartIcon="@Icons.Material.Filled.Rocket"
                           Style="text-transform:none;border-radius:10px;min-width:160px;">
                    Kom i gang!
                </MudButton>
            }
        </MudStack>
    </div>
</div>

@code {
    private int _current;
    private List<SlideData> _slides = [];
    private string _industry = "bygg";

    protected override async Task OnInitializedAsync()
    {
        var status = await OnboardingService.GetStatusAsync();
        _industry = status?.IndustryType ?? "bygg";
        _slides = GetSlidesForIndustry(_industry);
    }

    private void Next() { if (_current < _slides.Count - 1) _current++; }
    private void Prev() { if (_current > 0) _current--; }
    private void Skip() => Navigation.NavigateTo("/", forceLoad: true);
    private void Finish() => Navigation.NavigateTo("/", forceLoad: true);

    private static List<SlideData> GetSlidesForIndustry(string industry) => industry switch
    {
        "bygg" => GetConstructionSlides(),
        "elektro" or "rorlegger" => GetTradesSlides(),
        "landbruk" => GetFarmingSlides(),
        _ => GetGenericSlides()
    };

