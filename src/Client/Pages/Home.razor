    private async Task OpenCheckInDialog()
    {
        _checkInTargetKey = null;

        // Load projects, jobs, locations in parallel
        var projectsTask = ProjectService.GetActiveProjectsAsync();
        var jobsTask = JobService.GetJobsAsync(1, 50, null, null, false);
        var locationsTask = LocationService.GetLocationsAsync();

        try { await Task.WhenAll(projectsTask, jobsTask, locationsTask); } catch { }

        _checkInProjects = projectsTask.IsCompletedSuccessfully ? projectsTask.Result : [];
        _checkInJobs = jobsTask.IsCompletedSuccessfully ? jobsTask.Result.Items : [];
        _checkInLocations = locationsTask.IsCompletedSuccessfully ? locationsTask.Result : [];

        _checkInDialogOpen = true;
    }

    private async Task ExecuteCheckIn()
    {
        if (string.IsNullOrEmpty(_checkInTargetKey)) return;

        try
        {
            var parts = _checkInTargetKey.Split(':', 2);
            var type = parts[0];
            var id = Guid.Parse(parts[1]);

            var request = new CheckInRequest(
                ProjectId: type == "p" ? id : null,
                JobId: type == "j" ? id : null,
                LocationId: type == "l" ? id : null,
                Source: "Manual",
                Latitude: null,
                Longitude: null);

            var ok = await CheckInService.CheckInAsync(request);
            _checkInDialogOpen = false;

            if (ok)
            {
                _checkInStatus = await CheckInService.GetMyStatusAsync();
                _siteOverview = await CheckInService.GetAllSitesAsync();
                Snackbar.Add("Sjekket inn!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Kunne ikke sjekke inn. Prov igjen.", Severity.Error);
            }
        }
        catch
        {
            _checkInDialogOpen = false;
            Snackbar.Add("Feil ved innsjekking.", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task HandleCheckOut()
    {
        try
        {
            var ok = await CheckInService.CheckOutAsync(new CheckOutRequest(null, null));
            if (ok)
            {
                _checkInStatus = await CheckInService.GetMyStatusAsync();
                _siteOverview = await CheckInService.GetAllSitesAsync();
                Snackbar.Add("Sjekket ut!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Kunne ikke sjekke ut. Prov igjen.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Feil ved utsjekking.", Severity.Error);
        }
        StateHasChanged();
    }

    public void Dispose()
    {
        _elapsedTimer?.Dispose();
    }
