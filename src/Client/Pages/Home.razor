@* ── Check-in dialog ── *@
<MudDialog @bind-Visible="_checkInDialogOpen" Options="_checkInDlgOpts">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Login" Style="color:#059669;" />
            <MudText Typo="Typo.h6" Style="font-weight:600;">Sjekk inn</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Velg hvor du sjekker inn</MudText>

            @* Prosjekt (grouped with sub-projects) *@
            <MudSelect T="Guid?" Value="_ciProjectId" ValueChanged="OnCiProjectChanged" Label="Prosjekt" Variant="Variant.Outlined"
                       Clearable="true" AdornmentIcon="@Icons.Material.Filled.Folder"
                       Placeholder="Velg prosjekt...">
                @foreach (var p in _checkInProjects.Where(p => p.ParentProjectId is null))
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)p.Id)">@p.Name</MudSelectItem>
                    @foreach (var sub in _checkInProjects.Where(s => s.ParentProjectId == p.Id))
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)sub.Id)">
                            <span style="padding-left:16px;color:#6B7280;">↳ @sub.Name</span>
                        </MudSelectItem>
                    }
                }
            </MudSelect>

            @* Oppdrag *@
            <MudSelect T="Guid?" Value="_ciJobId" ValueChanged="OnCiJobChanged" Label="Oppdrag" Variant="Variant.Outlined"
                       Clearable="true" AdornmentIcon="@Icons.Material.Filled.Handyman"
                       Placeholder="Velg oppdrag...">
                @foreach (var j in _checkInJobs)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)j.Id)">@j.Description</MudSelectItem>
                }
            </MudSelect>

            @* Lokasjon *@
            <MudSelect T="Guid?" Value="_ciLocationId" ValueChanged="OnCiLocationChanged" Label="Lokasjon" Variant="Variant.Outlined"
                       Clearable="true" AdornmentIcon="@Icons.Material.Filled.LocationOn"
                       Placeholder="Velg lokasjon...">
                @foreach (var l in _checkInLocations)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)l.Id)">@l.Name</MudSelectItem>
                }
            </MudSelect>

            @* ── Start timer toggle ── *@
            @if (_activeClock is null)
            {
                <MudDivider />
                <MudPaper Elevation="0" Style="@($"border:1px solid {(_ciAlsoStartClock ? "#4361EE" : "#E9ECEF")};border-radius:10px;background:{(_ciAlsoStartClock ? "#EBF0FF" : "#F9FAFB")};cursor:pointer;")"
                          Class="pa-3" @onclick="() => _ciAlsoStartClock = !_ciAlsoStartClock">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small"
                                     Style="@($"color:{(_ciAlsoStartClock ? "#4361EE" : "#9CA3AF")};")"/>
                            <div>
                                <div style="@($"font-weight:{(_ciAlsoStartClock ? "600" : "400")};font-size:0.85rem;color:{(_ciAlsoStartClock ? "#4361EE" : "#374151")};")">
                                    Start timeregistrering også
                                </div>
                                <div style="font-size:0.7rem;color:#9CA3AF;">Timer starter når du sjekker inn</div>
                            </div>
                        </MudStack>
                        <MudSwitch T="bool" Value="_ciAlsoStartClock" Color="Color.Primary"
                                   Style="margin:0;" />
                    </MudStack>
                </MudPaper>

                @if (_ciAlsoStartClock)
                {
                    <MudStack Spacing="2" Style="padding-left:12px;border-left:3px solid #4361EE;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Startet du egentlig tidligere? Juster starttid:
                        </MudText>
                        <MudTimePicker @bind-Time="_ciClockStartTime" Label="Starttid" Variant="Variant.Outlined"
                                       Editable="true" AmPm="false" />
                        <MudSelect T="string" @bind-Value="_ciClockCategory" Label="Kategori" Variant="Variant.Outlined" Dense="true">
                            <MudSelectItem T="string" Value="@("Arbeid")">Arbeid</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Reise")">Reise</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Kontorarbeid")">Kontorarbeid</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Lagerarbeid")">Lagerarbeid</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Kurs")">Kurs/opplæring</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Annet")">Annet</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _checkInDialogOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" OnClick="ExecuteCheckIn"
                   Disabled="@(!_ciProjectId.HasValue && !_ciJobId.HasValue && !_ciLocationId.HasValue)"
                   Style="text-transform:none;background:#059669;color:#fff;border-radius:8px;">Sjekk inn</MudButton>
    </DialogActions>
</MudDialog>

@* ── Photo lightbox ── *@
@if (_lightboxUrl is not null)
{
    <div @onclick="() => _lightboxUrl = null"
         style="position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:24px;">
        <img src="@_lightboxUrl" style="max-width:95%;max-height:95%;object-fit:contain;border-radius:8px;" />
        <div style="position:absolute;top:16px;right:16px;color:#fff;font-size:1.5rem;cursor:pointer;">✕</div>
    </div>
}

@* ── New announcement dialog ── *@
<MudDialog @bind-Visible="_showNewAnnouncement" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Ny kunngjøring</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" @bind-Value="_annTitle" Label="Tittel" Variant="Variant.Outlined" Required="true" />
            <MudTextField T="string" @bind-Value="_annBody" Label="Melding" Variant="Variant.Outlined" Lines="4" />
            <MudSelect T="int" @bind-Value="_annUrgency" Label="Prioritet" Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="1">Normal</MudSelectItem>
                <MudSelectItem T="int" Value="2">Viktig</MudSelectItem>
                <MudSelectItem T="int" Value="3">Kritisk</MudSelectItem>
            </MudSelect>
            <MudSwitch T="bool" @bind-Value="_annRequireAck" Label="Krev bekreftelse" Color="Color.Primary" />
            <div style="position:relative;">
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.CameraAlt"
                           Style="text-transform:none;border-radius:8px;">
                    @(_annPhotoKey is not null ? "Bilde lagt til" : "Legg til bilde")
                </MudButton>
                <InputFile OnChange="HandleAnnPhoto" accept="image/*"
                           style="position:absolute;inset:0;opacity:0;cursor:pointer;" />
            </div>
            <MudSelect T="string" @bind-Value="_annTarget" Label="Send til" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("all")">Alle ansatte</MudSelectItem>
                <MudSelectItem T="string" Value="@("select")">Velg mottakere...</MudSelectItem>
            </MudSelect>
            @if (_annTarget == "select" && _annEmployees.Count > 0)
            {
                <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;max-height:200px;overflow-y:auto;" Class="pa-2">
                    @foreach (var emp in _annEmployees)
                    {
                        var eid = emp.PersonId;
                        <MudCheckBox T="bool" Value="@_annSelectedPersons.Contains(eid)"
                                     ValueChanged="@(v => { if (v) _annSelectedPersons.Add(eid); else _annSelectedPersons.Remove(eid); })"
                                     Label="@emp.FullName" Dense="true" />
                    }
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showNewAnnouncement = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SendAnnouncement"
                   Disabled="@(string.IsNullOrWhiteSpace(_annTitle))"
                   Style="text-transform:none;border-radius:8px;">Send kunngjøring</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private DashboardSummaryDto _summary = new(0, 0m, 0, [], []);
    private ActiveClockDto? _activeClock;
    private TodayShiftDto? _todayShift;
    private List<SiteOverviewDto> _siteOverview = [];
    private List<AnnouncementDto> _announcements = [];
    private bool _showNewAnnouncement;
    private string _annTitle = "";
    private string _annBody = "";
    private int _annUrgency = 1;
    private bool _annRequireAck;
    private string? _annPhotoKey;
    private string _annTarget = "all";
    private HashSet<Guid> _annSelectedPersons = new();
    private List<Solodoc.Shared.Employees.EmployeeListItemDto> _annEmployees = [];
    private Dictionary<Guid, string> _annComments = new();
    private Dictionary<Guid, string> _photoUrls = new();
    private string? _lightboxUrl;

    private string GetAnnComment(Guid id) => _annComments.TryGetValue(id, out var v) ? v : "";
    private void SetAnnComment(Guid id, string val) => _annComments[id] = val;
    private List<ForefallendItemDto> _forefallendeItems = [];
    private bool _loading = true;
    private bool _announcementsLoading = true;
    private bool _forefallendeLoading = true;
    private bool _clockActionInProgress;
    private int _overdueCount;
    private string _userRole = "field-worker";
    private System.Threading.Timer? _elapsedTimer;

    // Check-in state
    private MyCheckInStatusDto? _checkInStatus;
    private bool _checkInDialogOpen;
    private Guid? _ciProjectId;
    private Guid? _ciJobId;
    private Guid? _ciLocationId;
    private bool _ciAlsoStartClock;
    private TimeSpan? _ciClockStartTime;
    private string _ciClockCategory = "Arbeid";
    private List<ProjectListItemDto> _checkInProjects = [];
    private List<JobListItemDto> _checkInJobs = [];
    private List<LocationListItemDto> _checkInLocations = [];
    private static readonly DialogOptions _checkInDlgOpts = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        // Determine user role
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.HasClaim("sa", "1"))
            _userRole = "admin";
        else
        {
            var roleValues = authState.User.Claims
                .Where(c => c.Type == "role" || c.Type.Contains("/role"))
                .Select(c => c.Value.ToLowerInvariant())
                .ToHashSet();
            if (roleValues.Contains("tenant-admin") || roleValues.Contains("tenantadmin") || roleValues.Contains("admin"))
                _userRole = "admin";
            else if (roleValues.Contains("project-leader") || roleValues.Contains("projectleader"))
                _userRole = "project-leader";
            else
                _userRole = "field-worker";
        }

        var summaryTask = DashboardService.GetSummaryAsync();
        var clockTask = HoursService.GetActiveClockAsync();
        var shiftTask = ShiftService.GetTodayShiftAsync();
        var announcementsTask = NotificationService.GetAnnouncementsAsync();
        var forefallendeTask = ForefallendeService.GetItemsAsync();

        try { await Task.WhenAll(summaryTask, clockTask, shiftTask, announcementsTask, forefallendeTask); } catch { }

        _summary = summaryTask.IsCompletedSuccessfully ? summaryTask.Result ?? _summary : _summary;
        _activeClock = clockTask.IsCompletedSuccessfully ? clockTask.Result : null;
        // If no server clock-in, check for local offline pending clock-in
        if (_activeClock is null)
        {
            try { _activeClock = await HoursService.GetLocalPendingClockInAsync(); } catch { }
        }
        _todayShift = shiftTask.IsCompletedSuccessfully ? shiftTask.Result : null;
        _announcements = announcementsTask.IsCompletedSuccessfully ? announcementsTask.Result : [];

        // Resolve announcement photo URLs (download through API, convert to data URL)
        foreach (var ann in _announcements.Where(a => !string.IsNullOrEmpty(a.PhotoFileKey)))
        {
            try
            {
                var r = await Api.GetAsync($"api/files/download/{ann.PhotoFileKey}");
                if (r.IsSuccessStatusCode)
                {
                    var bytes = await r.Content.ReadAsByteArrayAsync();
                    var ct2 = r.Content.Headers.ContentType?.MediaType ?? "image/png";
                    _photoUrls[ann.Id] = $"data:{ct2};base64,{Convert.ToBase64String(bytes)}";
                }
            }
            catch { }
        }

        // Load check-in status + overview (non-blocking)
        try
        {
            var statusTask = CheckInService.GetMyStatusAsync();
            var sitesTask = CheckInService.GetAllSitesAsync();
            await Task.WhenAll(statusTask, sitesTask);
            _checkInStatus = statusTask.Result;
            _siteOverview = sitesTask.Result;
        }
        catch { }
        _forefallendeItems = forefallendeTask.Result;
        _overdueCount = _forefallendeItems.Count(i => i.Column == "overdue");

        _loading = false;
        _announcementsLoading = false;
        _forefallendeLoading = false;

        if (_activeClock is not null)
        {
            StartElapsedTimer();
        }
    }

    private record KanbanColumnDef(string Key, string Label, Color LabelColor, string BorderColor, string BgColor);

    private static readonly KanbanColumnDef[] _kanbanColumns =
    [
        new("overdue", "OVER FRIST", Color.Error, "#E63946", "#FFF5F5"),
        new("this-week", "DENNE UKEN", Color.Warning, "#F4A261", "#FFF8F0"),
        new("this-month", "DENNE MÅNEDEN", Color.Default, "#E9ECEF", "#FAFAFA"),
        new("later", "SEINARE", Color.Default, "#ADB5BD", "#F8F9FA")
    ];

    private static string GetSiteIcon(string siteType) => siteType switch
    {
        "Prosjekt" => Icons.Material.Filled.Folder,
        "Oppdrag" => Icons.Material.Filled.Build,
        "Lokasjon" => Icons.Material.Filled.LocationOn,
        _ => Icons.Material.Filled.Place
    };

    private static string GetTypeIcon(string type) => type switch
    {
        "deviation" => Icons.Material.Filled.ReportProblem,
        "certification" => Icons.Material.Filled.VerifiedUser,
        "calendar" => Icons.Material.Filled.Event,
        "safety-round" => Icons.Material.Filled.HealthAndSafety,
        "hms-meeting" => Icons.Material.Filled.Groups,
        _ => Icons.Material.Filled.Assignment
    };

    private static string FormatDueDate(DateTimeOffset dueDate)
    {
        var diff = dueDate - DateTimeOffset.UtcNow;
        if (diff.TotalDays < -1)
            return $"Forfalt {(int)Math.Abs(diff.TotalDays)} dager";
        if (diff.TotalDays < 0)
            return "Forfalt i dag";
        if (diff.TotalDays < 1)
            return "I dag";
        if (diff.TotalDays < 2)
            return "I morgen";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays} dager";
        return dueDate.LocalDateTime.ToString("dd.MM.yyyy");
    }

    private void StartElapsedTimer()
    {
        _elapsedTimer?.Dispose();
        _elapsedTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private string FormatElapsed()
    {
        if (_activeClock is null) return "--:--:--";
        var elapsed = DateTimeOffset.UtcNow - _activeClock.StartTime;
        return $"{(int)elapsed.TotalHours:D2}:{elapsed.Minutes:D2}:{elapsed.Seconds:D2}";
    }

    private async Task OpenClockInDialog()
    {
        var parameters = new DialogParameters<ClockInDialog>();
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ClockInDialog>("Stemple inn", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is ClockInRequest request)
        {
            _clockActionInProgress = true;
            StateHasChanged();

            var id = await HoursService.ClockInAsync(request);
            if (id.HasValue)
            {
                _activeClock = await HoursService.GetActiveClockAsync();
                StartElapsedTimer();
                Snackbar.Add("Innstemplet!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Kunne ikke stemple inn. Prøv igjen.", Severity.Error);
            }

            _clockActionInProgress = false;
        }
    }

    private async Task HandleClockOut()
    {
        _clockActionInProgress = true;
        StateHasChanged();

        try
        {
            var result = await HoursService.ClockOutAsync(new ClockOutRequest(null, null));
            if (result is not null)
            {
                _activeClock = null;
                _elapsedTimer?.Dispose();
                _elapsedTimer = null;

                // Refresh summary to update hours
                try { _summary = await DashboardService.GetSummaryAsync() ?? _summary; } catch { }

                Snackbar.Add($"Utstemplet! {result.Hours:0.#} timer registrert.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Kunne ikke stemple ut. Prøv igjen.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Feil ved utstempling.", Severity.Error);
        }
        finally
        {
            _clockActionInProgress = false;
            StateHasChanged();
        }
    }

    private async Task AcknowledgeAnnouncement(Guid id)
    {
        await NotificationService.AcknowledgeAnnouncementAsync(id);
        var ann = _announcements.FirstOrDefault(a => a.Id == id);
        if (ann is not null)
        {
            var index = _announcements.IndexOf(ann);
            _announcements[index] = ann with { HasAcknowledged = true };
        }
        Snackbar.Add("Kunngjøring bekreftet.", Severity.Info);
    }

    private async Task OpenNewAnnouncement()
    {
        _showNewAnnouncement = true;
        _annTarget = "all";
        _annSelectedPersons.Clear();
        if (_annEmployees.Count == 0)
        {
            try { _annEmployees = await EmployeeService.GetEmployeesAsync(); } catch { }
        }
        StateHasChanged();
    }

    private async Task SendAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(_annTitle)) return;
        var targetIds = _annTarget == "select" && _annSelectedPersons.Count > 0
            ? _annSelectedPersons.ToList()
            : null;
        var ok = await NotificationService.CreateAnnouncementAsync(
            new CreateAnnouncementRequest(_annTitle, _annBody, _annUrgency, _annRequireAck, _annPhotoKey, targetIds));
        if (ok)
        {
            _showNewAnnouncement = false;
            _annTitle = "";
            _annBody = "";
            _annUrgency = 1;
            _annRequireAck = false;
            _annPhotoKey = null;
            _announcements = await NotificationService.GetAnnouncementsAsync();
            Snackbar.Add("Kunngjøring sendt!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Kunne ikke sende kunngjøring", Severity.Error);
        }
    }

    private async Task HandleAnnPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            _annPhotoKey = await FileUploadService.UploadPhotoAsync(ms, file.Name, file.ContentType ?? "image/jpeg");
            if (_annPhotoKey is not null) Snackbar.Add("Bilde lagt til", Severity.Info);
            StateHasChanged();
        }
        catch { Snackbar.Add("Kunne ikke laste opp bilde", Severity.Error); }
    }

    private async Task CommentOnAnnouncement(Guid annId)
    {
        var text = GetAnnComment(annId);
        if (string.IsNullOrWhiteSpace(text)) return;
        await NotificationService.CommentOnAnnouncementAsync(annId, text);
        _annComments[annId] = "";
        _announcements = await NotificationService.GetAnnouncementsAsync();
        StateHasChanged();
    }

    private async Task DeleteAnnouncement(Guid annId)
    {
        await NotificationService.DeleteAnnouncementAsync(annId);
        _announcements = await NotificationService.GetAnnouncementsAsync();
        Snackbar.Add("Kunngjøring slettet", Severity.Info);
    }

    private static Color GetProjectStatusColor(string status) => status.ToLowerInvariant() switch
    {
        "aktiv" => Color.Success,
        "planlagt" => Color.Info,
        "ferdig" or "avsluttet" => Color.Default,
        _ => Color.Default
    };

    private async Task OpenCheckInDialog()
    {
        _ciProjectId = null;
        _ciJobId = null;
        _ciLocationId = null;
        _ciAlsoStartClock = false;
        _ciClockStartTime = DateTimeOffset.Now.TimeOfDay;
        _ciClockCategory = "Arbeid";

        // Load projects, jobs, locations in parallel
        var projectsTask = ProjectService.GetActiveProjectsAsync();
        var jobsTask = JobService.GetJobsAsync(1, 50, null, null, false);
        var locationsTask = LocationService.GetLocationsAsync();

        try { await Task.WhenAll(projectsTask, jobsTask, locationsTask); } catch { }

        _checkInProjects = projectsTask.IsCompletedSuccessfully ? projectsTask.Result : [];
        _checkInJobs = jobsTask.IsCompletedSuccessfully ? jobsTask.Result.Items : [];
        _checkInLocations = locationsTask.IsCompletedSuccessfully ? locationsTask.Result : [];

        _checkInDialogOpen = true;
    }

    private void OnCiProjectChanged(Guid? val) { _ciProjectId = val; if (val.HasValue) { _ciJobId = null; _ciLocationId = null; } }
    private void OnCiJobChanged(Guid? val) { _ciJobId = val; if (val.HasValue) { _ciProjectId = null; _ciLocationId = null; } }
    private void OnCiLocationChanged(Guid? val) { _ciLocationId = val; if (val.HasValue) { _ciProjectId = null; _ciJobId = null; } }

    private async Task ExecuteCheckIn()
    {
        if (!_ciProjectId.HasValue && !_ciJobId.HasValue && !_ciLocationId.HasValue) return;

        try
        {
            var request = new CheckInRequest(
                ProjectId: _ciProjectId,
                JobId: _ciJobId,
                LocationId: _ciLocationId,
                Source: "Manual",
                Latitude: null,
                Longitude: null);

            var ok = await CheckInService.CheckInAsync(request);
            _checkInDialogOpen = false;

            if (ok)
            {
                _checkInStatus = await CheckInService.GetMyStatusAsync();
                _siteOverview = await CheckInService.GetAllSitesAsync();

                // Also start clock if toggled
                if (_ciAlsoStartClock && _activeClock is null)
                {
                    // Calculate actual start time from time picker
                    DateTimeOffset? startTime = null;
                    if (_ciClockStartTime.HasValue)
                    {
                        var today = DateTimeOffset.Now.Date;
                        var local = today.Add(_ciClockStartTime.Value);
                        startTime = new DateTimeOffset(local, DateTimeOffset.Now.Offset).ToUniversalTime();
                    }

                    var clockReq = new ClockInRequest(
                        _ciProjectId, _ciJobId,
                        _ciClockCategory, null, null, startTime);
                    var clockId = await HoursService.ClockInAsync(clockReq);
                    if (clockId.HasValue)
                    {
                        _activeClock = await HoursService.GetActiveClockAsync();
                        StartElapsedTimer();
                        Snackbar.Add("Sjekket inn og timer startet!", Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add("Sjekket inn! (Kunne ikke starte timer)", Severity.Warning);
                    }
                }
                else
                {
                    Snackbar.Add("Sjekket inn!", Severity.Success);
                }
            }
            else
            {
                Snackbar.Add("Kunne ikke sjekke inn. Prøv igjen.", Severity.Error);
            }
        }
        catch
        {
            _checkInDialogOpen = false;
            Snackbar.Add("Feil ved innsjekking.", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task HandleCheckOut()
    {
        try
        {
            var ok = await CheckInService.CheckOutAsync(new CheckOutRequest(null, null));
            if (ok)
            {
                _checkInStatus = await CheckInService.GetMyStatusAsync();
                _siteOverview = await CheckInService.GetAllSitesAsync();

                // Also clock out if running
                if (_activeClock is not null)
                {
                    var clockResult = await HoursService.ClockOutAsync(new ClockOutRequest(null, null));
                    if (clockResult is not null)
                    {
                        _activeClock = null;
                        _elapsedTimer?.Dispose();
                        _elapsedTimer = null;
                        try { _summary = await DashboardService.GetSummaryAsync() ?? _summary; } catch { }
                        Snackbar.Add($"Sjekket ut og timer stoppet! {clockResult.Hours:0.#} timer registrert.", Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add("Sjekket ut! (Kunne ikke stoppe timer)", Severity.Warning);
                    }
                }
                else
                {
                    Snackbar.Add("Sjekket ut!", Severity.Success);
                }
            }
            else
            {
                Snackbar.Add("Kunne ikke sjekke ut. Prøv igjen.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Feil ved utsjekking.", Severity.Error);
        }
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var tourDone = await LocalStorage.GetItemAsStringAsync("tourCompleted");
                if (string.IsNullOrWhiteSpace(tourDone) || tourDone.Trim('"') != "true")
                {
                    // Small delay to let page render
                    await Task.Delay(1500);
                    await StartDashboardTour();
                    await LocalStorage.SetItemAsStringAsync("tourCompleted", "true");
                }
            }
            catch { }
        }
    }

    private async Task StartDashboardTour()
    {
        var steps = new[]
        {
            new { id = "welcome", title = "Velkommen til Solodoc!", text = "Dette er dashboardet ditt. Herfra har du oversikt over alt.", element = (string?)null, position = "bottom" },
            new { id = "clock", title = "Stemple inn", text = "Trykk her for å starte arbeidsdagen. Timene registreres automatisk.", element = ".mud-button-filled", position = "bottom" },
            new { id = "sidebar", title = "Navigasjon", text = "Bruk menyen til venstre for å finne prosjekter, avvik, sjekklister og mer.", element = ".sidebar-drawer", position = "right" },
            new { id = "done", title = "Du er klar!", text = "Utforsk pa egenhånd. Trykk på ? i toppmenyen for hjelp.", element = (string?)null, position = "bottom" }
        };

        await JS.InvokeVoidAsync("tourInterop.start", (object)steps);
    }

    public void Dispose()
    {
        _elapsedTimer?.Dispose();
    }
}
