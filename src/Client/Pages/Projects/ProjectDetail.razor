    private static bool IsThisWeek(DateOnly date)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var dayOfWeek = (int)today.DayOfWeek;
        if (dayOfWeek == 0) dayOfWeek = 7;
        var monday = today.AddDays(1 - dayOfWeek);
        var sunday = monday.AddDays(6);
        return date >= monday && date <= sunday;
    }

    // ── Project posts ──

    private Dictionary<Guid, string> _postPhotoUrls = new();

    private async Task LoadPosts()
    {
        try
        {
            var r = await Api.GetAsync($"api/projects/{Id}/posts");
            if (r.IsSuccessStatusCode)
            {
                _posts = await r.Content.ReadFromJsonAsync<List<ProjectPostDto>>() ?? [];
                foreach (var p in _posts)
                    _commentTexts.TryAdd(p.Id, "");

                // Resolve photo URLs through API proxy
                foreach (var p in _posts.Where(p => !string.IsNullOrEmpty(p.PhotoFileKey)))
                {
                    try
                    {
                        var dr = await Api.GetAsync($"api/files/download/{p.PhotoFileKey}");
                        if (dr.IsSuccessStatusCode)
                        {
                            var bytes = await dr.Content.ReadAsByteArrayAsync();
                            var ct2 = dr.Content.Headers.ContentType?.MediaType ?? "image/png";
                            _postPhotoUrls[p.Id] = $"data:{ct2};base64,{Convert.ToBase64String(bytes)}";
                        }
                    }
                    catch { }
                }
            }
        }
        catch { }
    }

    private async Task CreatePost()
    {
        if (string.IsNullOrWhiteSpace(_newPostContent)) return;
        _postingNew = true;
        StateHasChanged();

        var r = await Api.PostAsJsonAsync($"api/projects/{Id}/posts",
            new CreateProjectPostRequest(_newPostContent, _newPostPhotoKey));
        if (r.IsSuccessStatusCode)
        {
            _newPostContent = "";
            _newPostPhotoKey = null;
            await LoadPosts();
            Snackbar.Add("Innlegg publisert", Severity.Success);
        }
        _postingNew = false;
        StateHasChanged();
    }

    private async Task AddComment(Guid postId)
    {
        if (!_commentTexts.TryGetValue(postId, out var text) || string.IsNullOrWhiteSpace(text)) return;

        await Api.PostAsJsonAsync($"api/projects/{Id}/posts/{postId}/comments",
            new CreateProjectPostCommentRequest(text));
        _commentTexts[postId] = "";
        await LoadPosts();
        StateHasChanged();
    }

    private async Task HandlePostPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            _newPostPhotoKey = await FileUploadService.UploadPhotoAsync(ms, file.Name, file.ContentType ?? "image/jpeg");
            if (_newPostPhotoKey is not null)
                Snackbar.Add("Bilde lagt til", Severity.Info);
            StateHasChanged();
        }
        catch { Snackbar.Add("Kunne ikke laste opp bilde", Severity.Error); }
    }

    // ── Objects ──

    private async Task LoadObjectsAsync()
    {
        _objects = await ChecklistService.GetObjectsAsync(Id);
        if (_availableTemplates.Count == 0)
            _availableTemplates = await ChecklistService.GetTemplatesAsync();
        StateHasChanged();
    }

    private async Task OpenCreateObjectDialog()
    {
        if (_availableTemplates.Count == 0)
            _availableTemplates = await ChecklistService.GetTemplatesAsync();

        _objName = "";
        _objCount = 1;
        _selectedTemplateIds.Clear();

        // Auto-suggest next number
        var maxNum = _objects.Count > 0 ? _objects.Max(o => o.Number) : 0;
        _objStartNumber = maxNum + 1;

        _showCreateObject = true;
    }

    private async Task CreateObjectSubmit()
    {
        if (string.IsNullOrWhiteSpace(_objName) || _selectedTemplateIds.Count == 0) return;
        _creatingObject = true;
        StateHasChanged();

        var templateIds = _selectedTemplateIds.ToList();
        var created = 0;

        for (var i = 0; i < _objCount; i++)
        {
            var number = _objStartNumber + i;
            var id = await ChecklistService.CreateObjectAsync(
                new Solodoc.Shared.Checklists.CreateChecklistObjectRequest(
                    Id, _objName, number, templateIds));
            if (id.HasValue) created++;
        }

        if (created > 0)
        {
            _showCreateObject = false;
            await LoadObjectsAsync();
            Snackbar.Add($"{created} objekter opprettet ({_objName} {_objStartNumber}–{_objStartNumber + created - 1})", Severity.Success);
        }
        else
        {
            Snackbar.Add("Kunne ikke opprette objekter", Severity.Error);
        }
        _creatingObject = false;
    }

    private async Task CopyObject(Guid sourceId)
    {
        var id = await ChecklistService.CopyObjectAsync(sourceId);
        if (id.HasValue)
        {
            await LoadObjectsAsync();
            Snackbar.Add("Objekt kopiert", Severity.Success);
        }
        else
        {
            Snackbar.Add("Kunne ikke kopiere objekt", Severity.Error);
        }
    }

