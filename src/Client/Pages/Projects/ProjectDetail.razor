@page "/projects/{Id:guid}"
@attribute [Authorize]
@inject ProjectService ProjectService
@inject DeviationService DeviationService
@inject ChecklistService ChecklistService
@inject HoursService HoursService
@inject EmployeeService EmployeeService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject CheckInService CheckInService
@inject ApiHttpClient Api
@inject FileUploadService FileUploadService
@inject ExpenseService ExpenseService
@inject EquipmentService EquipmentService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@using Solodoc.Shared.Notifications
@using Solodoc.Shared.Expenses
@using System.Security.Claims

<PageTitle>Solodoc - @(_project?.Name ?? "Prosjekt")</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4"
          Style="flex-wrap:wrap;gap:8px;">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack" />
        <div>
            @if (_project?.ParentProjectId.HasValue == true)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="margin-bottom:2px;">
                    <MudLink Href="/projects" Typo="Typo.caption" Color="Color.Secondary" Style="text-decoration:none;">Prosjekter</MudLink>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color:#9CA3AF;font-size:0.8rem;" />
                    <MudLink Href="@($"/projects/{_project.ParentProjectId}")" Typo="Typo.caption" Color="Color.Primary" Style="text-decoration:none;">@(_project.ParentProjectName ?? "Hovedprosjekt")</MudLink>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color:#9CA3AF;font-size:0.8rem;" />
                </MudStack>
            }
            <MudText Typo="Typo.h5">@(_project?.Name ?? "Laster...")</MudText>
        </div>
        @if (_project is not null)
        {
            var color = _project.Status switch
            {
                "Aktiv" => Color.Success,
                "Fullført" or "Fullført" => Color.Info,
                "Planlagt" => Color.Primary,
                "Kansellert" => Color.Error,
                _ => Color.Default
            };
            <MudChip T="string" Size="Size.Small" Color="@color">@_project.Status</MudChip>
        }
    </MudStack>
    @if (_project is not null && _canManageProject)
    {
        <MudStack Row="true" Spacing="1">
            @if (_project.Status is "Planlagt")
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                           OnClick="ActivateProject"
                           Style="text-transform:none;border-radius:8px;">
                    Aktiver
                </MudButton>
            }
            @if (_project.Status is "Aktiv")
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                           OnClick="@(() => { _confirmAction = "complete"; _showConfirm = true; })"
                           Style="text-transform:none;border-radius:8px;">
                    Fullfør
                </MudButton>
            }
            @if (_project.Status is "Aktiv" or "Planlagt")
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => { _confirmAction = "cancel"; _showConfirm = true; })"
                           Style="text-transform:none;border-radius:8px;">
                    Kanseller
                </MudButton>
            }
            @if (_project.Status is "Fullfort" or "Fullført" or "Kansellert")
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                           OnClick="ReopenProject"
                           Style="text-transform:none;border-radius:8px;">
                    Gjenåpne
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.QrCode2"
                       Href="@($"/admin/qr-card/project/{Id}")"
                       Style="text-transform:none;border-radius:8px;">
                QR-kode
            </MudButton>
        </MudStack>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_project is null)
{
    <MudAlert Severity="Severity.Warning">Prosjektet ble ikke funnet.</MudAlert>
}
else
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
             ActivePanelIndexChanged="OnTabChanged"
             Style="border:1px solid #e9ecef;border-radius:12px;">
        @* Tab 0: Oversikt *@
        <MudTabPanel Text="Oversikt" Icon="@Icons.Material.Filled.Dashboard">
            <div class="pa-4">
                @* Who's on site *@
                @if (_onSitePersons.Count > 0)
                {
                    <MudPaper Class="pa-3 mb-4" Elevation="0" Style="border:1px solid #059669;border-radius:12px;background:#F0FDF4;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Small" Color="Color.Success" />
                            <MudText Typo="Typo.body2" Style="font-weight:600;color:#059669;">
                                På byggeplass nå (@_onSitePersons.Count)
                            </MudText>
                            @foreach (var p in _onSitePersons)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Style="height:22px;font-size:0.75rem;">
                                    @p.FullName
                                </MudChip>
                            }
                        </MudStack>
                    </MudPaper>
                }

                @* ── KPI cards: Totalt (default view) ── *@
                @{
                    var hasSubs = _project.SubProjects is { Count: > 0 };
                    var tHours = _dashHoursParent + (_project.SubProjects?.Sum(s => s.TotalHours) ?? 0);
                    var tDevs = _dashDeviationsParent + (_project.SubProjects?.Sum(s => s.OpenDeviations) ?? 0);
                    var tClDone = _dashChecklistsDoneParent + (_project.SubProjects?.Sum(s => s.ChecklistsCompleted) ?? 0);
                    var tClAll = _dashChecklistsTotalParent + (_project.SubProjects?.Sum(s => s.ChecklistsTotal) ?? 0);
                }
                @if (hasSubs)
                {
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;color:#00B5A6;" Class="mb-2">Totalt</MudText>
                }
                <MudGrid Spacing="2" Class="mb-3">
                    <MudItem xs="6" sm="3">
                        <div style="background:#E6FAF8;border-radius:10px;padding:14px;text-align:center;">
                            <div style="font-size:1.5rem;font-weight:700;color:#00B5A6;">@((hasSubs ? tHours : _dashHoursParent).ToString("N1"))</div>
                            <div style="font-size:0.7rem;color:#6B7280;">Timer</div>
                        </div>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <div style="background:#FEE2E2;border-radius:10px;padding:14px;text-align:center;">
                            <div style="font-size:1.5rem;font-weight:700;color:#DC2626;">@(hasSubs ? tDevs : _dashDeviationsParent)</div>
                            <div style="font-size:0.7rem;color:#6B7280;">Åpne avvik</div>
                        </div>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <div style="background:#D1FAE5;border-radius:10px;padding:14px;text-align:center;">
                            <div style="font-size:1.5rem;font-weight:700;color:#059669;">@(hasSubs ? tClDone : _dashChecklistsDoneParent) / @(hasSubs ? tClAll : _dashChecklistsTotalParent)</div>
                            <div style="font-size:0.7rem;color:#6B7280;">Sjekklister</div>
                        </div>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <div style="background:#EDE9FE;border-radius:10px;padding:14px;text-align:center;">
                            <div style="font-size:1.5rem;font-weight:700;color:#7C3AED;">@_onSitePersons.Count</div>
                            <div style="font-size:0.7rem;color:#6B7280;">På byggeplass</div>
                        </div>
                    </MudItem>
                </MudGrid>

                @* ── Per-project breakdown (expandable) ── *@
                @if (hasSubs)
                {
                    <MudExpansionPanels Elevation="0" Class="mb-4">
                        <MudExpansionPanel Style="border:1px solid #e9ecef;border-radius:10px;">
                            <TitleContent>
                                <MudText Typo="Typo.body2" Style="font-weight:600;">Vis per prosjekt</MudText>
                            </TitleContent>
                            <ChildContent>
                                @* Main project *@
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;" Class="mb-2">@_project.Name (hoved)</MudText>
                                <MudGrid Spacing="2" Class="mb-4">
                                    <MudItem xs="6" sm="3">
                                        <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                            <div style="font-size:1.2rem;font-weight:700;color:#00B5A6;">@_dashHoursParent.ToString("N1")</div>
                                            <div style="font-size:0.65rem;color:#6B7280;">Timer</div>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                            <div style="font-size:1.2rem;font-weight:700;color:#DC2626;">@_dashDeviationsParent</div>
                                            <div style="font-size:0.65rem;color:#6B7280;">Åpne avvik</div>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                            <div style="font-size:1.2rem;font-weight:700;color:#059669;">@_dashChecklistsDoneParent / @_dashChecklistsTotalParent</div>
                                            <div style="font-size:0.65rem;color:#6B7280;">Sjekklister</div>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                            <div style="font-size:1.2rem;font-weight:700;color:#7C3AED;">@_onSitePersons.Count</div>
                                            <div style="font-size:0.65rem;color:#6B7280;">På byggeplass</div>
                                        </div>
                                    </MudItem>
                                </MudGrid>

                                @* Each sub-project *@
                                @foreach (var sub in _project.SubProjects!)
                                {
                                    var capturedSub = sub;
                                    var sc = sub.Status switch { "Aktiv" => "#059669", "Fullført" or "Fullfort" => "#00B5A6", _ => "#9CA3AF" };
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;">↳ @sub.Name</MudText>
                                        <span style="@($"color:{sc};font-size:0.7rem;font-weight:600;")">@sub.Status</span>
                                        <MudSpacer />
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                   Href="@($"/projects/{capturedSub.Id}")"
                                                   Style="text-transform:none;font-size:0.7rem;border-radius:6px;">Åpne</MudButton>
                                    </MudStack>
                                    <MudGrid Spacing="2" Class="mb-4">
                                        <MudItem xs="6" sm="3">
                                            <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                                <div style="font-size:1.2rem;font-weight:700;color:#00B5A6;">@sub.TotalHours.ToString("N1")</div>
                                                <div style="font-size:0.65rem;color:#6B7280;">Timer</div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                                <div style="font-size:1.2rem;font-weight:700;color:#DC2626;">@sub.OpenDeviations</div>
                                                <div style="font-size:0.65rem;color:#6B7280;">Åpne avvik</div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                                <div style="font-size:1.2rem;font-weight:700;color:#059669;">@sub.ChecklistsCompleted / @sub.ChecklistsTotal</div>
                                                <div style="font-size:0.65rem;color:#6B7280;">Sjekklister</div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <div style="background:#F8F9FA;border:1px solid #e9ecef;border-radius:10px;padding:12px;text-align:center;">
                                                <div style="font-size:1.2rem;font-weight:700;color:#7C3AED;">—</div>
                                                <div style="font-size:0.65rem;color:#6B7280;">På byggeplass</div>
                                            </div>
                                        </MudItem>
                                    </MudGrid>
                                }
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }

                @* ── Project info ── *@
                <MudPaper Class="pa-4 mb-4" Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;">
                    @if (!string.IsNullOrEmpty(_project.Description))
                    {
                        <MudText Typo="Typo.body2" Class="mb-3">@_project.Description</MudText>
                    }
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Kunde</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@(_project.ClientName ?? "---")</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Startdato</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@(_project.StartDate?.ToString("dd.MM.yyyy") ?? "---")</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Adresse</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@(_project.Address ?? "---")</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@_project.Status</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                @* ── Open deviations ── *@
                @if (_project.OpenDeviations.Count > 0)
                {
                    <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid #FECACA;border-radius:12px;">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;color:#DC2626;" Class="mb-2">Åpne avvik (@_project.OpenDeviations.Count)</MudText>
                        <MudStack Spacing="1">
                            @foreach (var d in _project.OpenDeviations.Take(5))
                            {
                                var devId = d.Id;
                                var sevColor = d.Severity switch { "Høy" or "Hoy" => Color.Error, "Middels" => Color.Warning, _ => Color.Success };
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                                          Style="cursor:pointer;padding:4px 0;" @onclick="() => GoToDeviation(devId)">
                                    <MudText Typo="Typo.body2">@d.Title</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@sevColor" Style="height:22px;">@d.Severity</MudChip>
                                </MudStack>
                            }
                        </MudStack>
                    </MudPaper>
                }
                @* ── Project wall (Innlegg) ── *@
                <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-4 mt-4">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;" Class="mb-3">Innlegg</MudText>

                    @* New post form *@
                    <MudPaper Elevation="0" Style="border:1px solid #E9ECEF;border-radius:10px;background:#F9FAFB;" Class="pa-3 mb-3">
                        <MudTextField T="string" @bind-Value="_newPostContent" Placeholder="Skriv et innlegg..." Variant="Variant.Text"
                                      Lines="2" Immediate="true" Style="font-size:0.9rem;" />
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-2">
                            <div style="position:relative;">
                                <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.CameraAlt"
                                           Style="text-transform:none;color:#6B7280;">
                                    @(_newPostPhotoKey is not null ? "Bilde lagt til" : "Legg til bilde")
                                </MudButton>
                                <InputFile OnChange="HandlePostPhoto" accept="image/*"
                                           style="position:absolute;inset:0;opacity:0;cursor:pointer;font-size:0;" />
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="CreatePost"
                                       Disabled="@(string.IsNullOrWhiteSpace(_newPostContent) || _postingNew)"
                                       Style="text-transform:none;border-radius:8px;">
                                @if (_postingNew) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                                Publiser
                            </MudButton>
                        </MudStack>
                    </MudPaper>

                    @* Feed *@
                    @if (_posts.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align:center;padding:16px;">
                            Ingen innlegg ennå. Vær den første!
                        </MudText>
                    }
                    @foreach (var post in _posts)
                    {
                        var capturedPost = post;
                        <MudPaper Elevation="0" Style="@($"border:1px solid {(post.IsPinned ? "#00B5A6" : "#E9ECEF")};border-radius:10px;{(post.IsPinned ? "background:#F8FAFF;" : "")}")" Class="pa-3 mb-2">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-size:0.7rem;">@post.AuthorInitials</MudAvatar>
                                <div style="flex:1;min-width:0;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">@post.AuthorName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@post.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</MudText>
                                        @if (post.IsPinned)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.PushPin" Size="Size.Small" Style="color:#00B5A6;font-size:0.8rem;" />
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.body2" Style="white-space:pre-wrap;margin-top:4px;">@post.Content</MudText>
                                    @if (!string.IsNullOrEmpty(post.PhotoFileKey) && _postPhotoUrls.TryGetValue(post.Id, out var postPhotoUrl))
                                    {
                                        <img src="@postPhotoUrl" alt="Bilde" @onclick="() => _lightboxUrl = postPhotoUrl"
                                             style="max-width:100%;max-height:300px;border-radius:8px;margin-top:8px;object-fit:cover;cursor:pointer;" />
                                    }

                                    @* Comments *@
                                    @if (post.Comments.Count > 0)
                                    {
                                        <div style="margin-top:8px;padding-top:8px;border-top:1px solid #E9ECEF;">
                                            @foreach (var c in post.Comments)
                                            {
                                                <MudStack Row="true" Spacing="1" Style="margin-bottom:4px;">
                                                    <MudText Typo="Typo.caption" Style="font-weight:600;">@c.AuthorName</MudText>
                                                    <MudText Typo="Typo.caption">@c.Content</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@c.CreatedAt.ToLocalTime().ToString("HH:mm")</MudText>
                                                </MudStack>
                                            }
                                        </div>
                                    }

                                    @* Comment input *@
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Style="margin-top:4px;">
                                        <MudTextField T="string" @bind-Value="_commentTexts[post.Id]" Placeholder="Kommenter..."
                                                      Variant="Variant.Text" Margin="Margin.Dense" Style="font-size:0.8rem;flex:1;" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Send" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(async () => await AddComment(capturedPost.Id))" />
                                    </MudStack>
                                </div>
                            </MudStack>
                        </MudPaper>
                    }
                </MudPaper>
            </div>
        </MudTabPanel>

        @* Tab: Sub-prosjekter *@
        <MudTabPanel Text="Underprosjekter" Icon="@Icons.Material.Filled.AccountTree">
                <div class="pa-4">
                    @if (_project!.SubProjects is { Count: > 0 })
                    {
                        var completedCount = _project.SubProjects.Count(s => s.Status == "Fullfort");
                        var totalCount = _project.SubProjects.Count;
                        var progressPct = totalCount > 0 ? (double)completedCount / totalCount * 100 : 0;
                        <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-4 mb-4">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                                    @completedCount av @totalCount underprosjekter fullfort
                                </MudText>
                                <MudText Typo="Typo.body2" Style="font-weight:600;color:#00B5A6;">@((int)progressPct)%</MudText>
                            </MudStack>
                            <MudProgressLinear Value="progressPct" Color="Color.Success" Rounded="true" Style="height:8px;" Class="mt-2" />
                        </MudPaper>

                        <MudGrid Spacing="3">
                            @foreach (var sub in _project.SubProjects)
                            {
                                var capturedSub = sub;
                                var subStatusColor = sub.Status switch { "Aktiv" => "#059669", "Fullfort" => "#00B5A6", "Planlagt" => "#6B7280", _ => "#DC2626" };
                                var subCheckPct = sub.ChecklistsTotal > 0 ? (double)sub.ChecklistsCompleted / sub.ChecklistsTotal * 100 : 0;
                                <MudItem xs="12" sm="6" md="4">
                                    <MudPaper Elevation="0" Class="pa-4"
                                              Style="border:1px solid #e9ecef;border-radius:12px;cursor:pointer;height:100%;"
                                              @onclick="@(() => Navigation.NavigateTo($"/projects/{capturedSub.Id}"))">
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@sub.Name</MudText>
                                                <span style="@($"background:{subStatusColor}20;color:{subStatusColor};padding:2px 8px;border-radius:4px;font-size:0.7rem;font-weight:600;")">@sub.Status</span>
                                            </MudStack>
                                            <MudGrid Spacing="2">
                                                <MudItem xs="4">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Timer</MudText>
                                                    <MudText Style="font-weight:600;">@sub.TotalHours.ToString("N1")</MudText>
                                                </MudItem>
                                                <MudItem xs="4">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Avvik</MudText>
                                                    <MudText Style="@($"font-weight:600;{(sub.OpenDeviations > 0 ? "color:#DC2626;" : "")}")">@sub.OpenDeviations</MudText>
                                                </MudItem>
                                                <MudItem xs="4">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Sjekklister</MudText>
                                                    <MudText Style="font-weight:600;">@sub.ChecklistsCompleted/@sub.ChecklistsTotal</MudText>
                                                </MudItem>
                                            </MudGrid>
                                            <MudProgressLinear Value="subCheckPct" Color="Color.Primary" Rounded="true" Style="height:4px;" />
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Color="Color.Secondary">Ingen underprosjekter ennå</MudText>
                        </MudStack>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                               Href="@($"/projects/new?parentId={Id}")"
                               StartIcon="@Icons.Material.Filled.Add"
                               Style="text-transform:none;border-radius:8px;">
                        Nytt underprosjekt
                    </MudButton>
                </div>
        </MudTabPanel>

        @* Tab: Sjekklister *@
        <MudTabPanel Text="Sjekklister" Icon="@Icons.Material.Filled.Checklist">
            <div class="pa-4">
                @* Object summary banner *@
                @if (_objects.Count > 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <span>
                                @_objects.Count objekter ·
                                @_objects.Sum(o => o.CompletedChecklists) / @_objects.Sum(o => o.TotalChecklists) sjekklister fullført
                            </span>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                       Style="text-transform:none;"
                                       OnClick="@(() => { })">
                                Se Objekter-fanen
                            </MudButton>
                        </MudStack>
                    </MudAlert>
                }

                @* Inline template picker for creating checklist *@
                @if (!_showChecklistPicker)
                {
                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="() => OpenChecklistPicker()"
                                   Style="text-transform:none;border-radius:8px;">
                            Opprett sjekkliste
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudPaper Elevation="0" Style="border:1px solid #E9ECEF;border-radius:12px;" Class="pa-4 mb-4">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-3">Velg mal</MudText>
                        <MudStack Spacing="2">
                            <MudSelect T="Guid?" @bind-Value="_selectedTemplateId" Label="Mal"
                                       Variant="Variant.Outlined" Required="true"
                                       RequiredError="Velg en mal">
                                @foreach (var t in _publishedTemplates)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)t.Id)">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <span>@t.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(t.DocumentNumber))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@t.DocumentNumber</MudText>
                                            }
                                        </MudStack>
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField T="string" @bind-Value="_checklistLocation" Label="Lokasjon (valgfritt)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          HelperText="F.eks. Etasje 3, Seksjon B" />

                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                                <MudButton Variant="Variant.Text" Color="Color.Default"
                                           OnClick="() => _showChecklistPicker = false"
                                           Style="text-transform:none;">
                                    Avbryt
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           OnClick="CreateChecklistFromProject"
                                           Disabled="_creatingChecklist"
                                           Style="text-transform:none;border-radius:8px;min-height:48px;">
                                    @if (_creatingChecklist)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    }
                                    Start sjekkliste
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }

                @if (_loadingChecklists)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_checklists.Count == 0 && !_showChecklistPicker)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.PlaylistAddCheck" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen sjekklister for dette prosjektet</MudText>
                    </MudStack>
                }
                else
                {
                    var drafts = _checklists.Where(c => c.Status is "Utkast" or "Gjenåpnet" or "Gjenapnet").ToList();
                    var completedList = _checklists.Where(c => c.Status is "Innsendt" or "Godkjent").ToList();

                    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0 pt-3" MinimumTabWidth="100px">
                        <MudTabPanel Text="@($"Aktive ({drafts.Count})")" Icon="@Icons.Material.Filled.Edit">
                            @if (drafts.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4" Style="text-align:center;">Ingen aktive sjekklister</MudText>
                            }
                            else
                            {
                                @RenderChecklistGroup(drafts)
                            }
                        </MudTabPanel>
                        <MudTabPanel Text="@($"Fullførte ({completedList.Count})")" Icon="@Icons.Material.Filled.CheckCircle">
                            @if (completedList.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4" Style="text-align:center;">Ingen fullførte sjekklister</MudText>
                            }
                            else
                            {
                                @RenderChecklistGroup(completedList)
                            }
                        </MudTabPanel>
                    </MudTabs>
                }
            </div>
        </MudTabPanel>

        @* Tab: Objekter *@
        <MudTabPanel Text="Objekter" Icon="@Icons.Material.Filled.ViewModule">
            <div class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Objekter</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateObjectDialog"
                               Style="text-transform:none;border-radius:8px;">
                        Opprett objekt
                    </MudButton>
                </MudStack>

                @if (_objects.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                        <MudIcon Icon="@Icons.Material.Filled.ViewModule" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Ingen objekter opprettet. Objekter lar deg gruppere sjekklister
                            for gjentakende elementer (f.eks. Fundament 1, 2, 3).
                        </MudText>
                    </MudStack>
                }
                else
                {
                    var objectGroups = _objects.GroupBy(o => o.Name).OrderBy(g => g.Key).ToList();

                    <MudExpansionPanels MultiExpansion="true">
                        @foreach (var group in objectGroups)
                        {
                            var grp = group;
                            var grpTotal = grp.Sum(o => o.TotalChecklists);
                            var grpDone = grp.Sum(o => o.CompletedChecklists);
                            var grpProgress = grpTotal > 0 ? (double)grpDone / grpTotal * 100 : 0;
                            var grpAllDone = grpDone == grpTotal && grpTotal > 0;

                            <MudExpansionPanel Style="@($"border:1px solid {(grpAllDone ? "#2B8A3E" : "#e9ecef")};border-radius:10px;margin-bottom:8px;{(grpAllDone ? "background:#F0FFF4;" : "")}")">
                                <TitleContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width:100%;">
                                        @if (grpAllDone)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                        }
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@grp.Key</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="height:20px;">
                                            @grp.Count() stk
                                        </MudChip>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @grpDone / @grpTotal sjekklister
                                        </MudText>
                                        <div style="flex:1;max-width:200px;">
                                            <MudProgressLinear Value="@grpProgress" Color="@(grpAllDone ? Color.Success : Color.Primary)"
                                                               Rounded="true" Size="Size.Small" Style="height:5px;" />
                                        </div>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    @foreach (var obj in grp.OrderBy(o => o.Number))
                                    {
                                        var o = obj;
                                        var oProgress = o.TotalChecklists > 0 ? (double)o.CompletedChecklists / o.TotalChecklists * 100 : 0;
                                        var oDone = o.CompletedChecklists == o.TotalChecklists && o.TotalChecklists > 0;

                                        <MudPaper Elevation="0" Class="pa-2 mb-2"
                                                  Style="@($"border:1px solid {(oDone ? "#2B8A3E30" : "#f0f0f0")};border-radius:8px;{(oDone ? "background:#F0FFF4;" : "")}")">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                                                @if (oDone)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                }
                                                <MudText Typo="Typo.body2" Style="font-weight:600;">@o.DisplayName</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@o.CompletedChecklists/@o.TotalChecklists</MudText>
                                                <div style="flex:1;max-width:120px;">
                                                    <MudProgressLinear Value="@oProgress" Color="@(oDone ? Color.Success : Color.Primary)"
                                                                       Rounded="true" Size="Size.Small" Style="height:4px;" />
                                                </div>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap;">
                                                @foreach (var cl in o.Checklists)
                                                {
                                                    var clColor = cl.Status switch
                                                    {
                                                        "Godkjent" => Color.Success,
                                                        "Fullført" => Color.Info,
                                                        _ => Color.Default
                                                    };
                                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="@clColor"
                                                               Href="@($"/checklists/{cl.InstanceId}/fill")"
                                                               Style="text-transform:none;border-radius:6px;height:26px;font-size:0.75rem;">
                                                        @cl.TemplateName
                                                    </MudButton>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    }
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(async () => await CopyObject(grp.Last().Id))"
                                               StartIcon="@Icons.Material.Filled.ContentCopy"
                                               Style="text-transform:none;border-radius:8px;margin-top:4px;">
                                        Kopier @grp.Key @(grp.Max(o => o.Number) + 1)
                                    </MudButton>
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
            </div>
        </MudTabPanel>

        @* Tab: Timer *@
        <MudTabPanel Text="Timer" Icon="@Icons.Material.Filled.AccessTime">
            <div class="pa-4">
                @if (_loadingHours)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_timeEntries.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.TimerOff" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen timer registrert på dette prosjektet</MudText>
                    </MudStack>
                }
                else
                {
                    @* Summary cards *@
                    <MudGrid Spacing="3" Class="mb-4">
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Totalt</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight:600;color:#00B5A6;">
                                    @_timeEntries.Sum(t => t.Hours).ToString("N1") t
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Overtid</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight:600;">
                                    @_timeEntries.Sum(t => t.OvertimeHours).ToString("N1") t
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Registreringer</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight:600;">@_timeEntries.Count</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Denne uken</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight:600;">
                                    @_timeEntries.Where(t => IsThisWeek(t.Date)).Sum(t => t.Hours).ToString("N1") t
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @* Time entries table *@
                    <MudSimpleTable Dense="true" Hover="true" Style="border:1px solid #e9ecef;border-radius:8px;">
                        <thead>
                            <tr>
                                <th>Dato</th>
                                <th>Timer</th>
                                <th>Overtid</th>
                                <th>Kategori</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in _timeEntries.OrderByDescending(t => t.Date).Take(20))
                            {
                                var statusColor = entry.Status switch
                                {
                                    "Godkjent" or "Approved" => Color.Success,
                                    "Innsendt" or "Submitted" => Color.Warning,
                                    _ => Color.Default
                                };
                                <tr>
                                    <td>@entry.Date.ToString("dd.MM.yyyy")</td>
                                    <td>@entry.Hours.ToString("N1")</td>
                                    <td>@entry.OvertimeHours.ToString("N1")</td>
                                    <td>@entry.Category</td>
                                    <td><MudChip T="string" Size="Size.Small" Color="@statusColor" Style="height:22px;">@entry.Status</MudChip></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </div>
        </MudTabPanel>

        @* Tab 3: Avvik *@
        <MudTabPanel Text="Avvik" Icon="@Icons.Material.Filled.Warning">
            <div class="pa-4">
                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               Href="@($"/deviations/new?projectId={Id}")"
                               Style="text-transform:none;border-radius:8px;">
                        Registrer avvik
                    </MudButton>
                </MudStack>

                @if (_loadingDeviations)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_deviations.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen avvik registrert på dette prosjektet</MudText>
                    </MudStack>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var dev in _deviations)
                        {
                            var devId = dev.Id;
                            var statusColor = dev.Status switch
                            {
                                "Åpen" or "Åpen" => Color.Error,
                                "Under behandling" => Color.Warning,
                                "Lukket" => Color.Success,
                                _ => Color.Default
                            };
                            var sevColor = dev.Severity switch
                            {
                                "Høy" => Color.Error,
                                "Middels" => Color.Warning,
                                _ => Color.Success
                            };
                            <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;cursor:pointer;"
                                      Class="pa-3" @onclick="() => GoToDeviation(devId)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body1" Style="font-weight:500;">@dev.Title</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Rapportert av @dev.ReportedBy, @dev.CreatedAt.ToString("dd.MM.yyyy")
                                        </MudText>
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudChip T="string" Size="Size.Small" Color="@sevColor" Style="height:22px;">@dev.Severity</MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="@statusColor" Style="height:22px;">@dev.Status</MudChip>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }
            </div>
        </MudTabPanel>

        @* Tab 4: Personell *@
        <MudTabPanel Text="Personell" Icon="@Icons.Material.Filled.Group">
            <div class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mb-2">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="ExportCheckInLog"
                               Style="text-transform:none;border-radius:8px;">Eksporter innsjekking (CSV)</MudButton>
                </MudStack>
                @if (_loadingCrew)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_crewMembers.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.GroupOff" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen personell registrert på dette prosjektet</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Personell bygges automatisk fra timer og innsjekking
                        </MudText>
                    </MudStack>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Style="border:1px solid #e9ecef;border-radius:8px;">
                        <thead>
                            <tr>
                                <th>Navn</th>
                                <th>E-post</th>
                                <th>Rolle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in _crewMembers)
                            {
                                <tr>
                                    <td>@member.FullName</td>
                                    <td>@member.Email</td>
                                    <td>
                                        @{
                                            var roleColor = member.Role switch
                                            {
                                                "Admin" => Color.Primary,
                                                "Prosjektleder" => Color.Info,
                                                _ => Color.Default
                                            };
                                        }
                                        <MudChip T="string" Size="Size.Small" Color="@roleColor" Style="height:22px;">@member.Role</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </div>
        </MudTabPanel>

        @* Tab: Utlegg *@
        <MudTabPanel Text="Utlegg" Icon="@Icons.Material.Filled.Receipt">
            <div class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3" Style="flex-wrap:wrap;gap:8px;">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">Kvitteringer</MudText>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/utlegg/ny"
                               StartIcon="@Icons.Material.Filled.Add"
                               Style="text-transform:none;border-radius:8px;">Ny kvittering</MudButton>
                </MudStack>

                @if (_loadingExpenses)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_projectExpenses.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Color="Color.Secondary">Ingen kvitteringer registrert på dette prosjektet</MudText>
                    </MudStack>
                }
                else
                {
                    <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:10px;overflow:hidden;">
                        <div style="overflow-x:auto;">
                            <MudSimpleTable Dense="true" Hover="true" Style="font-size:0.85rem;min-width:600px;">
                                <thead>
                                    <tr style="background:#F8F9FA;">
                                        <th>Ansatt</th>
                                        <th style="text-align:right;">Beløp</th>
                                        <th>Dato</th>
                                        <th>Beskrivelse</th>
                                        <th>Status</th>
                                        <th style="text-align:center;">Godkjent</th>
                                        <th style="text-align:center;">Betalt</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exp in _projectExpenses)
                                    {
                                        var captured = exp;
                                        var statusColor = exp.Status switch { "Approved" or "Paid" => "#059669", "Submitted" => "#00B5A6", "Rejected" => "#DC2626", _ => "#6B7280" };
                                        var statusLabel = exp.Status switch { "Draft" => "Utkast", "Submitted" => "Innsendt", "Approved" => "Godkjent", "Rejected" => "Avvist", "Paid" => "Betalt", _ => exp.Status };
                                        <tr style="cursor:pointer;" @onclick="@(() => Navigation.NavigateTo($"/utlegg/{captured.Id}"))">
                                            <td style="font-weight:500;">@exp.EmployeeName</td>
                                            <td style="text-align:right;font-weight:600;">kr @exp.Amount.ToString("N0")</td>
                                            <td>@exp.Date.ToString("dd.MM.yy")</td>
                                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(exp.Description ?? "-")</td>
                                            <td><span style="@($"color:{statusColor};font-weight:600;font-size:0.75rem;")">@statusLabel</span></td>
                                            <td style="text-align:center;">
                                                @if (exp.IsApproved)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                                }
                                                else if (_isExpenseAdmin && exp.Status == "Submitted")
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(async () => { await ExpenseService.ApproveExpenseAsync(captured.Id); await LoadExpensesAsync(); })"
                                                                   OnClick:stopPropagation="true" />
                                                }
                                            </td>
                                            <td style="text-align:center;">
                                                @if (exp.IsPaid)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Paid" Size="Size.Small" Color="Color.Success" />
                                                }
                                                else if (_isExpenseAccountant && exp.Status == "Approved")
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Paid" Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(async () => { await ExpenseService.MarkExpensePaidAsync(captured.Id); await LoadExpensesAsync(); })"
                                                                   OnClick:stopPropagation="true" />
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </div>
                    </MudPaper>

                    <MudStack Row="true" Spacing="4" Style="padding:12px;background:#F8F9FA;border-radius:8px;margin-top:12px;flex-wrap:wrap;">
                        <div><span style="font-size:0.75rem;color:#6B7280;">Totalt:</span> <b>kr @_projectExpenses.Sum(e => e.Amount).ToString("N0")</b></div>
                        <div><span style="font-size:0.75rem;color:#6B7280;">Godkjent:</span> <b style="color:#059669;">kr @_projectExpenses.Where(e => e.IsApproved).Sum(e => e.Amount).ToString("N0")</b></div>
                        <div><span style="font-size:0.75rem;color:#6B7280;">Betalt:</span> <b style="color:#00B5A6;">kr @_projectExpenses.Where(e => e.IsPaid).Sum(e => e.Amount).ToString("N0")</b></div>
                    </MudStack>
                }
            </div>
        </MudTabPanel>

        @* Tab: Dokumenter *@
        @* Tab: Utstyr *@
        <MudTabPanel Text="Utstyr" Icon="@Icons.Material.Filled.Construction">
            <div class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Utstyr på prosjektet</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAssignEquipmentDialog"
                               Style="text-transform:none;border-radius:8px;">
                        Legg til utstyr
                    </MudButton>
                </MudStack>

                @if (_projectEquipment.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                        <MudIcon Icon="@Icons.Material.Filled.Construction" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Ingen utstyr tilknyttet dette prosjektet</MudText>
                    </MudStack>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr>
                                <th>Navn</th>
                                <th>Type</th>
                                <th>Reg.nr</th>
                                <th>Merke / Modell</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var eq in _projectEquipment)
                            {
                                <tr style="cursor:pointer;" @onclick="@(() => Navigation.NavigateTo($"/machines/{eq.Id}"))">
                                    <td><strong>@eq.Name</strong></td>
                                    <td>@(eq.Type ?? "—")</td>
                                    <td>@(eq.RegistrationNumber ?? "—")</td>
                                    <td>@($"{eq.Make} {eq.Model}".Trim())</td>
                                    <td style="text-align:right;">
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                                       Href="@($"/machines/{eq.Id}")" Color="Color.Primary" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Dokumenter" Icon="@Icons.Material.Filled.Description">
            <div class="pa-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           Href="@($"/dokumenter/{Id}")"
                           StartIcon="@Icons.Material.Filled.FolderOpen"
                           Style="text-transform:none;border-radius:8px;">
                    Åpne dokumentarkiv
                </MudButton>
            </div>
        </MudTabPanel>

        @* Tab: Arbeidssted (Geofence) *@
        <MudTabPanel Text="Arbeidssted" Icon="@Icons.Material.Filled.Map">
            <div class="pa-4">
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Arbeidsområde</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Bruk tegneverktøyene øverst til venstre på kartet for å markere arbeidsområder.
                    Du kan legge til flere soner (polygon, rektangel eller sirkel). Bruk blyanten for a redigere og sopelbotta for a slette.
                </MudText>

                <GeofenceEditor Latitude="_project?.Latitude"
                                Longitude="_project?.Longitude"
                                GeofenceGeoJson="@_project?.GeofenceGeoJson"
                                GeofenceRadiusMeters="_project?.GeofenceRadiusMeters"
                                Address="@_project?.Address"
                                OnGeofenceChanged="OnGeofenceUpdated" />

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveGeofence"
                               StartIcon="@Icons.Material.Filled.Save" Style="text-transform:none;border-radius:8px;"
                               Disabled="_savingGeofence">
                        @(_savingGeofence ? "Lagrer..." : "Lagre arbeidsområde")
                    </MudButton>
                    @if (_geofenceDirty)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">Ulagrede endringer</MudText>
                    }
                    @if (!string.IsNullOrEmpty(_project?.GeofenceGeoJson))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Område lagret</MudChip>
                    }
                </MudStack>
            </div>
        </MudTabPanel>
    </MudTabs>
}

@* ── Create object dialog ── *@
<MudDialog @bind-Visible="_showCreateObject" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Opprett objekter</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_objName" Label="Navn (f.eks. Fundament, Søyle, Vindu)"
                          Variant="Variant.Outlined" Required="true" />
            <MudStack Row="true" Spacing="2">
                <MudNumericField @bind-Value="_objStartNumber" Label="Fra nummer" Variant="Variant.Outlined"
                                 Min="1" Style="flex:1;" />
                <MudNumericField @bind-Value="_objCount" Label="Antall" Variant="Variant.Outlined"
                                 Min="1" Max="50" Style="flex:1;" />
            </MudStack>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Oppretter @_objCount stk: @_objName @_objStartNumber–@(_objStartNumber + _objCount - 1)
            </MudText>

            <MudText Typo="Typo.subtitle2" Style="font-weight:600;">Velg sjekkliste-maler</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Hver mal opprettes som sjekkliste på hvert objekt.
            </MudText>
            <div style="max-height:200px;overflow-y:auto;border:1px solid #e9ecef;border-radius:8px;padding:8px;">
                @foreach (var t in _availableTemplates)
                {
                    var tmpl = t;
                    <MudCheckBox T="bool" Value="_selectedTemplateIds.Contains(tmpl.Id)"
                                 ValueChanged="@(v => { if (v) _selectedTemplateIds.Add(tmpl.Id); else _selectedTemplateIds.Remove(tmpl.Id); })"
                                 Label="@tmpl.Name" Dense="true" Color="Color.Primary" />
                }
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showCreateObject = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateObjectSubmit"
                   Disabled="string.IsNullOrWhiteSpace(_objName) || _selectedTemplateIds.Count == 0 || _creatingObject"
                   Style="text-transform:none;border-radius:8px;">
            @(_creatingObject ? "Oppretter..." : $"Opprett {_objCount} objekter")
        </MudButton>
    </DialogActions>
</MudDialog>

@* ── Assign equipment dialog ── *@
<MudDialog @bind-Visible="_showAssignEquipment" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Legg til utstyr</MudText></TitleContent>
    <DialogContent>
        <MudSelect T="Guid?" @bind-Value="_assignEquipmentId" Label="Velg utstyr"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
            @foreach (var eq in _allEquipment.Where(e => !_projectEquipment.Any(pe => pe.Id == e.Id)))
            {
                <MudSelectItem T="Guid?" Value="@eq.Id">@eq.Name @(eq.Type is not null ? $"({eq.Type})" : "")</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showAssignEquipment = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AssignEquipmentToProject"
                   Disabled="!_assignEquipmentId.HasValue || _assigningEquipment"
                   Style="text-transform:none;border-radius:8px;">
            @(_assigningEquipment ? "Legger til..." : "Legg til")
        </MudButton>
    </DialogActions>
</MudDialog>

@* ── Confirmation dialog ── *@
@if (_confirmAction is not null)
{
    var title = _confirmAction == "complete" ? "Fullfør prosjekt" : "Kanseller prosjekt";
    var msg = _confirmAction == "complete"
        ? "Er du sikker på at du vil fullføre dette prosjektet? Alle aktive registreringer vil bli avsluttet."
        : "Er du sikker på at du vil kansellere dette prosjektet?";
    var btnColor = _confirmAction == "complete" ? Color.Info : Color.Error;
    var btnText = _confirmAction == "complete" ? "Fullfør" : "Kanseller";

    <MudDialog @bind-Visible="_showConfirm" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent><MudText Typo="Typo.h6">@title</MudText></TitleContent>
        <DialogContent><MudText Typo="Typo.body2">@msg</MudText></DialogContent>
        <DialogActions>
            <MudButton OnClick="() => { _confirmAction = null; _showConfirm = false; }" Style="text-transform:none;">Avbryt</MudButton>
            <MudButton Variant="Variant.Filled" Color="@btnColor"
                       OnClick="ConfirmStatusChange"
                       Style="text-transform:none;border-radius:8px;">@btnText</MudButton>
        </DialogActions>
    </MudDialog>
}

@* ── Photo lightbox ── *@
@if (_lightboxUrl is not null)
{
    <div @onclick="() => _lightboxUrl = null"
         style="position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:24px;">
        <img src="@_lightboxUrl" style="max-width:95%;max-height:95%;object-fit:contain;border-radius:8px;" />
        <div style="position:absolute;top:16px;right:16px;color:#fff;font-size:1.5rem;cursor:pointer;">✕</div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Solodoc.Shared.Projects.ProjectDetailDto? _project;
    private bool _loading = true;
    private bool _isParentProject => _project?.ParentProjectId is null && (_project?.SubProjects?.Count > 0);

    private string? _lightboxUrl;

    // Geofence
    private bool _geofenceDirty;
    private bool _savingGeofence;
    private double? _pendingGeoLat;
    private double? _pendingGeoLng;
    private string? _pendingGeoJson;
    private double? _pendingGeoRadius;
    private string? _confirmAction;
    private bool _showConfirm;

    // Trigger confirmation dialog
    private string? ConfirmAction { set { _confirmAction = value; _showConfirm = value is not null; } }

    // Project posts (Innlegg)
    private List<ProjectPostDto> _posts = [];
    private string _newPostContent = "";
    private string? _newPostPhotoKey;
    private bool _postingNew;
    private Dictionary<Guid, string> _commentTexts = new();

    // Dashboard KPIs (loaded on init)
    private decimal _dashHoursParent;
    private int _dashChecklistsDoneParent;
    private int _dashChecklistsTotalParent;
    private int _dashDeviationsParent;
    private string _dashView = "all"; // "all", "parent", "sub:{guid}"

    // Computed filtered KPIs based on dropdown selection
    private decimal DashFilteredHours => _dashView switch
    {
        "all" => _dashHoursParent + (_project?.SubProjects?.Sum(s => s.TotalHours) ?? 0),
        "parent" => _dashHoursParent,
        _ when _dashView.StartsWith("sub:") && Guid.TryParse(_dashView[4..], out var sid)
            => _project?.SubProjects?.FirstOrDefault(s => s.Id == sid)?.TotalHours ?? 0,
        _ => _dashHoursParent
    };
    private int DashFilteredDeviations => _dashView switch
    {
        "all" => _dashDeviationsParent + (_project?.SubProjects?.Sum(s => s.OpenDeviations) ?? 0),
        "parent" => _dashDeviationsParent,
        _ when _dashView.StartsWith("sub:") && Guid.TryParse(_dashView[4..], out var sid)
            => _project?.SubProjects?.FirstOrDefault(s => s.Id == sid)?.OpenDeviations ?? 0,
        _ => _dashDeviationsParent
    };
    private int DashFilteredChecklistsDone => _dashView switch
    {
        "all" => _dashChecklistsDoneParent + (_project?.SubProjects?.Sum(s => s.ChecklistsCompleted) ?? 0),
        "parent" => _dashChecklistsDoneParent,
        _ when _dashView.StartsWith("sub:") && Guid.TryParse(_dashView[4..], out var sid)
            => _project?.SubProjects?.FirstOrDefault(s => s.Id == sid)?.ChecklistsCompleted ?? 0,
        _ => _dashChecklistsDoneParent
    };
    private int DashFilteredChecklistsTotal => _dashView switch
    {
        "all" => _dashChecklistsTotalParent + (_project?.SubProjects?.Sum(s => s.ChecklistsTotal) ?? 0),
        "parent" => _dashChecklistsTotalParent,
        _ when _dashView.StartsWith("sub:") && Guid.TryParse(_dashView[4..], out var sid)
            => _project?.SubProjects?.FirstOrDefault(s => s.Id == sid)?.ChecklistsTotal ?? 0,
        _ => _dashChecklistsTotalParent
    };
    private void OnDashViewChanged(string view) { _dashView = view; StateHasChanged(); }

    // Tab data
    private List<Solodoc.Shared.Checklists.ChecklistInstanceListItemDto> _checklists = [];
    private List<Solodoc.Shared.Hours.TimeEntryListItemDto> _timeEntries = [];
    private List<Solodoc.Shared.Deviations.DeviationListItemDto> _deviations = [];
    private List<Solodoc.Shared.Employees.EmployeeListItemDto> _crewMembers = [];

    private bool _loadingChecklists;
    private bool _loadingHours;
    private bool _loadingDeviations;
    private bool _loadingCrew;
    private List<OnSitePersonDto> _onSitePersons = [];

    private bool _checklistsLoaded;
    private bool _hoursLoaded;
    private bool _deviationsLoaded;
    private bool _crewLoaded;
    private bool _expensesLoaded;

    // Expenses
    private List<ExpenseListItemDto> _projectExpenses = [];
    private bool _loadingExpenses;
    private bool _isExpenseAdmin;
    private bool _canManageProject;
    private bool _isExpenseAccountant;

    // Objects
    private List<Solodoc.Shared.Checklists.ChecklistObjectDto> _objects = [];
    private List<Solodoc.Shared.Checklists.ChecklistTemplateListItemDto> _availableTemplates = [];
    private bool _showCreateObject;
    private bool _creatingObject;
    private string _objName = "";
    private int _objStartNumber = 1;
    private int _objCount = 1;
    private HashSet<Guid> _selectedTemplateIds = [];

    // Equipment
    private List<Solodoc.Shared.Equipment.EquipmentListItemDto> _projectEquipment = [];
    private List<Solodoc.Shared.Equipment.EquipmentListItemDto> _allEquipment = [];
    private bool _showAssignEquipment;
    private Guid? _assignEquipmentId;
    private bool _assigningEquipment;

    // Checklist creation state
    private bool _showChecklistPicker;
    private List<Solodoc.Shared.Checklists.ChecklistTemplateListItemDto> _publishedTemplates = [];
    private Guid? _selectedTemplateId;
    private string _checklistLocation = string.Empty;
    private bool _creatingChecklist;

    private void GoToDeviation(Guid id) => Navigation.NavigateTo($"/deviations/{id}");

    private RenderFragment RenderChecklistGroup(List<Solodoc.Shared.Checklists.ChecklistInstanceListItemDto> items) => __builder =>
    {
        var grouped = items.GroupBy(c => c.TemplateName).ToList();

        foreach (var group in grouped)
        {
            if (group.Count() == 1)
            {
                // Single item — render directly
                var cl = group.First();
                var capturedCl = cl;
                @RenderSingleChecklist(capturedCl);
            }
            else
            {
                // Multiple items of same template — expandable group
                var groupList = group.OrderBy(c => c.LocationIdentifier).ToList();
                var groupCompleted = groupList.Count(c => c.Status is "Innsendt" or "Godkjent");
                <MudExpansionPanels Class="mb-2">
                    <MudExpansionPanel Style="border:1px solid #e9ecef;border-radius:12px;">
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                                <MudText Typo="Typo.body1" Style="font-weight:600;">@group.Key</MudText>
                                <MudChip T="string" Size="Size.Small" Style="height:22px;">
                                    @groupCompleted / @groupList.Count
                                </MudChip>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            @foreach (var cl in groupList)
                            {
                                var capturedCl = cl;
                                @RenderSingleChecklist(capturedCl);
                            }
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
        }
    };

    private RenderFragment RenderSingleChecklist(Solodoc.Shared.Checklists.ChecklistInstanceListItemDto cl) => __builder =>
    {
        var statusColor = cl.Status switch
        {
            "Godkjent" => Color.Success, "Innsendt" => Color.Info,
            "Utkast" => Color.Default, _ => Color.Warning
        };
        var capturedCl = cl;
        var pct = cl.ItemCount > 0 ? (double)cl.CompletedItemCount / cl.ItemCount * 100 : 0;

        <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:8px;cursor:pointer;"
                  Class="pa-3 mb-2" @onclick="() => GoToChecklist(capturedCl)">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap:wrap;gap:8px;">
                <MudStack Spacing="0" Style="flex:1;min-width:0;">
                    @if (!string.IsNullOrWhiteSpace(cl.ObjectDisplayName))
                    {
                        <MudText Typo="Typo.caption" Style="font-weight:600;color:#00B5A6;">@cl.ObjectDisplayName</MudText>
                    }
                    else if (!string.IsNullOrWhiteSpace(cl.LocationIdentifier))
                    {
                        <MudText Typo="Typo.caption" Style="font-weight:600;color:#00B5A6;">@cl.LocationIdentifier</MudText>
                    }
                    <MudText Typo="Typo.body2" Style="font-weight:500;">@cl.TemplateName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @cl.StartedBy · @cl.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                    </MudText>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudStack Spacing="0" Style="min-width:50px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@cl.CompletedItemCount/@cl.ItemCount</MudText>
                        <MudProgressLinear Value="@pct" Color="Color.Primary" Rounded="true" Style="height:4px;" />
                    </MudStack>
                    <MudChip T="string" Size="Size.Small" Color="@statusColor" Style="height:22px;">@cl.Status</MudChip>
                    @if (cl.Status is "Utkast" or "Gjenåpnet" or "Gjenapnet")
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="() => GoToChecklist(capturedCl)"
                                   Style="text-transform:none;border-radius:6px;">Fyll ut</MudButton>
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                       Color="Color.Error" Title="Fjern"
                                       OnClick="async () => await RemoveChecklistInstance(capturedCl.Id)" />
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    };

    private async Task RemoveChecklistInstance(Guid instanceId)
    {
        if (await ChecklistService.DeleteInstanceAsync(instanceId))
        {
            Snackbar.Add("Sjekkliste fjernet", Severity.Success);
            _checklists = await ChecklistService.GetInstancesAsync(Id);
            StateHasChanged();
        }
        else Snackbar.Add("Kunne ikke fjerne. Kun utkast kan slettes.", Severity.Warning);
    }

    private void GoToChecklist(Solodoc.Shared.Checklists.ChecklistInstanceListItemDto cl)
    {
        if (cl.Status is "Utkast" or "Gjenåpnet" or "Gjenapnet")
            Navigation.NavigateTo($"/checklists/{cl.Id}/fill");
        else
            Navigation.NavigateTo($"/checklists/{cl.Id}");
    }

    private void GoBack()
    {
        if (_project?.ParentProjectId.HasValue == true)
            Navigation.NavigateTo($"/projects/{_project.ParentProjectId}");
        else
            Navigation.NavigateTo("/projects");
    }

    private Guid _lastLoadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _lastLoadedId)
        {
            _lastLoadedId = Id;
            await LoadProject();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _lastLoadedId = Id;
        await LoadProject();
    }

    private async Task LoadProject()
    {
        _loading = true;
        _checklistsLoaded = false;
        _hoursLoaded = false;
        _deviationsLoaded = false;
        _crewLoaded = false;

        _project = await ProjectService.GetProjectByIdAsync(Id);

        // Check role for project management buttons
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var roles = auth.User.Claims.Where(c => c.Type == "role" || c.Type.Contains("/role"))
            .Select(c => c.Value).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _canManageProject = auth.User.HasClaim("sa", "1") || roles.Contains("tenant-admin") || roles.Contains("TenantAdmin")
            || roles.Contains("project-leader") || roles.Contains("ProjectLeader");

        _loading = false;

        // Load dashboard KPIs in parallel
        try
        {
            var hoursTask = HoursService.GetTimeEntriesAsync(projectId: Id);
            var checklistsTask = ChecklistService.GetInstancesAsync(Id);
            var onSiteTask = CheckInService.GetOnSiteAsync("project", Id);

            var hours = await hoursTask;
            _dashHoursParent = hours.Items.Sum(h => h.Hours);

            var checklists = await checklistsTask;
            _dashChecklistsTotalParent = checklists.Count;
            _dashChecklistsDoneParent = checklists.Count(c => c.Status is "Innsendt" or "Godkjent");
            _dashDeviationsParent = _project?.OpenDeviations.Count ?? 0;

            _onSitePersons = await onSiteTask;

            // Load posts
            await LoadPosts();
        }
        catch { }
        StateHasChanged();
    }

    private async Task OnTabChanged(int tabIndex)
    {
        // Tab 0=Oversikt, 1=Underprosjekter, 2=Sjekklister, 3=Objekter, 4=Timer, 5=Avvik, 6=Personell, 7=Utlegg, 8=Utstyr, 9=Dokumenter, 10=Arbeidssted
        switch (tabIndex)
        {
            case 2 when !_checklistsLoaded:
                await LoadChecklistsAsync();
                if (_objects.Count == 0) await LoadObjectsAsync();
                break;
            case 3:
                await LoadObjectsAsync();
                break;
            case 4 when !_hoursLoaded:
                await LoadHoursAsync();
                break;
            case 5 when !_deviationsLoaded:
                await LoadDeviationsAsync();
                break;
            case 6 when !_crewLoaded:
                await LoadCrewAsync();
                break;
            case 7 when !_expensesLoaded:
                await LoadExpensesAsync();
                break;
            case 8:
                await LoadProjectEquipmentAsync();
                break;
        }
    }

    private async Task LoadChecklistsAsync()
    {
        _loadingChecklists = true;
        StateHasChanged();
        _checklists = await ChecklistService.GetInstancesAsync(Id);
        _checklistsLoaded = true;
        _loadingChecklists = false;
        StateHasChanged();
    }

    private async Task LoadHoursAsync()
    {
        _loadingHours = true;
        StateHasChanged();
        var result = await HoursService.GetTimeEntriesAsync(projectId: Id);
        _timeEntries = result.Items.ToList();
        _hoursLoaded = true;
        _loadingHours = false;
        StateHasChanged();
    }

    private async Task LoadDeviationsAsync()
    {
        _loadingDeviations = true;
        StateHasChanged();
        var result = await DeviationService.GetDeviationsForProjectAsync(Id);
        _deviations = result.Items.ToList();
        _deviationsLoaded = true;
        _loadingDeviations = false;
        StateHasChanged();
    }

    private async Task LoadCrewAsync()
    {
        _loadingCrew = true;
        StateHasChanged();
        _crewMembers = await EmployeeService.GetProjectCrewAsync(Id);
        _crewLoaded = true;
        _loadingCrew = false;
        StateHasChanged();
    }

    private async Task ExportCheckInLog()
    {
        try
        {
            var r = await Api.GetAsync(CheckInService.GetExportUrl("project", Id));
            if (r.IsSuccessStatusCode)
            {
                var bytes = await r.Content.ReadAsByteArrayAsync();
                var b64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("eval", $"{{ var a=document.createElement('a'); a.href='data:text/csv;base64,{b64}'; a.download='innsjekking-{_project?.Name ?? "prosjekt"}.csv'; a.click(); }}");
            }
            else
                Snackbar.Add("Kunne ikke eksportere", Severity.Error);
        }
        catch { Snackbar.Add("Kunne ikke eksportere", Severity.Error); }
    }

    private async Task LoadExpensesAsync()
    {
        _loadingExpenses = true;
        StateHasChanged();

        // Check roles for approve/pay actions
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var roles = auth.User.Claims
            .Where(c => c.Type == "role" || c.Type.Contains("/role"))
            .Select(c => c.Value).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _isExpenseAdmin = auth.User.HasClaim("sa", "1") || roles.Contains("tenant-admin") || roles.Contains("TenantAdmin");
        _isExpenseAccountant = _isExpenseAdmin || roles.Contains("Regnskapsforer") || roles.Contains("regnskapsforer");

        var (items, _) = await ExpenseService.GetExpensesAsync(projectId: Id);
        _projectExpenses = items;
        _expensesLoaded = true;
        _loadingExpenses = false;
        StateHasChanged();
    }

