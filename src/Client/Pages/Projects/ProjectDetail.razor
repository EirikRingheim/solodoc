    // ── Geofence ──

    private void OnGeofenceUpdated(GeofenceEditor.GeofenceData data)
    {
        _pendingGeoLat = data.Latitude;
        _pendingGeoLng = data.Longitude;
        _pendingGeoJson = data.GeoJson;
        _pendingGeoRadius = data.RadiusMeters;
        _geofenceDirty = true;
        StateHasChanged();
    }

    private async Task SaveGeofence()
    {
        if (_project is null) return;
        _savingGeofence = true;
        StateHasChanged();

        var request = new Solodoc.Shared.Projects.UpdateProjectGeofenceRequest(
            _pendingGeoLat, _pendingGeoLng, _pendingGeoJson, _pendingGeoRadius);
        var ok = await ProjectService.UpdateGeofenceAsync(_project.Id, request);

        if (ok)
        {
            Snackbar.Add("Arbeidsområde lagret", Severity.Success);
            _geofenceDirty = false;
            // Reload project so geofence shows on next tab visit
            _project = await ProjectService.GetProjectByIdAsync(Id);
        }
        else
        {
            Snackbar.Add("Kunne ikke lagre arbeidsområde", Severity.Error);
        }

        _savingGeofence = false;
        StateHasChanged();
    }
