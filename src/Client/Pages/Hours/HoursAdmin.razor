    private static string AutoColon(string v)
    {
        if (string.IsNullOrEmpty(v)) return v;
        var clean = v.Replace(":", "").Replace(".", "");
        if (clean.Length == 2 && !v.Contains(':') && !v.Contains('.')) return clean + ":";
        if (v.Length > 5) return v[..5];
        return v;
    }

    private static TimeSpan? ParseTime(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return null;
        s = s.Trim().Replace('.', ':');
        if (TimeSpan.TryParseExact(s, @"hh\:mm", null, out var ts)) return ts;
        if (TimeSpan.TryParseExact(s, @"h\:mm", null, out ts)) return ts;
        if (int.TryParse(s, out var h) && h is >= 0 and <= 23) return new TimeSpan(h, 0, 0);
        return null;
    }

    // ── Admin Edit Day ──

    private bool _editDayDialogOpen;
    private readonly DialogOptions _editDayDialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
    private DayDetailDto? _editDayDetail;
    private string _editEmployeeName = "";
    private Guid _editPersonId;
    private DateOnly _editDayDate;
    private string _adminStartStr = "07:00";
    private string _adminEndStr = "15:00";
    private string? _adminTargetKey;
    private string _adminCategory = "Arbeid";
    private bool _adminSaving;
    private List<ProjectListItemDto> _adminProjects = [];

    private async Task OpenAdminEdit(int row, int col)
    {
        if (row < 0 || row >= _filteredRows.Count || col < 0 || col >= _filteredRows[row].Cells.Count) return;

        var r = _filteredRows[row];
        _editPersonId = r.PersonId;
        _editEmployeeName = r.EmployeeName;
        _editDayDate = r.Cells[col].Date;

        // Load projects if not loaded
        if (_adminProjects.Count == 0)
        {
            try { _adminProjects = await ProjectService.GetActiveProjectsAsync(); } catch { }
        }

        // Load day detail
        _editDayDetail = await HoursService.GetDayDetailAsync(_editPersonId, _editDayDate);

        // Chain from last entry
        if (_editDayDetail?.Entries.Count > 0)
        {
            var last = _editDayDetail.Entries.LastOrDefault(e => e.EndTime.HasValue);
            if (last?.EndTime is not null)
            {
                var t = last.EndTime.Value.ToLocalTime().TimeOfDay;
                _adminStartStr = $"{t.Hours:D2}:{t.Minutes:D2}";
                var end = t.Add(TimeSpan.FromHours(1));
                _adminEndStr = end.TotalHours >= 24 ? "23:59" : $"{end.Hours:D2}:{end.Minutes:D2}";
            }
            else
            {
                _adminStartStr = "07:00"; _adminEndStr = "15:00";
            }
        }
        else
        {
            _adminStartStr = "07:00"; _adminEndStr = "15:00";
        }

        _editDayDialogOpen = true;
        StateHasChanged();
    }

    private async Task SaveAdminEntry()
    {
        var start = ParseTime(_adminStartStr);
        var end = ParseTime(_adminEndStr);
        if (start is null || end is null) { Snackbar.Add("Ugyldig tid", Severity.Warning); return; }

        _adminSaving = true; StateHasChanged();

        var (projectId, jobId) = ParseAdminTarget();
        var startDto = new DateTimeOffset(_editDayDate.ToDateTime(new TimeOnly(start.Value.Hours, start.Value.Minutes)), TimeSpan.Zero);
        var endDto = new DateTimeOffset(_editDayDate.ToDateTime(new TimeOnly(end.Value.Hours, end.Value.Minutes)), TimeSpan.Zero);
        if (endDto <= startDto) endDto = endDto.AddDays(1);

        // Note: this creates a manual entry as the admin user. For proper "on behalf of" we'd need a separate endpoint.
        // For now it creates under admin's name — good enough for corrections.
        var request = new ManualTimeEntryRequest(_editDayDate, null, projectId, jobId, _adminCategory, null, startDto, endDto, 30);
        var id = await HoursService.CreateManualEntryAsync(request);

        if (id.HasValue)
        {
            Snackbar.Add("Periode lagt til", Severity.Success);
            _editDayDetail = await HoursService.GetDayDetailAsync(_editPersonId, _editDayDate);
            // Chain times
            _adminStartStr = _adminEndStr;
            var endTs = ParseTime(_adminEndStr);
            if (endTs.HasValue)
            {
                var next = endTs.Value.Add(TimeSpan.FromHours(1));
                _adminEndStr = next.TotalHours >= 24 ? "23:59" : $"{next.Hours:D2}:{next.Minutes:D2}";
            }
            await LoadHeatmap();
        }
        else
        {
            Snackbar.Add("Feil ved lagring", Severity.Error);
        }

        _adminSaving = false; StateHasChanged();
    }

    private (Guid? projectId, Guid? jobId) ParseAdminTarget()
    {
        if (string.IsNullOrEmpty(_adminTargetKey)) return (null, null);
        if (_adminTargetKey.StartsWith("p:") && Guid.TryParse(_adminTargetKey[2..], out var pid)) return (pid, null);
        if (_adminTargetKey.StartsWith("j:") && Guid.TryParse(_adminTargetKey[2..], out var jid)) return (null, jid);
        return (null, null);
    }
