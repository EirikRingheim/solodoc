@page "/deviations"
@attribute [Authorize]
@inject DeviationService DeviationService
@inject NavigationManager Navigation

<PageTitle>Solodoc - Avvik</PageTitle>
<PageHelp PageKey="deviations" />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">Avvik</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/deviations/new"
               Style="text-transform:none;border-radius:8px;">
        Nytt avvik
    </MudButton>
</MudStack>

@* Filters *@
<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3" Style="flex-wrap:wrap;">
    <MudTextField T="string" Value="_search" Placeholder="Sok avvik..."
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" DebounceInterval="300"
                  ValueChanged="OnSearchChanged"
                  Style="max-width:300px;min-width:200px;" />
    <MudSelect T="string" Value="_statusFilter" Label="Status" Variant="Variant.Outlined"
               Margin="Margin.Dense" Clearable="true" Style="max-width:200px;min-width:150px;"
               ValueChanged="OnStatusFilterChanged">
        <MudSelectItem Value="@("Åpen")">Åpen</MudSelectItem>
        <MudSelectItem Value="@("Under behandling")">Under behandling</MudSelectItem>
        <MudSelectItem Value="@("Lukket")">Lukket</MudSelectItem>
    </MudSelect>
    <MudSelect T="string" Value="_severityFilter" Label="Alvorlighet" Variant="Variant.Outlined"
               Margin="Margin.Dense" Clearable="true" Style="max-width:200px;min-width:150px;"
               ValueChanged="OnSeverityFilterChanged">
        <MudSelectItem Value="@("Lav")">Lav</MudSelectItem>
        <MudSelectItem Value="@("Middels")">Middels</MudSelectItem>
        <MudSelectItem Value="@("Høy")">Høy</MudSelectItem>
    </MudSelect>
</MudStack>

<MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;overflow:hidden;">
    <MudDataGrid @ref="_grid" T="DeviationListItemDto"
                 ServerData="LoadServerData"
                 Sortable="true"
                 Filterable="false"
                 Hover="true"
                 Dense="false"
                 RowClick="OnRowClick"
                 RowStyle="cursor:pointer;"
                 Loading="_loading">
        <Columns>
            <PropertyColumn Property="x => x.Title" Title="Tittel" />
            <PropertyColumn Property="x => x.ProjectName" Title="Prosjekt" SortLabel="projectname" />
            <TemplateColumn Title="Status" SortLabel="status">
                <CellTemplate>
                    @{
                        var statusCss = context.Item.Status switch
                        {
                            "Åpen" => "status-badge status-badge--open",
                            "Under behandling" => "status-badge status-badge--inprogress",
                            _ => "status-badge status-badge--closed"
                        };
                    }
                    <span class="@statusCss">@context.Item.Status</span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Alvorlighet" SortLabel="severity">
                <CellTemplate>
                    @{
                        var sevColor = context.Item.Severity switch
                        {
                            "Høy" => Color.Error,
                            "Middels" => Color.Warning,
                            _ => Color.Success
                        };
                    }
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@sevColor" Style="height:22px;">@context.Item.Severity</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ReportedBy" Title="Rapportert av" Sortable="false" />
            <TemplateColumn Title="Dato" SortLabel="createdat">
                <CellTemplate>
                    <MudText Typo="Typo.body2">
                        @context.Item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                    </MudText>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="DeviationListItemDto"
                              PageSizeOptions="@(new[] { 10, 25, 50 })" />
        </PagerContent>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large" Color="Color.Success" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen avvik funnet</MudText>
            </MudStack>
        </NoRecordsContent>
    </MudDataGrid>
</MudPaper>

@code {
    private string? _search;
    private string? _statusFilter;
    private string? _severityFilter;
    private bool _loading;
    private MudDataGrid<DeviationListItemDto>? _grid;

    private async Task<GridData<DeviationListItemDto>> LoadServerData(
        GridState<DeviationListItemDto> state, CancellationToken ct)
    {
        _loading = true;
        StateHasChanged();

        var sortDef = state.SortDefinitions.FirstOrDefault();
        var sortBy = sortDef?.SortBy;
        var sortDesc = sortDef?.Descending ?? false;

        var page = state.Page + 1;

        // Build search string combining text search with filters
        var searchParts = new List<string>();
        if (!string.IsNullOrWhiteSpace(_search))
            searchParts.Add(_search);
        if (!string.IsNullOrWhiteSpace(_statusFilter))
            searchParts.Add($"status:{_statusFilter}");
        if (!string.IsNullOrWhiteSpace(_severityFilter))
            searchParts.Add($"severity:{_severityFilter}");

        var combinedSearch = searchParts.Count > 0 ? string.Join(" ", searchParts) : null;

        var result = await DeviationService.GetDeviationsAsync(
            page, state.PageSize, combinedSearch, sortBy, sortDesc);

        _loading = false;

        return new GridData<DeviationListItemDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        if (_grid is not null)
            await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(string? value)
    {
        _statusFilter = value;
        if (_grid is not null)
            await _grid.ReloadServerData();
    }

    private async Task OnSeverityFilterChanged(string? value)
    {
        _severityFilter = value;
        if (_grid is not null)
            await _grid.ReloadServerData();
    }

    private void OnRowClick(DataGridRowClickEventArgs<DeviationListItemDto> args)
    {
        Navigation.NavigateTo($"/deviations/{args.Item.Id}");
    }
}
