@page "/deviations/new"
@attribute [Authorize]
@inject DeviationService DeviationService
@inject ProjectService ProjectService
@inject JobService JobService
@inject LocationService LocationService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - Nytt avvik</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/deviations" />
    <MudText Typo="Typo.h5">Rapporter avvik</MudText>
</MudStack>

<MudPaper Class="pa-5" Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;max-width:700px;">
    <MudStack Spacing="4">
        @* ── Beskriv ── *@
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Beskriv avviket</MudText>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_title" Label="Tittel" Variant="Variant.Outlined"
                              Required="true" RequiredError="Tittel er påkrevd"
                              Placeholder="Kort beskrivelse av avviket" />
                <MudTextField @bind-Value="_description" Label="Beskrivelse" Variant="Variant.Outlined"
                              Lines="4" Placeholder="Detaljert beskrivelse (valgfritt)" />
            </MudStack>
        </div>

        <MudDivider />

        @* ── Klassifiser ── *@
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Klassifiser</MudText>
            <MudStack Spacing="3">
                <MudSelect @bind-Value="_severity" Label="Alvorlighet" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Lav")">Lav</MudSelectItem>
                    <MudSelectItem Value="@("Middels")">Middels</MudSelectItem>
                    <MudSelectItem Value="@("Høy")">Høy</MudSelectItem>
                </MudSelect>
                <MudSelect @bind-Value="_categoryId" Label="Kategori" Variant="Variant.Outlined"
                           Clearable="true" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem Value="@((Guid?)cat.Id)">@cat.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        </div>

        <MudDivider />

        @* ── Koble til sted ── *@
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Koble til sted</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">Valgfritt — velg hvor avviket ble oppdaget.</MudText>
            <MudStack Spacing="3">
                <MudSelect @bind-Value="_projectId" Label="Prosjekt" Variant="Variant.Outlined"
                           Clearable="true" AnchorOrigin="Origin.BottomCenter"
                           AdornmentIcon="@Icons.Material.Filled.Folder">
                    @foreach (var p in _projects.Where(p => p.ParentProjectId is null))
                    {
                        <MudSelectItem Value="@((Guid?)p.Id)">@p.Name</MudSelectItem>
                        @foreach (var sub in _projects.Where(s => s.ParentProjectId == p.Id))
                        {
                            <MudSelectItem Value="@((Guid?)sub.Id)">
                                <span style="padding-left:16px;color:#6B7280;">↳ @sub.Name</span>
                            </MudSelectItem>
                        }
                    }
                </MudSelect>
                <MudSelect @bind-Value="_jobId" Label="Oppdrag" Variant="Variant.Outlined"
                           Clearable="true" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var j in _jobs)
                    {
                        <MudSelectItem Value="@((Guid?)j.Id)">@j.Description</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect @bind-Value="_locationId" Label="Lokasjon" Variant="Variant.Outlined"
                           Clearable="true" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var l in _locations)
                    {
                        <MudSelectItem Value="@((Guid?)l.Id)">@l.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        </div>

        <MudDivider />

        @* ── Send inn ── *@
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudButton Variant="Variant.Text" Href="/deviations" Style="text-transform:none;">Avbryt</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="HandleSubmit" Disabled="_submitting"
                       StartIcon="@Icons.Material.Filled.Send"
                       Style="text-transform:none;border-radius:8px;">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
                }
                Send inn
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    private string _title = "";
    private string _description = "";
    private string _severity = "Middels";
    private Guid? _categoryId;
    private Guid? _projectId;
    private Guid? _jobId;
    private Guid? _locationId;
    private bool _submitting;
    private List<ProjectListItemDto> _projects = [];
    private List<JobListItemDto> _jobs = [];
    private List<LocationListItemDto> _locations = [];
    private List<DeviationCategoryDto> _categories = [];

    protected override async Task OnInitializedAsync()
    {
        var projectsTask = ProjectService.GetProjectsAsync(1, 100, null, "name", false);
        var jobsTask = JobService.GetJobsAsync(1, 50, null, null, false);
        var locationsTask = LocationService.GetLocationsAsync();
        var categoriesTask = DeviationService.GetCategoriesAsync();
        _projects = (await projectsTask).Items;
        _jobs = (await jobsTask).Items.ToList();
        _locations = await locationsTask;
        _categories = (await categoriesTask).Where(c => c.IsActive).ToList();
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Tittel er påkrevd", Severity.Warning);
            return;
        }

        _submitting = true;
        var id = await DeviationService.CreateDeviationAsync(
            new(_title, string.IsNullOrWhiteSpace(_description) ? null : _description, _severity, _projectId, _jobId, _locationId, _categoryId));

        if (id.HasValue)
        {
            Snackbar.Add("Avvik rapportert", Severity.Success);
            Navigation.NavigateTo($"/deviations/{id.Value}");
        }
        else
        {
            Snackbar.Add("Kunne ikke opprette avvik", Severity.Error);
        }
        _submitting = false;
    }
}
