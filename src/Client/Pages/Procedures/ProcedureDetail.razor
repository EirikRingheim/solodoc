@page "/procedures/{Id:guid}"
@attribute [Authorize]
@inject ProcedureService ProcedureService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - @(_procedure?.Name ?? "Prosedyre")</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/procedures" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">@(_procedure?.Name ?? "Laster...")</MudText>
    @if (_procedure?.Category is not null)
    {
        <MudChip T="string" Size="Size.Small" Style="height:22px;">@_procedure.Category</MudChip>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_procedure is null)
{
    <MudAlert Severity="Severity.Warning">Prosedyre ble ikke funnet.</MudAlert>
}
else
{
    @* ── Document-style container ── *@
    <MudPaper Elevation="1" Style="border-radius:12px;max-width:900px;margin:0 auto;" Class="pa-0">

        @* Document header *@
        <div style="background:linear-gradient(135deg,#4361EE10,#4361EE05);padding:32px;border-bottom:1px solid #E9ECEF;">
            <MudText Typo="Typo.h4" Style="font-weight:700;">@_procedure.Name</MudText>
            @if (!string.IsNullOrWhiteSpace(_procedure.Description))
            {
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">@_procedure.Description</MudText>
            }
            @if (_procedure.Category is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Kategori: @_procedure.Category</MudText>
            }
        </div>

        @* Document body *@
        <div style="padding:32px;">
            @if (_procedure.Blocks.Count == 0)
            {
                <MudText Typo="Typo.body1" Color="Color.Secondary" Style="text-align:center;padding:40px 0;">
                    Denne prosedyren har ingen innhold ennå.
                </MudText>
            }
            else
            {
                var sectionNumber = 0;
                @foreach (var block in _procedure.Blocks)
                {
                    sectionNumber++;
                    <div style="margin-bottom:24px;">
                        @switch (block.Type.ToLowerInvariant())
                        {
                            case "text":
                                <div style="display:flex;gap:12px;">
                                    <div style="min-width:32px;text-align:right;">
                                        <span style="font-weight:700;color:#4361EE;font-size:0.9rem;">@sectionNumber.</span>
                                    </div>
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.body1" Style="white-space:pre-wrap;line-height:1.7;">@block.Content</MudText>
                                    </div>
                                </div>
                                break;

                            case "steplist":
                                var steps = block.Content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                <div style="display:flex;gap:12px;">
                                    <div style="min-width:32px;text-align:right;">
                                        <span style="font-weight:700;color:#4361EE;font-size:0.9rem;">@sectionNumber.</span>
                                    </div>
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Fremgangsmåte</MudText>
                                        @for (var i = 0; i < steps.Length; i++)
                                        {
                                            var stepNum = i + 1;
                                            <div style="display:flex;gap:10px;margin-bottom:8px;align-items:flex-start;">
                                                <div style="width:24px;height:24px;border-radius:50%;background:#4361EE;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0;margin-top:2px;">
                                                    @stepNum
                                                </div>
                                                <MudText Typo="Typo.body1" Style="line-height:1.6;">@steps[i]</MudText>
                                            </div>
                                        }
                                    </div>
                                </div>
                                break;

                            case "responsibility":
                                var rows = block.Content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                <div style="display:flex;gap:12px;">
                                    <div style="min-width:32px;text-align:right;">
                                        <span style="font-weight:700;color:#4361EE;font-size:0.9rem;">@sectionNumber.</span>
                                    </div>
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Ansvar</MudText>
                                        <MudSimpleTable Dense="true" Style="border:1px solid #E9ECEF;border-radius:8px;">
                                            <thead><tr style="background:#F8F9FA;"><th>Rolle</th><th>Ansvar</th></tr></thead>
                                            <tbody>
                                                @foreach (var row in rows)
                                                {
                                                    var parts = row.Split('|', 2, StringSplitOptions.TrimEntries);
                                                    <tr>
                                                        <td style="font-weight:500;">@parts[0]</td>
                                                        <td>@(parts.Length > 1 ? parts[1] : "")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    </div>
                                </div>
                                break;

                            case "warning":
                                <div style="display:flex;gap:12px;">
                                    <div style="min-width:32px;text-align:right;">
                                        <span style="font-weight:700;color:#D97706;font-size:0.9rem;">⚠</span>
                                    </div>
                                    <div style="flex:1;background:#FFFBEB;border:1px solid #FDE68A;border-radius:8px;padding:16px;">
                                        <MudText Typo="Typo.body1" Style="white-space:pre-wrap;color:#92400E;">@block.Content</MudText>
                                    </div>
                                </div>
                                break;

                            case "reference":
                                var refs = block.Content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                <div style="display:flex;gap:12px;">
                                    <div style="min-width:32px;text-align:right;">
                                        <span style="font-weight:700;color:#4361EE;font-size:0.9rem;">@sectionNumber.</span>
                                    </div>
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">Referanser</MudText>
                                        @foreach (var r in refs)
                                        {
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="margin-bottom:4px;">
                                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Secondary" />
                                                <MudText Typo="Typo.body2">@r</MudText>
                                            </MudStack>
                                        }
                                    </div>
                                </div>
                                break;

                            default:
                                <div style="display:flex;gap:12px;">
                                    <div style="min-width:32px;text-align:right;">
                                        <span style="font-weight:700;color:#4361EE;font-size:0.9rem;">@sectionNumber.</span>
                                    </div>
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.body1" Style="white-space:pre-wrap;line-height:1.7;">@block.Content</MudText>
                                    </div>
                                </div>
                                break;
                        }
                    </div>
                }
            }
        </div>

        @* Read confirmation footer *@
        <div style="padding:24px 32px;border-top:1px solid #E9ECEF;background:#F9FAFB;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Justify="Justify.SpaceBetween" Style="flex-wrap:wrap;gap:8px;">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                           StartIcon="@(_hasRead ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Visibility)"
                           Style="text-transform:none;border-radius:8px;"
                           OnClick="MarkAsRead" Disabled="_hasRead">
                    @(_hasRead ? "Lest og bekreftet" : "Marker som lest")
                </MudButton>
                @if (_readStatus is not null)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_readStatus.ReadCount av @_readStatus.TotalWorkers har lest denne prosedyren
                    </MudText>
                }
            </MudStack>
        </div>
    </MudPaper>

    @* Read log *@
    @if (_readStatus is not null && _readStatus.Readers.Count > 0)
    {
        <MudExpansionPanels Class="mt-4" Style="max-width:900px;margin:0 auto;">
            <MudExpansionPanel Text="@($"Lest av ({_readStatus.ReadCount})")"
                               Style="border:1px solid #E9ECEF;border-radius:12px;">
                @foreach (var reader in _readStatus.Readers)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="padding:4px 0;">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@reader.PersonName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @reader.ReadAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </MudText>
                    </MudStack>
                }
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProcedureDetailDto? _procedure;
    private ProcedureReadStatusDto? _readStatus;
    private bool _loading = true;
    private bool _hasRead;

    protected override async Task OnInitializedAsync()
    {
        var procedureTask = ProcedureService.GetProcedureByIdAsync(Id);
        var readStatusTask = ProcedureService.GetReadStatusAsync(Id);
        await Task.WhenAll(procedureTask, readStatusTask);
        _procedure = await procedureTask;
        _readStatus = await readStatusTask;
        _loading = false;
    }

    private async Task MarkAsRead()
    {
        var success = await ProcedureService.MarkReadAsync(Id);
        if (success)
        {
            _hasRead = true;
            _readStatus = await ProcedureService.GetReadStatusAsync(Id);
            Snackbar.Add("Markert som lest", Severity.Success);
        }
        else
        {
            Snackbar.Add("Kunne ikke markere som lest", Severity.Error);
        }
    }
}
