@page "/checklists/templates/new"
@attribute [Authorize]
@inject ChecklistService ChecklistService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - Ny mal</PageTitle>

<MudButton Variant="Variant.Text" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.ArrowBack"
           Href="/checklists"
           Style="text-transform:none;margin-bottom:16px;">
    Tilbake til dokumenter
</MudButton>

<MudText Typo="Typo.h5" Class="mb-4">Ny mal</MudText>

<MudPaper Elevation="0" Style="border:1px solid #E9ECEF;border-radius:12px;" Class="pa-5">
    <MudForm @ref="_form">
        <MudStack Spacing="3">
            <MudSelect @bind-Value="_documentType" Label="Type" Variant="Variant.Outlined"
                       Required="true" RequiredError="Type er paakrevd">
                <MudSelectItem Value="@("Checklist")">Sjekkliste</MudSelectItem>
                <MudSelectItem Value="@("Schema")">Skjema</MudSelectItem>
                <MudSelectItem Value="@("Procedure")">Prosedyre</MudSelectItem>
            </MudSelect>

            <MudTextField T="string" @bind-Value="_name" Label="Navn" Required="true"
                          RequiredError="Navn er paakrevd" Variant="Variant.Outlined" />
            <MudTextField T="string" @bind-Value="_description" Label="Beskrivelse"
                          Variant="Variant.Outlined" Lines="3" />
            <MudTextField T="string" @bind-Value="_category" Label="Kategori"
                          Variant="Variant.Outlined"
                          HelperText="F.eks. Elektrisk, Brann, Generell" />

            <MudDivider Class="my-2" />

            @if (_documentType is "Checklist" or "Schema")
            {
                <MudSwitch T="bool" @bind-Value="_requireSignature" Label="Krev signatur"
                           Color="Color.Primary" />

                @if (_requireSignature)
                {
                    <MudNumericField T="int" @bind-Value="_signatureCount"
                                     Label="Antall signaturer" Min="1" Max="5"
                                     Variant="Variant.Outlined" />
                    <MudTextField T="string" @bind-Value="_signatureRoles"
                                  Label="Signaturroller (kommaseparert)"
                                  Variant="Variant.Outlined"
                                  HelperText="F.eks. Utfyller, Prosjektleder, Kontrollor" />
                }
            }

            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="Submit" Disabled="_submitting"
                           Style="text-transform:none;border-radius:8px;">
                    @if (_submitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Opprett mal
                </MudButton>
            </MudStack>
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    private MudForm? _form;
    private string _documentType = "Checklist";
    private string _name = string.Empty;
    private string? _description;
    private string? _category;
    private bool _requireSignature = true;
    private int _signatureCount = 1;
    private string? _signatureRoles;
    private bool _submitting;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var typeParam = query["type"];
        if (!string.IsNullOrWhiteSpace(typeParam) && typeParam is "Checklist" or "Schema" or "Procedure")
        {
            _documentType = typeParam;
        }
    }

    private async Task Submit()
    {
        if (_form is not null)
            await _form.ValidateAsync();

        if (_form?.IsValid != true)
            return;

        _submitting = true;

        var request = new CreateChecklistTemplateRequest(
            _name,
            _description,
            _category,
            _documentType,
            _requireSignature,
            _signatureCount,
            _signatureRoles);
        var id = await ChecklistService.CreateTemplateAsync(request);

        _submitting = false;

        if (id.HasValue)
        {
            Snackbar.Add("Mal opprettet", Severity.Success);
            Navigation.NavigateTo($"/checklists/templates/{id.Value}");
        }
        else
        {
            Snackbar.Add("Kunne ikke opprette mal", Severity.Error);
        }
    }
}
