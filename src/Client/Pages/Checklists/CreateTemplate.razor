@page "/checklists/templates/new"
@attribute [Authorize]
@inject ChecklistService ChecklistService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - Ny mal</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/checklists" />
    <MudText Typo="Typo.h5">Ny mal</MudText>
</MudStack>

<div style="max-width:600px;">
    @* ── Quick create ── *@
    <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-5 mb-4">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-3">Opprett fra bunnen</MudText>
        <MudStack Spacing="3">
            <MudTextField T="string" @bind-Value="_name" Label="Navn pa malen" Variant="Variant.Outlined"
                          Placeholder="F.eks. Brannsjekk, Overlevering, Fuktkontroll"
                          Required="true" Immediate="true" />

            <MudStack Row="true" Spacing="2">
                <MudChipSet T="string" @bind-SelectedValue="_documentType" Mandatory="true" SelectionMode="SelectionMode.SingleSelection">
                    <MudChip T="string" Value="@("Checklist")" Variant="Variant.Outlined" Color="Color.Primary"
                             Style="text-transform:none;">Sjekkliste</MudChip>
                    <MudChip T="string" Value="@("Schema")" Variant="Variant.Outlined" Color="Color.Primary"
                             Style="text-transform:none;">Skjema</MudChip>
                    <MudChip T="string" Value="@("Procedure")" Variant="Variant.Outlined" Color="Color.Primary"
                             Style="text-transform:none;">Prosedyre</MudChip>
                </MudChipSet>
            </MudStack>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="CreateAndEdit" Disabled="@(_submitting || string.IsNullOrWhiteSpace(_name))"
                       Style="text-transform:none;border-radius:8px;min-height:48px;">
                @if (_submitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Opprett og rediger
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Import from file ── *@
    <MudPaper Elevation="0" Style="border:2px dashed #4361EE40;border-radius:12px;background:#F8FAFF;" Class="pa-5">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.UploadFile" Size="Size.Large" Style="color:#4361EE;" />
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Importer eksisterende mal</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align:center;">
                Last opp en sjekkliste, skjema eller prosedyre du allerede bruker.
                Vi leser filen og konverterer den til Solodoc-format.
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Stotter PDF, Excel (.xlsx), Word (.docx)
            </MudText>
            <MudFileUpload T="IBrowserFile" Accept=".pdf,.xlsx,.xls,.docx,.doc" MaximumFileCount="1"
                           FilesChanged="HandleFileUpload">
                <ActivatorContent>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               Style="text-transform:none;border-radius:8px;"
                               Disabled="_importing">
                        @if (_importing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Leser fil...</span>
                        }
                        else
                        {
                            <span>Velg fil</span>
                        }
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
        </MudStack>
    </MudPaper>
</div>

@code {
    private string _name = "";
    private string _documentType = "Checklist";
    private bool _submitting;
    private bool _importing;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var typeParam = query["type"];
        if (!string.IsNullOrWhiteSpace(typeParam) && typeParam is "Checklist" or "Schema" or "Procedure")
            _documentType = typeParam;
    }

    private async Task CreateAndEdit()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        _submitting = true;

        var request = new CreateChecklistTemplateRequest(_name, null, null, _documentType);
        var id = await ChecklistService.CreateTemplateAsync(request);
        _submitting = false;

        if (id.HasValue)
            Navigation.NavigateTo($"/checklists/templates/{id.Value}");
        else
            Snackbar.Add("Kunne ikke opprette mal", Severity.Error);
    }

    private async Task HandleFileUpload(IBrowserFile? file)
    {
        if (file is null) return;
        _importing = true;
        StateHasChanged();

        try
        {
            var stream = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
            var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(ms);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(streamContent, "file", file.Name);

            var id = await ChecklistService.ImportTemplateFromFileAsync(content);

            ms.Dispose();
            stream.Dispose();

            if (id.HasValue)
            {
                Snackbar.Add("Mal importert! Sjekk og juster elementene.", Severity.Success);
                Navigation.NavigateTo($"/checklists/templates/{id.Value}");
            }
            else
            {
                Snackbar.Add("Kunne ikke lese filen. Prov et annet format.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Feil ved opplasting: {ex.Message}", Severity.Error);
        }

        _importing = false;
    }
}
