        new("Elektrokontroll", "Sjekkliste for kontroll av elektrisk anlegg.", "Elektro", "elektro", "#4361EE", 18),
        new("Kabelføring", "Dokumentasjon av kabelføring og merking.", "Elektro", "elektro", "#7C3AED", 10),
        new("Jordingsanlegg", "Kontroll av jordingsanlegg og potensialutjevning.", "Elektro", "elektro", "#059669", 8),
        new("Tavlekontroll", "Sjekkliste for kontroll av elektriske tavler.", "Elektro", "elektro", "#EA580C", 12),
        new("Lysanlegg", "Dokumentasjon av lysanlegg og nødlys.", "Elektro", "elektro", "#0891B2", 9),

        // HMS
