        // Generell
        new("Bilkontroll", "Daglig sjekk av firmabil — lys, dekk, olje, førstehjelp.", "Generell", "generell", "#6B7280", 10),
        new("Verktøykontroll", "Periodisk kontroll av elektrisk håndverktøy.", "Generell", "generell", "#4361EE", 8),
