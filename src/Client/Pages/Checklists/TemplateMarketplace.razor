        new("Betongstøp", "Dokumentasjon av betongstøp — temperatur, herdetid, prøver.", "Bygg", "bygg", "#EA580C", 10),
        new("Tetthetsprøving", "Tetthetsprøving av bygningskropp.", "Bygg", "bygg", "#059669", 6),
        new("Ferdigbefaring", "Sjekkliste for ferdigbefaring med kunde.", "Bygg", "bygg", "#D97706", 22),
