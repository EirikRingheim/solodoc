@page "/templates/marketplace"
@attribute [Authorize]
@inject MarketplaceService MarketplaceService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using Solodoc.Shared.Onboarding
@using Solodoc.Shared.Marketplace
@using System.Security.Claims

<PageTitle>Solodoc - Malbutikk</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/checklists" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Malbutikk</MudText>
</MudStack>

@* ── Pricing banner ── *@
<MudPaper Elevation="0" Style="border:1px solid #C7D2FE;border-radius:12px;background:linear-gradient(135deg,#EBF0FF,#F8FAFF);" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap:wrap;gap:12px;">
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Ferdiglagde maler for din bransje</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Profesjonelle sjekklister og skjemaer — kjøp og bruk med ett klikk.</MudText>
        </div>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <div style="text-align:center;padding:8px 16px;background:#fff;border-radius:8px;border:1px solid #e9ecef;">
                <div style="font-weight:700;color:#4361EE;">kr @(PricingConfig.SingleTemplatePrice)</div>
                <div style="font-size:0.6rem;color:#9CA3AF;">per mal</div>
            </div>
            <div style="text-align:center;padding:8px 16px;background:#fff;border-radius:8px;border:1px solid #10B981;">
                <div style="font-weight:700;color:#059669;">kr @(PricingConfig.Pack10Price)</div>
                <div style="font-size:0.6rem;color:#9CA3AF;">10-pakke</div>
            </div>
            <div style="text-align:center;padding:8px 16px;background:#D1FAE5;border-radius:8px;border:1px solid #10B981;">
                <div style="font-weight:700;color:#059669;">kr @(PricingConfig.Pack50Price)</div>
                <div style="font-size:0.6rem;color:#059669;">50+ maler</div>
            </div>
        </MudStack>
    </MudStack>
</MudPaper>

@* ── Category filter ── *@
@{
    var categories = _templates.GroupBy(t => t.Category).Select(g => g.Key).OrderBy(c => c).ToList();
}
<MudStack Row="true" Spacing="1" Class="mb-4" Style="flex-wrap:wrap;">
    <MudChip T="string" OnClick="() => _filter = null"
             Variant="@(_filter is null ? Variant.Filled : Variant.Outlined)" Color="Color.Primary"
             Style="text-transform:none;">Alle (@_templates.Count)</MudChip>
    @foreach (var cat in categories)
    {
        var count = _templates.Count(t => t.Category == cat);
        var capturedCat = cat;
        <MudChip T="string" OnClick="() => _filter = capturedCat"
                 Variant="@(_filter == capturedCat ? Variant.Filled : Variant.Outlined)" Color="Color.Primary"
                 Style="text-transform:none;">@cat (@count)</MudChip>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @* ── Template grid ── *@
    <MudGrid Spacing="3">
        @foreach (var tmpl in FilteredTemplates)
        {
            var capturedTmpl = tmpl;
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Style="@($"border:1px solid {(tmpl.AlreadyPurchased ? "#D1FAE5" : "#e9ecef")};border-radius:12px;height:100%;")" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <div style="@($"width:36px;height:36px;border-radius:8px;background:{(tmpl.Color ?? "#4361EE")};color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.8rem;flex-shrink:0;")">
                                @tmpl.Name[0]
                            </div>
                            <div style="flex:1;min-width:0;">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@tmpl.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@tmpl.Category · @tmpl.ItemCount punkter</MudText>
                            </div>
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(tmpl.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-size:0.8rem;">@tmpl.Description</MudText>
                        }
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2" Style="font-weight:600;color:#4361EE;">kr @tmpl.PriceKr</MudText>
                            @if (tmpl.AlreadyPurchased)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Style="height:28px;">
                                    Kjøpt
                                </MudChip>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           OnClick="() => BuyTemplate(capturedTmpl)"
                                           Disabled="_buying"
                                           Style="text-transform:none;border-radius:8px;">
                                    Kjøp
                                </MudButton>
                            }
                        </MudStack>
                        @if (tmpl.PurchaseCount > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@tmpl.PurchaseCount bedrifter bruker denne</MudText>
                        }

                        @* Admin controls *@
                        @if (_isAdmin)
                        {
                            <MudStack Row="true" Spacing="1" Style="margin-top:4px;">
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="() => OpenEditDialog(capturedTmpl)"
                                           Style="text-transform:none;font-size:0.75rem;">Rediger</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.VisibilityOff"
                                           OnClick="() => HideTemplate(capturedTmpl)"
                                           Style="text-transform:none;font-size:0.75rem;color:#F59E0B;">Skjul</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="() => DeleteTemplate(capturedTmpl)"
                                           Style="text-transform:none;font-size:0.75rem;">Slett</MudButton>
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    @if (FilteredTemplates.Count == 0)
    {
        <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-8">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Secondary" />
                <MudText Color="Color.Secondary">Ingen maler i denne kategorien ennå.</MudText>
            </MudStack>
        </MudPaper>
    }
}

@* ── Bundle CTA ── *@
<MudPaper Elevation="0" Style="border:2px solid #059669;border-radius:12px;background:#F0FDF4;" Class="pa-4 mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap:wrap;gap:12px;">
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;color:#059669;">Spar med pakker</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                10 maler for kr @(PricingConfig.Pack10Price) ·
                20 maler for kr @(PricingConfig.Pack20Price) ·
                50+ maler for kr @(PricingConfig.Pack50Price)
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   Style="text-transform:none;border-radius:8px;"
                   OnClick="OrderPack">
            Bestill pakke
        </MudButton>
    </MudStack>
</MudPaper>

@* ── My purchases ── *@
@if (_purchases.Count > 0)
{
    <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mt-4 mb-2">Mine kjøp</MudText>
    <MudSimpleTable Dense="true" Hover="true" Style="border:1px solid #e9ecef;border-radius:8px;">
        <thead>
            <tr>
                <th>Mal</th>
                <th>Pris</th>
                <th>Dato</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in _purchases)
            {
                var capturedP = p;
                <tr>
                    <td style="font-weight:500;">@p.TemplateName</td>
                    <td>kr @p.PriceKr</td>
                    <td>@p.PurchasedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    <td>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                   OnClick="() => GoToTemplate(capturedP.CopiedTemplateId)"
                                   Style="text-transform:none;">
                            Åpne
                        </MudButton>
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@* ── Edit Dialog ── *@
<MudDialog @bind-Visible="_editOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Rediger mal i butikk</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" @bind-Value="_editName" Label="Navn" Variant="Variant.Outlined" />
            <MudTextField T="string" @bind-Value="_editDescription" Label="Beskrivelse" Variant="Variant.Outlined" Lines="2" />
            <MudSelect T="string" @bind-Value="_editCategory" Label="Kategori" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("Bygg")">Bygg</MudSelectItem>
                <MudSelectItem T="string" Value="@("Elektro")">Elektro</MudSelectItem>
                <MudSelectItem T="string" Value="@("HMS")">HMS</MudSelectItem>
                <MudSelectItem T="string" Value="@("Rørlegger")">Rørlegger</MudSelectItem>
                <MudSelectItem T="string" Value="@("Landbruk")">Landbruk</MudSelectItem>
                <MudSelectItem T="string" Value="@("Generell")">Generell</MudSelectItem>
            </MudSelect>
            <MudNumericField T="int" @bind-Value="_editPrice" Label="Pris (kr)" Variant="Variant.Outlined" Min="0" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _editOpen = false" Style="text-transform:none;">Avbryt</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit"
                   Style="text-transform:none;border-radius:8px;">Lagre</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<MarketplaceListItemDto> _templates = [];
    private List<PurchaseDto> _purchases = [];
    private string? _filter;
    private bool _loading = true;
    private bool _buying;
    private bool _isAdmin;

    // Edit dialog
    private bool _editOpen;
    private Guid _editId;
    private string _editName = "";
    private string _editDescription = "";
    private string _editCategory = "Generell";
    private int _editPrice = 49;

    private List<MarketplaceListItemDto> FilteredTemplates =>
        _filter is null ? _templates : _templates.Where(t => t.Category == _filter).ToList();

    protected override async Task OnInitializedAsync()
    {
        // Check admin status
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var role = auth.User.FindFirst("role")?.Value
                       ?? auth.User.FindFirst(ClaimTypes.Role)?.Value;
            _isAdmin = role is "super-admin" or "tenant-admin";
        }
        catch { }

        var templatesTask = MarketplaceService.GetTemplatesAsync();
        var purchasesTask = MarketplaceService.GetPurchasesAsync();
        _templates = await templatesTask;
        _purchases = await purchasesTask;
        _loading = false;
    }

    private async Task BuyTemplate(MarketplaceListItemDto tmpl)
    {
        _buying = true;
        StateHasChanged();

        var result = await MarketplaceService.BuyAsync(tmpl.Id);
        if (result is not null)
        {
            Snackbar.Add($"{tmpl.Name} kjøpt! Malen er lagt til i dine sjekklister.", Severity.Success);
            _templates = await MarketplaceService.GetTemplatesAsync();
            _purchases = await MarketplaceService.GetPurchasesAsync();
        }
        else
        {
            Snackbar.Add("Kunne ikke kjøpe malen. Prøv igjen.", Severity.Error);
        }
        _buying = false;
    }

    private void OpenEditDialog(MarketplaceListItemDto tmpl)
    {
        _editId = tmpl.Id;
        _editName = tmpl.Name;
        _editDescription = tmpl.Description ?? "";
        _editCategory = tmpl.Category;
        _editPrice = tmpl.PriceKr;
        _editOpen = true;
    }

    private async Task SaveEdit()
    {
        var ok = await MarketplaceService.UpdateAsync(_editId, new(_editName, _editDescription, _editCategory, null, _editPrice));
        if (ok)
        {
            Snackbar.Add("Oppdatert!", Severity.Success);
            _editOpen = false;
            _templates = await MarketplaceService.GetTemplatesAsync();
        }
        else
        {
            Snackbar.Add("Kunne ikke oppdatere", Severity.Error);
        }
    }

    private async Task HideTemplate(MarketplaceListItemDto tmpl)
    {
        var ok = await MarketplaceService.UnpublishAsync(tmpl.Id);
        if (ok)
        {
            Snackbar.Add($"{tmpl.Name} skjult fra butikken", Severity.Info);
            _templates = await MarketplaceService.GetTemplatesAsync();
        }
    }

    private async Task DeleteTemplate(MarketplaceListItemDto tmpl)
    {
        var ok = await MarketplaceService.DeleteAsync(tmpl.Id);
        if (ok)
        {
            Snackbar.Add($"{tmpl.Name} slettet", Severity.Success);
            _templates = await MarketplaceService.GetTemplatesAsync();
        }
        else
        {
            Snackbar.Add("Kunne ikke slette — har noen kjøpt denne?", Severity.Error);
        }
    }

    private void OrderPack() => Snackbar.Add("Kontakt oss for å bestille en pakke: kontakt@solodoc.no", Severity.Info);
    private void GoToTemplate(Guid id) => Navigation.NavigateTo($"/checklists/templates/{id}");
}
