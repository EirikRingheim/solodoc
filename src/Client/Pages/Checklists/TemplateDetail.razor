@page "/checklists/templates/{Id:guid}"
@attribute [Authorize]
@inject ChecklistService ChecklistService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - @(_template?.Name ?? "Mal")</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/checklists" />
    @if (_loading)
    {
        <MudText Typo="Typo.h5">Laster...</MudText>
    }
    else if (_template is not null)
    {
        @if (_editingName)
        {
            <MudTextField T="string" @bind-Value="_editName" Variant="Variant.Outlined" Dense="true"
                          Style="max-width:400px;"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Check"
                          OnAdornmentClick="SaveName" OnBlur="SaveName"
                          Placeholder="Malnavn" />
        }
        else
        {
            <MudText Typo="Typo.h5" Style="font-weight:600;cursor:pointer;" @onclick="StartEditName">
                @_template.Name
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="StartEditName" />
        }
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.ContentCopy"
                   OnClick="DuplicateTemplate" Disabled="_duplicating"
                   Style="text-transform:none;border-radius:8px;">
            Dupliser
        </MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_template is null)
{
    <MudAlert Severity="Severity.Warning">Mal ikke funnet.</MudAlert>
}
else
{
    <div style="max-width:720px;">
        @* ── Description & Category ── *@
        <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-4 mb-4">
            <MudStack Spacing="2">
                <MudTextField T="string" @bind-Value="_settingsDescription" Label="Beskrivelse (valgfritt)"
                              Variant="Variant.Outlined" Lines="2"
                              DebounceInterval="600" OnDebounceIntervalElapsed="SaveSettings" />
                <MudStack Row="true" Spacing="2">
                    <MudTextField T="string" @bind-Value="_settingsCategory" Label="Kategori"
                                  Variant="Variant.Outlined" Style="flex:1;"
                                  DebounceInterval="600" OnDebounceIntervalElapsed="SaveSettings" />
                    <MudSwitch T="bool" @bind-Value="_settingsRequireSignature" Label="Krev signatur"
                               Color="Color.Primary" @bind-Value:after="SaveSettings" />
                </MudStack>
            </MudStack>
        </MudPaper>

        @* ── Items list ── *@
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">
            Elementer (@_template.Items.Count)
        </MudText>

        @if (_template.Items.Count == 0)
        {
            <MudPaper Elevation="0" Style="border:2px dashed #d1d5db;border-radius:12px;" Class="pa-8 mb-4">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Color="Color.Secondary">Legg til elementer nedenfor</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            @foreach (var item in _template.Items.OrderBy(i => i.SortOrder))
            {
                var capturedItem = item;
                <MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-0 mb-2">
                    <div style="display:flex;align-items:stretch;">
                        @* Left color bar indicating type *@
                        <div style="width:5px;border-radius:12px 0 0 12px;background:@GetTypeColor(item.Type);flex-shrink:0;"></div>

                        <div style="flex:1;padding:12px 14px;">
                            @* Top row: number + label + actions *@
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span style="font-size:0.7rem;font-weight:700;color:#9CA3AF;min-width:20px;">@item.SortOrder</span>

                                @* Type preview icon *@
                                <MudIcon Icon="@GetTypeIcon(item.Type)" Size="Size.Small" Style="@($"color:{GetTypeColor(item.Type)};")" />

                                @* Editable label *@
                                @if (_editingItemId == item.Id)
                                {
                                    <MudTextField T="string" @bind-Value="_editItemLabel" Variant="Variant.Text"
                                                  Dense="true" Style="flex:1;" Immediate="true"
                                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Check"
                                                  OnAdornmentClick="() => SaveItemLabel(capturedItem)"
                                                  OnBlur="() => SaveItemLabel(capturedItem)" />
                                }
                                else
                                {
                                    <span style="flex:1;font-weight:500;cursor:pointer;"
                                          @onclick="() => StartEditItemLabel(capturedItem)">
                                        @item.Label
                                    </span>
                                }

                                @* Type badge *@
                                <span style="font-size:0.65rem;padding:2px 8px;border-radius:10px;background:@(GetTypeColor(item.Type) + "18");color:@GetTypeColor(item.Type);font-weight:600;white-space:nowrap;">
                                    @GetTypeLabel(item.Type)
                                </span>

                                @* Actions *@
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                               OnClick="() => MoveItemUp(capturedItem)" Disabled="item.SortOrder <= 1"
                                               Style="padding:4px;" />
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                               OnClick="() => MoveItemDown(capturedItem)"
                                               Style="padding:4px;" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Color="Color.Error" OnClick="() => DeleteItem(capturedItem)"
                                               Style="padding:4px;" />
                            </div>

                            @* Type-specific preview / settings (inline) *@
                            @if (item.Type == "Check")
                            {
                                <div style="margin-top:8px;display:flex;gap:6px;">
                                    <span style="padding:4px 14px;border-radius:8px;background:#D1FAE5;color:#059669;font-size:0.75rem;font-weight:600;">OK</span>
                                    <span style="padding:4px 14px;border-radius:8px;background:#F3F4F6;color:#6B7280;font-size:0.75rem;font-weight:600;">Ikke relevant</span>
                                </div>
                            }
                            else if (item.Type == "TextInput")
                            {
                                <div style="margin-top:8px;padding:8px 10px;border:1px solid #e5e7eb;border-radius:8px;color:#9CA3AF;font-size:0.8rem;">
                                    Fritekst...
                                </div>
                            }
                            else if (item.Type == "NumberInput")
                            {
                                <div style="margin-top:8px;display:flex;gap:8px;align-items:center;">
                                    <div style="flex:1;padding:8px 10px;border:1px solid #e5e7eb;border-radius:8px;color:#9CA3AF;font-size:0.8rem;">
                                        0
                                    </div>
                                    <MudTextField T="string" Value="@(item.UnitLabel ?? "")" Variant="Variant.Outlined"
                                                  Dense="true" Placeholder="Enhet" Style="max-width:100px;"
                                                  DebounceInterval="600"
                                                  ValueChanged="(string val) => UpdateItemUnitLabel(capturedItem, val)" />
                                </div>
                            }
                            else if (item.Type == "DateInput")
                            {
                                <div style="margin-top:8px;padding:8px 10px;border:1px solid #e5e7eb;border-radius:8px;color:#9CA3AF;font-size:0.8rem;display:flex;align-items:center;gap:6px;">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Color="Color.Secondary" />
                                    dd.mm.yyyy
                                </div>
                            }
                            else if (item.Type == "Dropdown")
                            {
                                <div style="margin-top:8px;">
                                    <MudTextField T="string" Value="@(item.DropdownOptions ?? "")"
                                                  Variant="Variant.Outlined" Dense="true"
                                                  Placeholder="Alternativ 1, Alternativ 2, Alternativ 3"
                                                  HelperText="Kommaseparerte valg"
                                                  DebounceInterval="600"
                                                  ValueChanged="(string val) => UpdateItemDropdownOptions(capturedItem, val)" />
                                </div>
                            }
                            else if (item.Type == "Photo")
                            {
                                <div style="margin-top:8px;padding:12px;border:2px dashed #d1d5db;border-radius:8px;text-align:center;color:#9CA3AF;font-size:0.8rem;">
                                    <MudIcon Icon="@Icons.Material.Filled.CameraAlt" Size="Size.Small" Color="Color.Secondary" />
                                    Ta bilde eller last opp
                                </div>
                            }
                            else if (item.Type == "Signature")
                            {
                                <div style="margin-top:8px;padding:12px;border:2px dashed #d1d5db;border-radius:8px;text-align:center;color:#9CA3AF;font-size:0.8rem;">
                                    <MudIcon Icon="@Icons.Material.Filled.Draw" Size="Size.Small" Color="Color.Secondary" />
                                    Signatur
                                </div>
                            }
                        </div>
                    </div>
                </MudPaper>
            }
        }

        @* ── Add element buttons ── *@
        <MudPaper Elevation="0" Style="border:2px dashed #4361EE40;border-radius:12px;background:#F8FAFF;" Class="pa-4 mb-4">
            <MudText Typo="Typo.caption" Style="font-weight:600;color:#4361EE;" Class="mb-2">LEGG TIL ELEMENT</MudText>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                @foreach (var t in _itemTypes)
                {
                    var type = t.Key;
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@GetTypeIcon(type)"
                               OnClick="() => AddItem(type)"
                               Disabled="_addingItem"
                               Style="@($"text-transform:none;border-radius:8px;border-color:{GetTypeColor(type)}40;color:{GetTypeColor(type)};")">
                        @t.Value
                    </MudButton>
                }
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ChecklistTemplateDetailDto? _template;
    private bool _loading = true;
    private bool _duplicating;
    private bool _addingItem;

    // Name editing
    private bool _editingName;
    private string _editName = "";

    // Item label editing
    private Guid? _editingItemId;
    private string _editItemLabel = "";

    // Settings
    private string _settingsDescription = "";
    private string _settingsCategory = "";
    private bool _settingsRequireSignature;

    private static readonly Dictionary<string, string> _itemTypes = new()
    {
        ["Check"] = "Sjekkpunkt",
        ["TextInput"] = "Tekstfelt",
        ["NumberInput"] = "Tallfelt",
        ["DateInput"] = "Dato",
        ["Dropdown"] = "Nedtrekk",
        ["Photo"] = "Foto",
        ["Signature"] = "Signatur"
    };

    protected override async Task OnInitializedAsync() => await LoadTemplate();

    private async Task LoadTemplate()
    {
        _loading = true;
        _template = await ChecklistService.GetTemplateByIdAsync(Id);
        if (_template is not null)
        {
            _settingsDescription = _template.Description ?? "";
            _settingsCategory = _template.Category ?? "";
            _settingsRequireSignature = _template.RequireSignature;
        }
        _loading = false;
    }

    // ── Name ──

    private void StartEditName()
    {
        if (_template is null) return;
        _editName = _template.Name;
        _editingName = true;
    }

    private async Task SaveName()
    {
        if (_template is null || !_editingName) return;
        _editingName = false;
        if (string.IsNullOrWhiteSpace(_editName) || _editName == _template.Name) return;
        await SaveSettingsWithName(_editName);
    }

    // ── Settings ──

    private async Task SaveSettings() => await SaveSettingsWithName(_template?.Name ?? "");

    private async Task SaveSettingsWithName(string name)
    {
        if (_template is null) return;
        var request = new UpdateChecklistTemplateRequest(
            name, _settingsDescription, _settingsCategory,
            _settingsRequireSignature, _template.SignatureCount,
            _template.SignatureRoles, _template.Tags);
        var ok = await ChecklistService.UpdateTemplateAsync(Id, request);
        if (ok) await LoadTemplate();
    }

    // ── Duplicate ──

    private async Task DuplicateTemplate()
    {
        if (_template is null) return;
        _duplicating = true;
        var newId = await ChecklistService.DuplicateTemplateAsync(Id);
        _duplicating = false;
        if (newId.HasValue)
        {
            Snackbar.Add("Mal duplisert", Severity.Success);
            Navigation.NavigateTo($"/checklists/templates/{newId.Value}");
        }
    }

    // ── Item label ──

    private void StartEditItemLabel(ChecklistTemplateItemDto item)
    {
        _editingItemId = item.Id;
        _editItemLabel = item.Label;
    }

    private async Task SaveItemLabel(ChecklistTemplateItemDto item)
    {
        if (_editingItemId != item.Id) return;
        _editingItemId = null;
        if (string.IsNullOrWhiteSpace(_editItemLabel) || _editItemLabel == item.Label) return;
        await UpdateItem(item with { Label = _editItemLabel });
    }

    // ── Item CRUD ──

    private async Task AddItem(string type)
    {
        _addingItem = true;
        var maxSort = _template?.Items.Count > 0 ? _template.Items.Max(i => i.SortOrder) : 0;
        var request = new AddTemplateItemRequest(
            type, "Nytt element", false, null, null, maxSort + 1,
            type == "Dropdown" ? "Alternativ 1, Alternativ 2" : null,
            type == "NumberInput" ? "" : null,
            true, true, true); // defaults: requireCommentOnIR, allowPhoto, allowComment all ON
        var itemId = await ChecklistService.AddTemplateItemAsync(Id, request);
        _addingItem = false;
        if (itemId.HasValue)
        {
            await LoadTemplate();
            var newItem = _template?.Items.FirstOrDefault(i => i.Id == itemId.Value);
            if (newItem is not null) StartEditItemLabel(newItem);
        }
    }

    private async Task DeleteItem(ChecklistTemplateItemDto item)
    {
        await ChecklistService.DeleteTemplateItemAsync(Id, item.Id);
        await LoadTemplate();
    }

    private async Task UpdateItem(ChecklistTemplateItemDto item)
    {
        var request = new UpdateTemplateItemRequest(
            item.Label, item.IsRequired, item.HelpText, item.SectionGroup,
            item.SortOrder, item.DropdownOptions, item.UnitLabel,
            item.RequireCommentOnIrrelevant, item.AllowPhoto, item.AllowComment);
        await ChecklistService.UpdateTemplateItemAsync(Id, item.Id, request);
        await LoadTemplate();
    }

    private async Task UpdateItemUnitLabel(ChecklistTemplateItemDto item, string val)
    {
        await UpdateItem(item with { UnitLabel = string.IsNullOrWhiteSpace(val) ? null : val });
    }

    private async Task UpdateItemDropdownOptions(ChecklistTemplateItemDto item, string val)
    {
        await UpdateItem(item with { DropdownOptions = string.IsNullOrWhiteSpace(val) ? null : val });
    }

    // ── Reorder ──

    private async Task MoveItemUp(ChecklistTemplateItemDto item)
    {
        var items = _template!.Items.OrderBy(i => i.SortOrder).ToList();
        var idx = items.IndexOf(item);
        if (idx <= 0) return;
        var prev = items[idx - 1];
        await SwapOrder(item, prev);
    }

    private async Task MoveItemDown(ChecklistTemplateItemDto item)
    {
        var items = _template!.Items.OrderBy(i => i.SortOrder).ToList();
        var idx = items.IndexOf(item);
        if (idx < 0 || idx >= items.Count - 1) return;
        var next = items[idx + 1];
        await SwapOrder(item, next);
    }

    private async Task SwapOrder(ChecklistTemplateItemDto a, ChecklistTemplateItemDto b)
    {
        var aSort = a.SortOrder;
        var bSort = b.SortOrder;
        await ChecklistService.UpdateTemplateItemAsync(Id, a.Id,
            new(a.Label, a.IsRequired, a.HelpText, a.SectionGroup, bSort, a.DropdownOptions, a.UnitLabel, a.RequireCommentOnIrrelevant, a.AllowPhoto, a.AllowComment));
        await ChecklistService.UpdateTemplateItemAsync(Id, b.Id,
            new(b.Label, b.IsRequired, b.HelpText, b.SectionGroup, aSort, b.DropdownOptions, b.UnitLabel, b.RequireCommentOnIrrelevant, b.AllowPhoto, b.AllowComment));
        await LoadTemplate();
    }

    // ── Helpers ──

    private static string GetTypeIcon(string type) => type switch
    {
        "Check" => Icons.Material.Filled.CheckBox,
        "TextInput" => Icons.Material.Filled.TextFields,
        "NumberInput" => Icons.Material.Filled.Numbers,
        "DateInput" => Icons.Material.Filled.CalendarMonth,
        "Dropdown" => Icons.Material.Filled.ArrowDropDown,
        "Photo" => Icons.Material.Filled.CameraAlt,
        "Signature" => Icons.Material.Filled.Draw,
        _ => Icons.Material.Filled.HelpOutline
    };

    private static string GetTypeLabel(string type) => type switch
    {
        "Check" => "Sjekkpunkt",
        "TextInput" => "Tekst",
        "NumberInput" => "Tall",
        "DateInput" => "Dato",
        "Dropdown" => "Nedtrekk",
        "Photo" => "Foto",
        "Signature" => "Signatur",
        _ => type
    };

    private static string GetTypeColor(string type) => type switch
    {
        "Check" => "#10B981",
        "TextInput" => "#4361EE",
        "NumberInput" => "#EA580C",
        "DateInput" => "#7C3AED",
        "Dropdown" => "#0891B2",
        "Photo" => "#E63946",
        "Signature" => "#D97706",
        _ => "#6B7280"
    };
}
