@inject EmployeeService EmployeeService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        @if (_inviteUrl is not null)
        {
            @* ── Success: show link ── *@
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Invitasjon opprettet!</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align:center;">
                    Send denne lenken til <b>@_email</b> via SMS, e-post eller melding.
                </MudText>
                <div style="width:100%;background:#F8F9FA;border:1px solid #E9ECEF;border-radius:8px;padding:12px;word-break:break-all;font-family:monospace;font-size:0.8rem;">
                    @_inviteFullUrl
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="CopyLink"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           Style="text-transform:none;border-radius:8px;">
                    Kopier lenke
                </MudButton>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Lenken utløper om 30 dager</MudText>
            </MudStack>
        }
        else
        {
            @* ── Form ── *@
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_email" Label="E-postadresse" Variant="Variant.Outlined"
                              Required="true" RequiredError="E-post er påkrevd"
                              InputType="InputType.Email"
                              Placeholder="navn@eksempel.no" />
                <MudSelect T="string" @bind-Value="_role" Label="Rolle" Variant="Variant.Outlined"
                           Required="true" RequiredError="Rolle er påkrevd">
                    <MudSelectItem T="string" Value="@("feltarbeider")">Feltarbeider</MudSelectItem>
                    <MudSelectItem T="string" Value="@("prosjektleder")">Prosjektleder</MudSelectItem>
                    <MudSelectItem T="string" Value="@("admin")">Administrator</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Personen får en lenke for å opprette konto og bli med i bedriften din.
                </MudText>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (_inviteUrl is not null)
        {
            <MudButton OnClick="() => { _inviteUrl = null; _email = null; }" Style="text-transform:none;">Inviter en til</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close"
                       Style="text-transform:none;border-radius:8px;">Ferdig</MudButton>
        }
        else
        {
            <MudButton OnClick="Cancel" Style="text-transform:none;">Avbryt</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       Style="text-transform:none;border-radius:8px;"
                       Disabled="@(_submitting || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_role))"
                       OnClick="Submit">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Opprett invitasjon
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private string? _email;
    private string? _role = "feltarbeider";
    private bool _submitting;
    private string? _inviteUrl;
    private string? _inviteFullUrl;

    private void Cancel() => MudDialog.Cancel();
    private void Close() => MudDialog.Close(DialogResult.Ok(true));

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_role))
            return;

        _submitting = true;
        var inviteId = await EmployeeService.InviteAsync(new InviteEmployeeRequest(_email.Trim(), _role));
        _submitting = false;

        if (inviteId is not null)
        {
            _inviteUrl = $"/invite/{inviteId}";
            _inviteFullUrl = $"{Navigation.BaseUri.TrimEnd('/')}/invite/{inviteId}";
        }
        else
        {
            Snackbar.Add(EmployeeService.LastInviteError ?? "Kunne ikke opprette invitasjon", Severity.Error);
        }
    }

    private async Task CopyLink()
    {
        if (_inviteFullUrl is null) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _inviteFullUrl);
            Snackbar.Add("Lenke kopiert!", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Kunne ikke kopiere — merk og kopier manuelt", Severity.Info);
        }
    }
}
