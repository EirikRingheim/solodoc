        {
            { x => x.ContentText, $"Er du sikker på at du vil suspendere {_employee?.FullName}?" },
            { x => x.ButtonText, "Suspender" },
            { x => x.ButtonColor, Color.Warning }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Suspender ansatt", parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            var success = await EmployeeService.SuspendAsync(PersonId);
            if (success)
            {
                Snackbar.Add("Ansatt suspendert", Severity.Success);
                await LoadData();
