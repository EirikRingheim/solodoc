    private async Task PrevEmpMonth()
    {
        _empHeatmapMonth = _empHeatmapMonth.AddMonths(-1);
        await ReloadEmpHeatmap();
    }

    private async Task NextEmpMonth()
    {
        _empHeatmapMonth = _empHeatmapMonth.AddMonths(1);
        await ReloadEmpHeatmap();
    }

    private async Task ReloadEmpHeatmap()
    {
        var lastOfMonth = _empHeatmapMonth.AddMonths(1).AddDays(-1);
        var fullHeatmap = await HoursService.GetHeatmapAsync(_empHeatmapMonth, lastOfMonth);
        if (fullHeatmap is not null)
        {
            var empRow = fullHeatmap.Rows.FirstOrDefault(r => r.PersonId == PersonId);
            _empHeatmap = empRow is not null ? new HoursHeatmapDto([empRow], fullHeatmap.Dates) : null;
        }
        else _empHeatmap = null;
        StateHasChanged();
    }

    private async Task ApproveAbsenceApplication(Guid absenceId)
    {
        var success = await HoursService.ApproveAbsenceAsync(absenceId);
        if (success)
        {
            Snackbar.Add("Soknad godkjent", Severity.Success);
            _empBalance = await HoursService.GetEmployeeBalanceAsync(PersonId);
            _empAbsences = await HoursService.GetMyAbsencesAsync(DateTime.Today.Year);
            StateHasChanged();
        }
        else Snackbar.Add("Kunne ikke godkjenne", Severity.Error);
    }

    private async Task RejectAbsenceApplication(Guid absenceId)
    {
        var success = await HoursService.RejectAbsenceAsync(absenceId);
        if (success)
        {
            Snackbar.Add("Soknad avvist", Severity.Success);
            _empAbsences = await HoursService.GetMyAbsencesAsync(DateTime.Today.Year);
            StateHasChanged();
        }
        else Snackbar.Add("Kunne ikke avvise", Severity.Error);
    }

    private async Task ConfirmSuspend()
