@page "/machines/new"
@attribute [Authorize]
@inject EquipmentService EquipmentService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Solodoc - Nytt utstyr</PageTitle>

<MudButton Variant="Variant.Text" Color="Color.Default" Href="/machines"
           StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2"
           Style="text-transform:none;">
    Tilbake
</MudButton>

<MudText Typo="Typo.h5" Class="mb-4">Nytt utstyr</MudText>

<MudPaper Elevation="0" Style="border:1px solid #e9ecef;border-radius:12px;" Class="pa-4">
    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.Name" Label="Navn" Required="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.Type" Label="Type"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.RegistrationNumber" Label="Reg.nummer"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_model.SerialNumber" Label="Serienummer"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_model.Year" Label="Arsmodell"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_model.Make" Label="Merke"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_model.Model" Label="Modell"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" Disabled="_saving"
                           Style="text-transform:none;border-radius:8px;">
                    @if (_saving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Opprett
                </MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    private EquipmentFormModel _model = new();
    private bool _saving;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_model.Name)) return;

        _saving = true;
        var request = new CreateEquipmentRequest(
            _model.Name,
            _model.Type,
            _model.RegistrationNumber,
            _model.SerialNumber,
            _model.Year,
            _model.Make,
            _model.Model);

        var id = await EquipmentService.CreateEquipmentAsync(request);
        _saving = false;

        if (id.HasValue)
        {
            Snackbar.Add("Utstyr opprettet", Severity.Success);
            Navigation.NavigateTo($"/machines/{id.Value}");
        }
        else
        {
            Snackbar.Add("Kunne ikke opprette utstyret", Severity.Error);
        }
    }

    private class EquipmentFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Type { get; set; }
        public string? RegistrationNumber { get; set; }
        public string? SerialNumber { get; set; }
        public int? Year { get; set; }
        public string? Make { get; set; }
        public string? Model { get; set; }
    }
}
