@page "/admin/qr-card/{SiteType}/{SiteId:guid}"
@attribute [Authorize]
@inject CheckInService CheckInService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Solodoc.Shared.CheckIn

<PageTitle>QR-kode - Solodoc</PageTitle>

@if (_loading)
{
    <div style="display:flex;align-items:center;justify-content:center;min-height:60vh;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else if (_info is null)
{
    <MudAlert Severity="Severity.Warning" Class="ma-4">
        Ingen QR-kode funnet. Generer en QR-kode først.
    </MudAlert>
    <MudButton Variant="Variant.Outlined" OnClick="GenerateAndReload"
               Style="margin:16px;border-radius:8px;text-transform:none;">
        Generer QR-kode
    </MudButton>
}
else
{
    var accent = _info.AccentColor ?? "#00B5A6";
    var accentLight = accent + "12";
    var siteLabel = _info.SiteType switch
    {
        "Prosjekt" or "project" => "PROSJEKT",
        "Lokasjon" or "location" => "LOKASJON",
        _ => "OPPDRAG"
    };

    @* ── Toolbar ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4 px-2">
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="GoBack" Style="text-transform:none;">
            Tilbake
        </MudButton>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="DownloadQr"
                       Style="border-radius:8px;text-transform:none;">
                Last ned
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Print"
                       OnClick="PrintCard"
                       Style="@($"border-radius:8px;text-transform:none;background:{accent};color:#fff;")">
                Skriv ut
            </MudButton>
        </MudStack>
    </MudStack>

    @* ── Printable card ── *@
    <div style="display:flex;justify-content:center;padding:16px;">
        <div id="qr-print-card" style="@($"width:360px;border:2px solid {accent};border-radius:24px;overflow:hidden;background:#fff;box-shadow:0 8px 32px rgba(0,0,0,0.08);font-family:Inter,sans-serif;")">
            @* Top accent bar *@
            <div style="@($"height:8px;background:linear-gradient(90deg, {accent}, {accent}AA);")"></div>

            @* Company header *@
            <div style="@($"padding:28px 24px 20px;text-align:center;background:{accentLight};")">
                @if (!string.IsNullOrEmpty(_info.LogoUrl))
                {
                    <img src="@_info.LogoUrl" alt="@_info.TenantName"
                         style="max-height:56px;max-width:180px;object-fit:contain;margin-bottom:12px;" />
                }
                else if (!string.IsNullOrEmpty(_info.TenantName))
                {
                    <div style="@($"font-size:1.25rem;font-weight:700;color:{accent};margin-bottom:8px;")">
                        @_info.TenantName
                    </div>
                }
            </div>

            @* QR code area *@
            <div style="padding:20px 40px;text-align:center;">
                <div id="qr-container" style="display:inline-block;"></div>
            </div>

            @* Site info *@
            <div style="padding:0 24px 24px;text-align:center;">
                <div style="@($"display:inline-block;padding:4px 14px;border-radius:16px;background:{accent};color:#fff;font-size:0.65rem;font-weight:600;letter-spacing:1px;margin-bottom:10px;")">
                    @siteLabel
                </div>
                <div style="font-size:1.3rem;font-weight:700;color:#1a1a2e;line-height:1.3;">
                    @_info.SiteName
                </div>
            </div>

            @* Instruction *@
            <div style="@($"padding:16px 24px;text-align:center;border-top:1px solid {accent}20;")">
                <div style="display:flex;align-items:center;justify-content:center;gap:8px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="@accent" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                        <circle cx="12" cy="13" r="4"/>
                    </svg>
                    <span style="@($"font-size:0.85rem;font-weight:500;color:{accent};")">
                        Skann med kamera for innsjekking
                    </span>
                </div>
            </div>

            @* Bottom bar *@
            <div style="@($"height:6px;background:linear-gradient(90deg, {accent}, {accent}AA);")"></div>
        </div>
    </div>

    @* Regenerate option *@
    <div style="text-align:center;margin-top:24px;">
        <MudButton Variant="Variant.Text" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RegenerateQr"
                   Style="text-transform:none;color:#6B7280;">
            Generer ny QR-kode (deaktiverer gammel)
        </MudButton>
    </div>
}

@code {
    [Parameter] public string SiteType { get; set; } = "";
    [Parameter] public Guid SiteId { get; set; }

    private QrCodeInfoDto? _info;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBranding();
    }

    private async Task LoadBranding()
    {
        _loading = true;
        _info = await CheckInService.GetQrBrandingAsync(SiteType, SiteId);

        // If no slug yet, generate one
        if (_info is not null && string.IsNullOrEmpty(_info.Slug))
        {
            var slug = await CheckInService.GenerateQrSlugAsync(SiteType, SiteId);
            if (slug is not null)
                _info = await CheckInService.GetQrBrandingAsync(SiteType, SiteId);
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_info is not null && !string.IsNullOrEmpty(_info.Slug))
        {
            var qrUrl = $"{Navigation.BaseUri}checkin/qr/{_info.Slug}";
            var accent = _info.AccentColor ?? "#00B5A6";
            await JS.InvokeVoidAsync("qrInterop.render",
                "qr-container", qrUrl, _info.LogoUrl, accent, 280);
        }
    }

    private async Task DownloadQr()
    {
        var siteName = _info?.SiteName?.Replace(" ", "-") ?? "qr";
        await JS.InvokeVoidAsync("qrInterop.download", "qr-container", $"solodoc-qr-{siteName}");
    }

    private async Task PrintCard()
    {
        await JS.InvokeVoidAsync("qrInterop.printElement", "qr-print-card");
    }

    private async Task GenerateAndReload()
    {
        var slug = await CheckInService.GenerateQrSlugAsync(SiteType, SiteId);
        if (slug is not null)
        {
            await LoadBranding();
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Kunne ikke generere QR-kode.", Severity.Error);
        }
    }

    private async Task RegenerateQr()
    {
        var slug = await CheckInService.GenerateQrSlugAsync(SiteType, SiteId);
        if (slug is not null)
        {
            _info = await CheckInService.GetQrBrandingAsync(SiteType, SiteId);
            StateHasChanged();
            // Re-render QR after state update
            await Task.Delay(100);
            if (_info is not null)
            {
                var qrUrl = $"{Navigation.BaseUri}checkin/qr/{_info.Slug}";
                var accent = _info.AccentColor ?? "#00B5A6";
                await JS.InvokeVoidAsync("qrInterop.render",
                    "qr-container", qrUrl, _info.LogoUrl, accent, 280);
            }
            Snackbar.Add("Ny QR-kode generert. Gammel kode er deaktivert.", Severity.Success);
        }
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");
}
