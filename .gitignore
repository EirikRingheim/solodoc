# =============================================================================
# Solodoc .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# .NET / C#
# -----------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
[Tt]est[Rr]esult*/
[Dd]ebugPublic/
[Rr]eleases/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
[Ll]og/

# Rider / JetBrains
.idea/
*.sln.iml

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# User secrets (NEVER commit)
**/Properties/launchSettings.json

# Published output
publish/
PublishOutput/

# -----------------------------------------------------------------------------
# Node.js (for Playwright E2E tests, tooling)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Environment & Secrets (NEVER commit)
# -----------------------------------------------------------------------------
appsettings.Development.json
appsettings.Staging.json
# appsettings.Production.json is safe to commit (secrets come from env vars)
*.local
.env
.env.*
!.env.example
!deploy/.env.production.template

# -----------------------------------------------------------------------------
# Docker (local data volumes)
# -----------------------------------------------------------------------------
docker-data/
postgres-data/
minio-data/
seq-data/

# -----------------------------------------------------------------------------
# MinIO / S3 (local upload data)
# -----------------------------------------------------------------------------
/data/
uploads/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
Logs/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Large / Binary Files (never commit these)
# -----------------------------------------------------------------------------
*.pdf
*.xlsx
*.docx
*.pptx
*.zip
*.tar.gz
*.rar
*.7z
*.mp4
*.mov
*.avi
*.mp3
*.wav
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.heic
*.webp
*.ico
*.svg

# EXCEPTIONS: allow specific checked-in assets
!src/Client/wwwroot/favicon.ico
!src/Client/wwwroot/icon-*.png
!src/Client/wwwroot/images/**
!docs/**/*.png
!docs/**/*.svg

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
tests/E2ETests/playwright-report/
tests/E2ETests/test-results/
tests/E2ETests/blob-report/

# -----------------------------------------------------------------------------
# Coverage Reports
# -----------------------------------------------------------------------------
coverage/
*.coverage
*.coveragexml
lcov.info

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*~
.claude/settings.local.json
