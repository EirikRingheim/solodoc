# =============================================================================
# Solodoc Production Environment
# =============================================================================
# Copy to .env.production and fill in real values.
# NEVER commit this file with real secrets.
# =============================================================================

# ── Domain ───────────────────────────────────────────────
# Your domain name (e.g., app.solodoc.no)
# Caddy will automatically get HTTPS certificates for this domain
DOMAIN=app.yourdomain.no

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=solodoc
POSTGRES_USER=solodoc
POSTGRES_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE

# ── MinIO (File Storage) ────────────────────────────────
MINIO_ACCESS_KEY=solodoc-storage
MINIO_SECRET_KEY=GENERATE_A_STRONG_PASSWORD_HERE
MINIO_BUCKET=solodoc-prod

# ── JWT Authentication ───────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
JWT_ISSUER=solodoc.app
JWT_AUDIENCE=solodoc.app
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# ── Email (SMTP) ────────────────────────────────────────
# Use a transactional email provider (SendGrid, Postmark, AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
EMAIL_FROM=noreply@solodoc.no

# ── DeepL (Translation) — optional ──────────────────────
DEEPL_API_KEY=

# ── Anthropic (AI) — optional ───────────────────────────
ANTHROPIC_API_KEY=
